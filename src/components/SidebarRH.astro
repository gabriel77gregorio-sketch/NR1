---
import { supabase } from '../lib/supabase';

export interface Props {
  activeMenu?: 'inicio' | 'dashboard' | 'pesquisas' | 'planos' | 'denuncias' | 'configuracoes' | 'inteligencia-de-dados' | 'advertencias' | 'avaliacoes-individuais';
}

const { activeMenu = 'dashboard' } = Astro.props;

// SSR: Obter cliente Supabase Configurado
const supabaseClient = supabase(Astro);
let user = null;
try {
  const { data: authData } = await supabaseClient.auth.getUser();
  user = authData?.user;
} catch (e) { }

// Defaults for mock / dev locally
let data = { user: { email: 'rh@empresa.com', name: 'Gestor de RH' }, company: 'Indústria Metalúrgica SA' };

let userRole = 'RH';
let unreadNotifs = 0;

if (user) {
  data.user.email = user.email || '';
  const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome, empresa_id, role').eq('id', user.id).single();
  if (perfil) {
    data.user.name = perfil.nome;
    userRole = perfil.role;
    const { data: emp } = await supabaseClient.from('empresas').select('nome').eq('id', perfil.empresa_id).single();
    if (emp) data.company = emp.nome;
    
    // Busca notificações não lidas
    const { count } = await supabaseClient.from('notificacoes').select('*', { count: 'exact', head: true })
      .eq('usuario_id', user.id).eq('lida', false);
    unreadNotifs = count || 0;
  }
}
---

<aside class="sidebar">
  <!-- Logo / Empresa -->
  <div class="sidebar-header">
    <div class="logo-circle">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
    </div>
    <div>
      <h1 class="company-name">{data.company}</h1>
      <p class="system-tag">Módulo Compliance</p>
    </div>
  </div>
  
  <!-- Navegação -->
  <nav class="sidebar-nav">
    <ul class="nav-list">
      <li class={activeMenu === 'inicio' ? "nav-item active" : "nav-item"}>
        <a href="/rh/inicio" class="nav-link">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
          Dashboard
        </a>
      </li>

      <li class={activeMenu === 'dashboard' ? "nav-item active" : "nav-item"}>
        <a href="/rh/dashboard" class="nav-link">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path><path d="M22 12A10 10 0 0 0 12 2v10z"></path></svg>
          Matriz de Risco
        </a>
      </li>
      
      <li class={activeMenu === 'pesquisas' ? "nav-item active" : "nav-item"}>
        <a href="/rh/pesquisas" class="nav-link">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
          Disparos
        </a>
      </li>

      <li class={activeMenu === 'planos' ? "nav-item active" : "nav-item"}>
        <a href="/rh/planos-de-acao" class="nav-link">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect><path d="M9 14l2 2 4-4"></path></svg>
          Planos de Ação
        </a>
      </li>

      <li class={activeMenu === 'denuncias' ? "nav-item active" : "nav-item"}>
        <a href="/rh/denuncias" class="nav-link">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
          Denúncias
        </a>
      </li>

      <li class={activeMenu === 'advertencias' ? "nav-item active" : "nav-item"}>
        <a href="/rh/advertencias" class="nav-link">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
          Advertências
        </a>
      </li>

      <li class={activeMenu === 'avaliacoes-individuais' ? "nav-item active" : "nav-item"}>
        <a href="/rh/avaliacoes-individuais" class="nav-link">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          Avaliações
        </a>
      </li>

      {['Master', 'Diretoria', 'Segurança_Trabalho', 'RH'].includes(userRole) && (
        <li class={activeMenu === 'inteligencia-de-dados' ? "nav-item active" : "nav-item"}>
          <a href="/rh/inteligencia-de-dados" class="nav-link" style="color: #60a5fa;">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line>
            </svg>
            Inteligência IA
          </a>
        </li>
      )}
    </ul>
  </nav>

  <!-- Rodapé Sidebar -->
  <div class="sidebar-footer">
    <a href="/rh/configuracoes" class={activeMenu === 'configuracoes' ? "nav-link active" : "nav-link"}>
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33h.09a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
      Ajustes
    </a>
    <a href="/login" class="nav-link logout">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
      Sair
    </a>
  </div>
</aside>

<style>
  .sidebar-header {
    padding: 2rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .logo-circle {
    width: 40px;
    height: 40px;
    background: var(--color-primary);
    color: white;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .logo-circle svg { width: 22px; height: 22px; }

  .company-name {
    color: white;
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .system-tag {
    color: var(--color-sidebar-text);
    font-size: 0.7rem;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .sidebar-nav {
    flex: 1;
    padding: 0 1rem;
  }

  .nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    color: var(--color-sidebar-text);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 12px;
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    color: white;
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-item.active .nav-link {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  }

  .nav-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .sidebar-footer {
    padding: 1.5rem 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .logout:hover {
    color: var(--color-danger);
    background: rgba(239, 68, 68, 0.1);
  }
</style>
