---
import '../styles/index.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Segurament</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <slot name="head" />
  </head>
  <body>
    <!-- Preloader Premium -->
    <div id="loader-wrapper">
      <div class="loader-content">
        <img src="/logo-segurament-horizontal-white.png" alt="Segurament" class="loader-logo" />
      </div>
    </div>

    <slot />

    <style is:global>
      #loader-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #0f172a;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        transition: opacity 0.6s ease, visibility 0.6s;
      }

      #loader-wrapper.loader-hidden {
        opacity: 0;
        visibility: hidden;
      }

      .loader-logo {
        width: 240px;
        height: auto;
        animation: logoPulse 2s infinite ease-in-out;
      }

      @keyframes logoPulse {
        0%, 100% { opacity: 0.4; transform: scale(0.95); filter: brightness(0.8); }
        50% { opacity: 1; transform: scale(1); filter: brightness(1.2); }
      }
    </style>

    <script>
      function hideLoader() {
        const loader = document.getElementById('loader-wrapper');
        if (loader) {
          loader.classList.add('loader-hidden');
        }
      }

      // Astro View Transitions compatibility
      document.addEventListener('astro:after-swap', hideLoader);
      
      // Initial load
      window.addEventListener('load', () => {
        // Pequeno delay para garantir que o usuário veja a animação premium
        setTimeout(hideLoader, 800);
      });

      // Fallback se o window.load demorar demais
      setTimeout(hideLoader, 3000);
    </script>
  </body>
</html>
