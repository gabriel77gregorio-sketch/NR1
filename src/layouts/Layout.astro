---
import '../styles/index.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Sistema NR1</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Preloader Premium -->
    <div id="loader-wrapper">
      <div class="loader-content">
        <div class="loader-text-only">CARREGANDO</div>
      </div>
    </div>

    <slot />

    <style is:global>
      #loader-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #0f172a;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        transition: opacity 0.6s ease, visibility 0.6s;
      }

      #loader-wrapper.loader-hidden {
        opacity: 0;
        visibility: hidden;
      }

      .loader-text-only {
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        font-weight: 800;
        letter-spacing: 0.5rem;
        color: white;
        opacity: 0.8;
        animation: textFadePulse 2s infinite ease-in-out;
      }

      @keyframes textFadePulse {
        0%, 100% { opacity: 0.3; transform: scale(0.98); letter-spacing: 0.4rem; }
        50% { opacity: 1; transform: scale(1); letter-spacing: 0.6rem; }
      }
    </style>

    <script>
      function hideLoader() {
        const loader = document.getElementById('loader-wrapper');
        if (loader) {
          loader.classList.add('loader-hidden');
        }
      }

      // Astro View Transitions compatibility
      document.addEventListener('astro:after-swap', hideLoader);
      
      // Initial load
      window.addEventListener('load', () => {
        // Pequeno delay para garantir que o usuário veja a animação premium
        setTimeout(hideLoader, 800);
      });

      // Fallback se o window.load demorar demais
      setTimeout(hideLoader, 3000);
    </script>
  </body>
</html>
