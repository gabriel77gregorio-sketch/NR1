---
import Layout from '../../../layouts/Layout.astro';
import SidebarRH from '../../../components/SidebarRH.astro';

const { id } = Astro.params;
---

<Layout title="Teste Relatório">
  <div class="app-layout">
    <SidebarRH activeMenu="pesquisas" />
    <main class="main-content" style="padding: 2rem;">
      <h1>Teste de Acesso ao Relatório</h1>
      <p>ID do Ciclo: {id}</p>
      <a href="/rh/pesquisas" class="btn btn-primary">Voltar</a>
    </main>
  </div>
</Layout>

<style>
  .btn-primary { background: #3b82f6; color: white; padding: 0.5rem 1rem; border-radius: 8px; text-decoration: none; }
</style>
