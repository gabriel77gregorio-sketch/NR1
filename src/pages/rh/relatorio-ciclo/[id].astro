---
import Layout from '../../../layouts/Layout.astro';
import SidebarRH from '../../../components/SidebarRH.astro';
import { supabase } from '../../../lib/supabase';

const { id } = Astro.params;

// Proteção de Rota e Busca de Dados
const supabaseClient = supabase(Astro);
let user = null;
try {
  const { data: authData } = await supabaseClient.auth.getUser();
  user = authData?.user;
} catch (e) { }

if (!user) return Astro.redirect('/login');

// Buscar Detalhes do Ciclo
const { data: ciclo, error: errorCiclo } = await supabaseClient
  .from('ciclos_avaliacao')
  .select(`
    *,
    campanhas_pesquisa (
      id,
      titulo,
      canal,
      metodologia_id,
      created_at,
      campanhas_participantes (
        id,
        colaborador_id,
        respondido_em,
        created_at,
        colaboradores_base (
          id,
          nome,
          departamento_id,
          departamentos_unidades (nome)
        )
      )
    )
  `)
  .eq('id', id)
  .single();

if (errorCiclo || !ciclo) return Astro.redirect('/rh/pesquisas');

// --- CÁLCULO DE MÉTRICAS REAIS ---

let totalParticipantes = 0;
let totalRespondidos = 0;
let somaTempoResposta = 0; // em milissegundos
let contagemTempo = 0;

const setoresAdesao: Record<string, { total: number, respondidos: number }> = {};
const canaisAdesao: Record<string, { total: number, respondidos: number }> = {
  'email': { total: 0, respondidos: 0 },
  'whatsapp': { total: 0, respondidos: 0 }
};

ciclo.campanhas_pesquisa.forEach(camp => {
  const canal = camp.canal || 'email';
  
  camp.campanhas_participantes.forEach(part => {
    totalParticipantes++;
    
    // Canais
    if (canaisAdesao[canal]) canaisAdesao[canal].total++;
    
    // Setores
    const setorNome = part.colaboradores_base?.departamentos_unidades?.nome || 'Não Definido';
    if (!setoresAdesao[setorNome]) setoresAdesao[setorNome] = { total: 0, respondidos: 0 };
    setoresAdesao[setorNome].total++;

    if (part.respondido_em) {
      totalRespondidos++;
      canaisAdesao[canal].respondidos++;
      setoresAdesao[setorNome].respondidos++;
      
      // Cálculo de Tempo (respondido_em - created_at do participante)
      const inicio = new Date(part.created_at).getTime();
      const fim = new Date(part.respondido_em).getTime();
      somaTempoResposta += (fim - inicio);
      contagemTempo++;
    }
  });
});

const taxaEngajamento = totalParticipantes > 0 ? Math.round((totalRespondidos / totalParticipantes) * 100) : 0;
const tempoMedioMinutos = contagemTempo > 0 ? Math.round((somaTempoResposta / contagemTempo) / 60000) : 0;

// Ordenar setores por adesão
const rankingSetores = Object.entries(setoresAdesao)
  .map(([nome, dados]) => ({
    nome,
    porcentagem: Math.round((dados.respondidos / dados.total) * 100),
    total: dados.total,
    respondidos: dados.respondidos
  }))
  .sort((a, b) => b.porcentagem - a.porcentagem);

---

<Layout title={`Relatório: ${ciclo.nome} | RH NR1`}>
  <div class="app-layout">
    <SidebarRH activeMenu="pesquisas" />

    <main class="main-content" style="background: #f8fafc;">
      <div style="padding: 2rem 3rem;">
        
        <!-- Breadcrumb & Header -->
        <div style="margin-bottom: 2.5rem;">
          <nav style="display: flex; gap: 0.5rem; font-size: 0.8rem; color: #64748b; margin-bottom: 1rem; align-items: center;">
            <a href="/rh/pesquisas" style="color: inherit; text-decoration: none;">Pesquisas</a>
            <span>/</span>
            <span style="color: var(--color-primary); font-weight: 600;">Relatório do Ciclo</span>
          </nav>
          
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <h1 style="font-size: 1.875rem; color: #1e293b; font-weight: 800; margin: 0; letter-spacing: -0.025em;">{ciclo.nome}</h1>
              <p style="color: #64748b; margin-top: 0.25rem;">Relatório Macro de Engajamento e Performance Operacional</p>
            </div>
            <div style="display: flex; gap: 1rem;">
              <button class="btn btn-outline" style="background: white;" onclick="window.print()">
                <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
                EXPORTAR PDF
              </button>
            </div>
          </div>
        </div>

        <!-- Cards de KPIS Principais -->
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 2.5rem;">
          <div style="background: white; padding: 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
            <span style="font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Taxa de Engajamento</span>
            <div style="display: flex; align-items: flex-end; gap: 0.5rem; margin-top: 0.5rem;">
              <span style="font-size: 2rem; font-weight: 800; color: #1e293b; line-height: 1;">{taxaEngajamento}%</span>
              <span style="color: #16a34a; font-size: 0.875rem; font-weight: 600; margin-bottom: 0.25rem;">{totalRespondidos}/{totalParticipantes}</span>
            </div>
          </div>

          <div style="background: white; padding: 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
            <span style="font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Tempo Médio de Resposta</span>
            <div style="display: flex; align-items: flex-end; gap: 0.5rem; margin-top: 0.5rem;">
              <span style="font-size: 2rem; font-weight: 800; color: #1e293b; line-height: 1;">{tempoMedioMinutos}</span>
              <span style="color: #64748b; font-size: 0.875rem; font-weight: 600; margin-bottom: 0.25rem;">minutos</span>
            </div>
          </div>

          <div style="background: white; padding: 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
            <span style="font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Disparos Realizados</span>
            <div style="display: flex; align-items: flex-end; gap: 0.5rem; margin-top: 0.5rem;">
              <span style="font-size: 2rem; font-weight: 800; color: #1e293b; line-height: 1;">{ciclo.campanhas_pesquisa.length}</span>
              <span style="color: #64748b; font-size: 0.875rem; font-weight: 600; margin-bottom: 0.25rem;">campanhas</span>
            </div>
          </div>

          <div style="background: white; padding: 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
            <span style="font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Status do Ciclo</span>
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem;">
              <span style={`width: 10px; height: 10px; border-radius: 50%; background: ${taxaEngajamento >= 100 ? '#16a34a' : '#3b82f6'};`}></span>
              <span style="font-size: 1.25rem; font-weight: 800; color: #1e293b;">{taxaEngajamento >= 100 ? 'Concluído' : 'Ativo'}</span>
            </div>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
          
          <!-- Seção de Setores -->
          <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; padding: 2rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
            <h3 style="font-size: 1.1rem; font-weight: 700; color: #1e293b; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem;">
              <svg style="width: 20px; height: 20px; color: #3b82f6;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
              Adesão por Setor / Unidade
            </h3>
            
            <div style="display: flex; flex-direction: column; gap: 1.25rem;">
              {rankingSetores.map(setor => (
                <div>
                  <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; align-items: flex-end;">
                    <span style="font-size: 0.9rem; font-weight: 600; color: #475569;">{setor.nome}</span>
                    <span style="font-size: 0.85rem; font-weight: 700; color: #1e293b;">{setor.porcentagem}% <small style="color: #64748b; font-weight: 400;">({setor.respondidos}/{setor.total})</small></span>
                  </div>
                  <div style="height: 8px; background: #f1f5f9; border-radius: 999px; overflow: hidden;">
                    <div style={`width: ${setor.porcentagem}%; height: 100%; background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 100%); border-radius: 999px;`}></div>
                  </div>
                </div>
              ))}
              
              {rankingSetores.length === 0 && (
                <p style="text-align: center; color: #64748b; padding: 2rem;">Nenhum dado por setor disponível ainda.</p>
              )}
            </div>
          </div>

          <!-- Comparativo de Canais -->
          <div style="display: flex; flex-direction: column; gap: 2rem;">
            <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; padding: 2rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
              <h3 style="font-size: 1.1rem; font-weight: 700; color: #1e293b; margin-bottom: 1.5rem;">Eficiência de Canal</h3>
              
              <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                <!-- E-mail -->
                <div style="display: flex; gap: 1rem; align-items: center;">
                  <div style="width: 44px; height: 44px; border-radius: 12px; background: #eff6ff; color: #3b82f6; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg style="width: 20px; height: 20px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                  </div>
                  <div style="flex: 1;">
                    <div style="display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 0.25rem;">
                      <span style="font-weight: 600;">E-mail</span>
                      <span style="font-weight: 700;">{canaisAdesao.email.total > 0 ? Math.round((canaisAdesao.email.respondidos / canaisAdesao.email.total) * 100) : 0}%</span>
                    </div>
                    <div style="height: 6px; background: #f1f5f9; border-radius: 999px;">
                      <div style={`width: ${canaisAdesao.email.total > 0 ? (canaisAdesao.email.respondidos / canaisAdesao.email.total) * 100 : 0}%; height: 100%; background: #3b82f6; border-radius: 999px;`}></div>
                    </div>
                  </div>
                </div>

                <!-- WhatsApp -->
                <div style="display: flex; gap: 1rem; align-items: center;">
                  <div style="width: 44px; height: 44px; border-radius: 12px; background: #f0fdf4; color: #22c55e; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg style="width: 20px; height: 20px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-13.5 8.38 8.38 0 0 1 3.8.9L21 3.5z"></path></svg>
                  </div>
                  <div style="flex: 1;">
                    <div style="display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 0.25rem;">
                      <span style="font-weight: 600;">WhatsApp</span>
                      <span style="font-weight: 700;">{canaisAdesao.whatsapp.total > 0 ? Math.round((canaisAdesao.whatsapp.respondidos / canaisAdesao.whatsapp.total) * 100) : 0}%</span>
                    </div>
                    <div style="height: 6px; background: #f1f5f9; border-radius: 999px;">
                      <div style={`width: ${canaisAdesao.whatsapp.total > 0 ? (canaisAdesao.whatsapp.respondidos / canaisAdesao.whatsapp.total) * 100 : 0}%; height: 100%; background: #22c55e; border-radius: 999px;`}></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border-radius: 20px; padding: 2rem; color: white;">
              <h3 style="font-size: 1rem; font-weight: 700; margin-bottom: 1rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em;">Insight de IA</h3>
              <p style="font-size: 0.9rem; line-height: 1.6; color: #cbd5e1; margin: 0;">
                {taxaEngajamento < 50 
                  ? "Sua taxa de engajamento está abaixo do esperado. Recomendamos um reforço de comunicação via lideranças imediatas para aumentar a adesão nos próximos 3 dias."
                  : "Excelente taxa de adesão! Os dados coletados já possuem validade estatística para análise de risco psicossocial por setor."
                }
              </p>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
</Layout>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid transparent;
    text-decoration: none;
  }
  .btn-outline {
    border-color: #e2e8f0;
    color: #475569;
  }
  .btn-outline:hover {
    background: #f8fafc;
    border-color: #cbd5e1;
  }
  .btn-primary {
    background: var(--color-primary);
    color: white;
  }
</style>
