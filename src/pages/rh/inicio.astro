---
import Layout from '../../layouts/Layout.astro';
import SidebarRH from '../../components/SidebarRH.astro';
import { supabase } from '../../lib/supabase';
import { AvaliacaoIndividualService } from '../../services/AvaliacaoIndividualService';

// Proteção SSR
const supabaseClient = supabase(Astro);
let user = null;
let empresaId = null;
let userData = {
  nome: 'Usuário',
  empresa: 'Carregando...',
  saudacao: 'Bem-vindo'
};

// Saudação baseada no horário
const hora = new Date().getHours();
if (hora < 12) userData.saudacao = 'Bom dia';
else if (hora < 18) userData.saudacao = 'Boa tarde';
else userData.saudacao = 'Boa noite';

try {
  const { data } = await supabaseClient.auth.getUser();
  user = data?.user;
  
  if (user) {
    const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome, role, empresa_id, empresas(nome)').eq('id', user.id).single();
    if (perfil) {
      userData.nome = perfil.nome;
      empresaId = perfil.empresa_id;

      // Se for MASTER, ele pode escolher qual empresa ver via URL
      if (perfil.role === 'Master') {
        const queryEmpresaId = Astro.url.searchParams.get('empresa');
        if (queryEmpresaId) {
          // Validar se essa empresa pertence ao portfolio dele
          const { data: link } = await supabaseClient
            .from('master_portfolios')
            .select('empresa_id, empresas(nome)')
            .eq('master_id', user.id)
            .eq('empresa_id', queryEmpresaId)
            .single();
          
          if (link) {
            empresaId = queryEmpresaId;
            userData.empresa = (link.empresas as any).nome;
          }
        }
      } else {
        if (perfil.empresas) userData.empresa = (perfil.empresas as any).nome;
      }
    }
  }
} catch (e) {
  console.log("Modo de desenvolvimento ou erro de rede. Usando mocks.");
}

// -------------------------------------------------------------
// VARIAVEIS GLOBAIS DE TELA (INICIADAS ZERADAS)
// -------------------------------------------------------------
let valAtrasadas = 0;
let valDenuncias = 0;
let valAvaliacoes = 0;
let valPgr = '0%';

// Indicadores Espelhados
let stats = { media45: 0, media90: 0, desligamentos: 0 };
let turnover = '0';

let listaAgendamentos: any[] = [];

// -------------------------------------------------------------
// CONSULTAS REAIS NO SUPABASE SE ESTIVER LOGADO
// -------------------------------------------------------------
if (user && empresaId) {
  // 1. Ações Atrasadas (PGR)
  const hoje = new Date().toISOString();
  const { count: cAtrasadas } = await supabaseClient.from('planos_de_acao_pgr')
    .select('*', { count: 'exact', head: true })
    .eq('empresa_id', empresaId)
    .neq('status', 'Concluído')
    .lt('when_end', hoje);
  if (cAtrasadas !== null) valAtrasadas = cAtrasadas;

  // 2. Denúncias aguardando triagem (Pendente ou Nova Denúncia)
  const { count: cDenuncias } = await supabaseClient.from('denuncias_anonimas')
    .select('*', { count: 'exact', head: true })
    .eq('empresa_id', empresaId)
    .in('status', ['Pendente', 'Nova Denúncia']);
  if (cDenuncias !== null) valDenuncias = cDenuncias;

  // 3. Avaliações Pendentes
  const { count: cAvaliacoes } = await supabaseClient.from('avaliacoes_individuais')
    .select('*', { count: 'exact', head: true })
    .eq('empresa_id', empresaId)
    .eq('status', 'Pendente');
  if (cAvaliacoes !== null) valAvaliacoes = cAvaliacoes;

  // 4. Estatísticas de Avaliação e Turnover
  const avalService = new AvaliacaoIndividualService(supabaseClient, empresaId);
  stats = await avalService.getStats();
  
  const { count: totalColabs } = await supabaseClient
    .from('colaboradores_base')
    .select('id', { count: 'exact', head: true })
    .eq('empresa_id', empresaId);
  
  turnover = totalColabs ? ((stats.desligamentos / totalColabs) * 100).toFixed(1) : '0';

  // 5. Agendamentos Pendentes (Lista)
  const { data: realAg } = await supabaseClient.from('avaliacoes_individuais')
    .select('id, tipo, data_limite, colaboradores_base(nome, cargo)')
    .eq('empresa_id', empresaId)
    .neq('status', 'Concluído')
    .order('data_limite', { ascending: true })
    .limit(4);
  
  if (realAg && realAg.length > 0) {
    listaAgendamentos = realAg.map(ag => {
      const colabName = ag.colaboradores_base ? `${(ag.colaboradores_base as any).nome}` : 'Colaborador Excluído';
      const colabCargo = ag.colaboradores_base ? (ag.colaboradores_base as any).cargo : '';
      const dataObj = new Date(ag.data_limite);
      const isAtrasado = dataObj < new Date();
      return {
        id: ag.id,
        tipo: ag.tipo,
        colaborador: colabName,
        cargo: colabCargo,
        data: dataObj.toLocaleDateString('pt-BR'),
        urgencia: isAtrasado ? 'Alta' : 'Média'
      };
    });
  }
}
---

<Layout title="Início | RH NR1">
  <div class="app-layout">
    <SidebarRH activeMenu="inicio" />

    <main class="main-content" style="height: 100vh; overflow: hidden; display: flex; flex-direction: column;">
      <div style="padding: 1.25rem 1.5rem; flex: 1; display: flex; flex-direction: column; overflow-y: auto;" class="custom-scrollbar">
        
        <!-- Top Header Compacto -->
        <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-shrink: 0;">
          <div>
            <h1 style="font-size: 1.4rem; font-weight: 800; color: var(--color-text); margin: 0; letter-spacing: -0.5px;">Visão Geral</h1>
            <p style="color: var(--color-text-muted); font-size: 0.85rem; margin-top: 0.1rem;">{userData.saudacao}, <strong>{userData.nome}</strong>. Resumo: {userData.empresa}.</p>
          </div>
          
          <div style="display: flex; gap: 0.75rem; align-items: center;">
             <div style="text-align: right;">
               <p style="font-size: 0.75rem; font-weight: 700; margin: 0;">{userData.nome}</p>
               <p style="font-size: 0.65rem; color: var(--color-text-muted); margin: 0;">Gestor RH</p>
             </div>
             <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--color-primary); color: white; font-size: 1rem; font-weight: 800; display: flex; align-items: center; justify-content: center; border: 2px solid white; box-shadow: var(--shadow-sm);">
                {userData.nome.charAt(0)}
             </div>
          </div>
        </header>

        <!-- Grid de KPIs Compacto -->
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem; flex-shrink: 0;">
          
          <div class="kpi-card" style="padding: 1rem; gap: 0.75rem;">
            <div class="kpi-icon" style="width: 40px; height: 40px; background: #eff6ff; color: #2563eb;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
            <div>
              <p style="font-size: 0.6rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase;">Ações Atrasadas</p>
              <h3 style="font-size: 1.25rem; font-weight: 800; margin: 0;">{valAtrasadas}</h3>
            </div>
          </div>

          <div class="kpi-card" style="padding: 1rem; gap: 0.75rem;">
            <div class="kpi-icon" style="width: 40px; height: 40px; background: #f0fdf4; color: #16a34a;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            </div>
            <div>
              <p style="font-size: 0.6rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase;">Denúncias</p>
              <h3 style="font-size: 1.25rem; font-weight: 800; margin: 0;">{valDenuncias}</h3>
            </div>
          </div>

          <div class="kpi-card" style="padding: 1rem; gap: 0.75rem;">
            <div class="kpi-icon" style="width: 40px; height: 40px; background: #fefce8; color: #ca8a04;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
            </div>
            <div>
              <p style="font-size: 0.6rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase;">Avaliações</p>
              <h3 style="font-size: 1.25rem; font-weight: 800; margin: 0;">{valAvaliacoes}</h3>
            </div>
          </div>

          <div class="kpi-card" style="padding: 1rem; gap: 0.75rem;">
            <div class="kpi-icon" style="width: 40px; height: 40px; background: #faf5ff; color: #9333ea;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
            </div>
            <div>
              <p style="font-size: 0.6rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase;">Status PGR</p>
              <h3 style="font-size: 1.25rem; font-weight: 800; margin: 0;">{valPgr}</h3>
            </div>
          </div>
        </div>

        <!-- Painel de People Analytics Compacto -->
        <section style="margin-bottom: 1.5rem; flex-shrink: 0;">
           <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
             <h4 style="font-size: 0.9rem; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 0.5rem;">
               <svg style="width: 18px; height: 18px; color: var(--color-primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><polyline points="17 11 19 13 23 9"></polyline></svg>
               Indicadores de Gente & Gestão
             </h4>
           </div>

           <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
              <div class="card" style="padding: 0.75rem 1rem; background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%);">
                <p style="margin: 0; font-size: 0.6rem; color: var(--color-text-muted); font-weight: 700; text-transform: uppercase;">Adaptação (45d)</p>
                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.25rem;">
                   <h3 style="font-size: 1.2rem; font-weight: 800; margin: 0; color: #0369a1;">{stats.media45}%</h3>
                   <div style="width: 32px; height: 32px;">
                      <svg viewBox="0 0 36 36" style="transform: rotate(-90deg);"><path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e0f2fe" stroke-width="4" /><path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#0ea5e9" stroke-width="4" stroke-dasharray={`${stats.media45}, 100`} /></svg>
                   </div>
                </div>
              </div>

              <div class="card" style="padding: 0.75rem 1rem; background: linear-gradient(135deg, #ffffff 0%, #f5f3ff 100%);">
                <p style="margin: 0; font-size: 0.6rem; color: var(--color-text-muted); font-weight: 700; text-transform: uppercase;">Efetivação (90d)</p>
                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.25rem;">
                   <h3 style="font-size: 1.2rem; font-weight: 800; margin: 0; color: #4338ca;">{stats.media90}%</h3>
                   <div style="width: 32px; height: 32px;">
                      <svg viewBox="0 0 36 36" style="transform: rotate(-90deg);"><path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#f3e8ff" stroke-width="4" /><path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#6366f1" stroke-width="4" stroke-dasharray={`${stats.media90}, 100`} /></svg>
                   </div>
                </div>
              </div>

              <div class="card" style="padding: 0.75rem 1rem; background: linear-gradient(135deg, #ffffff 0%, #fef2f2 100%);">
                <p style="margin: 0; font-size: 0.6rem; color: var(--color-text-muted); font-weight: 700; text-transform: uppercase;">Taxa Turnover</p>
                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.25rem;">
                   <h3 style="font-size: 1.2rem; font-weight: 800; margin: 0; color: #b91c1c;">{turnover}%</h3>
                   <span style="font-size: 0.6rem; font-weight: 700; color: #ef4444;">ALERTA</span>
                </div>
              </div>
           </div>
        </section>

        <!-- Seção de Conteúdo Flexível -->
        <div style="display: grid; grid-template-columns: 1fr 280px; gap: 1.25rem; flex: 1; min-height: 0;">
          
          <section class="card" style="display: flex; flex-direction: column; overflow: hidden; padding: 1rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-shrink: 0;">
              <h4 style="font-size: 0.95rem; font-weight: 700; margin: 0;">Próximas Atividades</h4>
              <a href="/rh/avaliacoes-individuais" style="font-size: 0.75rem; color: var(--color-primary); font-weight: 600; text-decoration: none;">Ver Agenda</a>
            </div>
            
            <div style="flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 0.75rem;" class="custom-scrollbar">
              {listaAgendamentos.length === 0 ? (
                <div style="padding: 2rem; text-align: center; border: 1px dashed var(--color-border); border-radius: 12px; color: var(--color-text-muted); font-size: 0.85rem;">
                  <p>Tudo em dia!</p>
                </div>
              ) : (
                listaAgendamentos.map(ag => (
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: #f8fafc; border-radius: 12px; border: 1px solid var(--color-border);" class="activity-item">
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                      <div style={`width: 36px; height: 36px; border-radius: 8px; background: white; border: 1px solid var(--color-border); display: flex; align-items: center; justify-content: center; color: ${ag.urgencia === 'Alta' ? '#ef4444' : '#3b82f6'}; flex-shrink: 0;`}>
                         <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>
                      </div>
                      <div>
                        <p style="font-size: 0.85rem; font-weight: 700; margin: 0; line-height: 1.2;">{ag.colaborador}</p>
                        <p style="font-size: 0.7rem; color: var(--color-text-muted); margin: 0;">{ag.tipo.replace(/_/g, ' ')}</p>
                      </div>
                    </div>
                    <div style="text-align: right;">
                      <p style="font-size: 0.8rem; font-weight: 700; margin: 0;">{ag.data}</p>
                      <span style={`font-size: 0.6rem; font-weight: 800; padding: 0.1rem 0.4rem; border-radius: 4px; background: ${ag.urgencia === 'Alta' ? '#fee2e2' : '#e0f2fe'}; color: ${ag.urgencia === 'Alta' ? '#b91c1c' : '#1d4ed8'};`}>
                        {ag.urgencia.toUpperCase()}
                      </span>
                    </div>
                  </div>
                ))
              )}
            </div>
          </section>

          <aside style="display: flex; flex-direction: column; gap: 1rem; overflow-y: auto;" class="custom-scrollbar">
             <div class="card gradient-blue" style="color: white; border: none; padding: 1.25rem;">
                <h4 style="margin: 0 0 0.5rem 0; font-size: 0.95rem; font-weight: 700;">Inteligência NR1</h4>
                <p style="font-size: 0.75rem; opacity: 0.9; margin-bottom: 1rem; line-height: 1.4;">Analise riscos psicossociais com nossa IA de conformidade.</p>
                <a href="/rh/inteligencia-de-dados" class="btn" style="background: white; color: var(--color-primary); width: 100%; font-size: 0.75rem; padding: 0.6rem; font-weight: 700;">VER INSIGHTS</a>
             </div>

             <div class="card" style="padding: 1.25rem;">
                <h4 style="margin: 0 0 1rem 0; font-size: 0.9rem; font-weight: 700;">Ações Rápidas</h4>
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                   <a href="/rh/pesquisas" class="quick-action" style="padding: 0.6rem;">
                     <div class="action-icon" style="width: 32px; height: 32px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg></div>
                     <span style="font-size: 0.8rem;">Novo Disparo</span>
                   </a>
                   <a href="/rh/denuncias" class="quick-action" style="padding: 0.6rem;">
                     <div class="action-icon" style="width: 32px; height: 32px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></div>
                     <span style="font-size: 0.8rem;">Canal Ética</span>
                   </a>
                </div>
             </div>
          </aside>

        </div>

      </div>
    </main>
  </div>
</Layout>

<style>
  .activity-item:hover {
    transform: translateX(8px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  .quick-action {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem;
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s;
    background: var(--color-background);
  }

  .quick-action:hover {
    background: var(--color-secondary);
    color: var(--color-primary);
  }

  .action-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }
</style>
