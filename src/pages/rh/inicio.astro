---
import Layout from '../../layouts/Layout.astro';
import SidebarRH from '../../components/SidebarRH.astro';
import { supabase } from '../../lib/supabase';

// Proteção SSR
const supabaseClient = supabase(Astro);
let user = null;
let empresaId = null;
let userData = {
  nome: 'Usuário',
  empresa: 'Carregando...',
  saudacao: 'Bem-vindo'
};

// Saudação baseada no horário
const hora = new Date().getHours();
if (hora < 12) userData.saudacao = 'Bom dia';
else if (hora < 18) userData.saudacao = 'Boa tarde';
else userData.saudacao = 'Boa noite';

try {
  const { data } = await supabaseClient.auth.getUser();
  user = data?.user;
  
  if (user) {
    const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome, empresa_id, empresas(nome)').eq('id', user.id).single();
    if (perfil) {
      userData.nome = perfil.nome;
      empresaId = perfil.empresa_id;
      if (perfil.empresas) userData.empresa = (perfil.empresas as any).nome;
    }
  }
} catch (e) {
  console.log("Modo de desenvolvimento ou erro de rede. Usando mocks.");
}

// -------------------------------------------------------------
// VARIAVEIS GLOBAIS DE TELA (MOCK DE FALLBACK)
// -------------------------------------------------------------
let valAtrasadas = 3;
let valDenuncias = 1;
let valAvaliacoes = 5;
let valPgr = '98%';

let listaAgendamentos: any[] = [
  { id: 1, tipo: 'Avaliação 45 Dias', colaborador: 'Carlos Silva (Soldador)', data: 'Hoje, 14:00', urgencia: 'Alta' },
  { id: 2, tipo: 'Revisão de EPI', colaborador: 'Setor de Usinagem', data: 'Amanhã, 09:30', urgencia: 'Média' },
  { id: 3, tipo: 'Entrevista Desligamento', colaborador: 'Ana Souza', data: '28/04, 10:00', urgencia: 'Baixa' }
];

let listaAcoes: any[] = [
  { id: 1, plano: 'PGR 2026', acao: 'Comprar novos protetores auriculares', prazo: 'Vence em 2 dias' },
  { id: 2, plano: 'Denúncia #402', acao: 'Apurar relato de falta de EPI no galpão B', prazo: 'Venceu ontem' }
];

// -------------------------------------------------------------
// CONSULTAS REAIS NO SUPABASE SE ESTIVER LOGADO
// -------------------------------------------------------------
if (user && empresaId) {
  // 1. Ações Atrasadas (PGR)
  const hoje = new Date().toISOString();
  const { count: cAtrasadas } = await supabaseClient.from('planos_de_acao_pgr')
    .select('*', { count: 'exact', head: true })
    .eq('empresa_id', empresaId)
    .neq('status', 'Concluído')
    .lt('when_end', hoje);
  if (cAtrasadas !== null) valAtrasadas = cAtrasadas;

  // 2. Denúncias não lidas
  const { count: cDenuncias } = await supabaseClient.from('denuncias_anonimas')
    .select('*', { count: 'exact', head: true })
    .eq('empresa_id', empresaId)
    .in('status', ['Nova', 'Em Análise']);
  if (cDenuncias !== null) valDenuncias = cDenuncias;

  // 3. Avaliações Pendentes
  const { count: cAvaliacoes } = await supabaseClient.from('avaliacoes_individuais')
    .select('*', { count: 'exact', head: true })
    .eq('empresa_id', empresaId)
    .eq('status', 'Pendente');
  if (cAvaliacoes !== null) valAvaliacoes = cAvaliacoes;

  // 4. Agendamentos Pendentes (Lista)
  const { data: realAg } = await supabaseClient.from('avaliacoes_individuais')
    .select('id, tipo, data_limite, colaboradores_base(nome, cargo)')
    .eq('empresa_id', empresaId)
    .neq('status', 'Concluído')
    .order('data_limite', { ascending: true })
    .limit(4);
  
  if (realAg && realAg.length > 0) {
    listaAgendamentos = realAg.map(ag => {
      const colabName = ag.colaboradores_base ? `${(ag.colaboradores_base as any).nome} (${(ag.colaboradores_base as any).cargo || 'Sem cargo'})` : 'Colaborador Excluído';
      const dataObj = new Date(ag.data_limite);
      const isAtrasado = dataObj < new Date();
      return {
        id: ag.id,
        tipo: ag.tipo,
        colaborador: colabName,
        data: dataObj.toLocaleDateString('pt-BR'),
        urgencia: isAtrasado ? 'Alta' : 'Média'
      };
    });
  } else {
    listaAgendamentos = [];
  }

  // 5. Ações Comigo (Gargalos)
  const { data: realAcoes } = await supabaseClient.from('planos_de_acao_pgr')
    .select('id, what_title, where_location, when_end')
    .eq('empresa_id', empresaId)
    .eq('responsavel_id', user.id)
    .neq('status', 'Concluído')
    .order('when_end', { ascending: true })
    .limit(3);
    
  if (realAcoes && realAcoes.length > 0) {
    listaAcoes = realAcoes.map(ac => {
      const isAtrasado = new Date(ac.when_end) < new Date();
      return {
        id: ac.id,
        plano: ac.where_location || 'Plano Geral',
        acao: ac.what_title,
        prazo: isAtrasado ? 'Atrasado' : `Vence em ${new Date(ac.when_end).toLocaleDateString('pt-BR')}`
      };
    });
  } else {
    listaAcoes = [];
  }
}

// Montagem do Array Final para Renderização
const kpis = [
  { titulo: 'Ações Atrasadas (5W2H)', valor: valAtrasadas.toString(), icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', color: '#ef4444', bg: '#fee2e2' },
  { titulo: 'Denúncias Não Lidas', valor: valDenuncias.toString(), icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', color: '#f59e0b', bg: '#fef3c7' },
  { titulo: 'Avaliações Pendentes', valor: valAvaliacoes.toString(), icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01', color: '#3b82f6', bg: '#eff6ff' },
  { titulo: 'Status do PGR', valor: valPgr, icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', color: '#10b981', bg: '#d1fae5', desc: 'Conformidade' }
];
---

<Layout title="Início | Painel RH">
  <div class="app-layout">
    
    <SidebarRH activeMenu="inicio" />

    <main class="main-content" style="background: #f8fafc;">
      <div style="padding: 2.5rem 3.5rem; max-width: 1200px; margin: 0 auto;">
        
        <!-- Header -->
        <div style="margin-bottom: 2.5rem; display: flex; justify-content: space-between; align-items: flex-end;">
          <div>
            <h1 style="font-size: 2rem; color: var(--color-primary); font-weight: 700; margin: 0; letter-spacing: -0.5px;">
              {userData.saudacao}, {userData.nome}!
            </h1>
            <p style="color: var(--color-text-muted); font-size: 1rem; margin-top: 0.5rem;">
              Aqui está o resumo da sua operação na <strong>{userData.empresa}</strong> hoje.
            </p>
          </div>
          <div style="text-align: right;">
            <p style="margin:0; font-size: 0.85rem; color: var(--color-text-muted); font-weight: 600;">DATA ATUAL</p>
            <p style="margin:0; font-size: 1.1rem; color: var(--color-text); font-weight: 700;">{new Date().toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long' })}</p>
          </div>
        </div>

        <!-- KPI Cards -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
          {kpis.map(kpi => (
            <div style="background: white; padding: 1.5rem; border-radius: 16px; border: 1px solid var(--color-border); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02); display: flex; align-items: center; gap: 1rem; transition: transform 0.2s;" class="kpi-card">
               <div style={`width: 50px; height: 50px; border-radius: 12px; background: ${kpi.bg}; color: ${kpi.color}; display: flex; align-items: center; justify-content: center; flex-shrink: 0;`}>
                  <svg style="width: 26px; height: 26px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d={kpi.icon} />
                  </svg>
               </div>
               <div>
                  <p style="margin: 0; font-size: 0.85rem; color: var(--color-text-muted); font-weight: 600;">{kpi.titulo}</p>
                  <div style="display: flex; align-items: baseline; gap: 0.5rem;">
                    <h3 style="margin: 0; font-size: 1.8rem; color: var(--color-text); font-weight: 800;">{kpi.valor}</h3>
                    {kpi.desc && <span style="font-size: 0.75rem; color: var(--color-text-muted); font-weight: 500;">{kpi.desc}</span>}
                  </div>
               </div>
            </div>
          ))}
        </div>

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
          
          <!-- Lembretes e Agendamentos -->
          <div style="background: white; border-radius: 16px; border: 1px solid var(--color-border); padding: 1.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
             <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
               <h2 style="font-size: 1.2rem; margin: 0; color: var(--color-text); display: flex; align-items: center; gap: 0.5rem;">
                 <svg style="width: 20px; height: 20px; color: var(--color-primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                 Lembretes e Agendamentos
               </h2>
               <a href="/rh/avaliacoes-individuais" style="font-size: 0.8rem; color: var(--color-primary); text-decoration: none; font-weight: 600;">Ver todos</a>
             </div>
             
             <div style="display: flex; flex-direction: column; gap: 1rem;">
               {listaAgendamentos.map(ag => (
                 <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; border: 1px solid var(--color-border); border-radius: 8px; background: #fbfbfc;">
                    <div style="display: flex; gap: 1rem; align-items: center;">
                       <div style={`width: 4px; height: 30px; border-radius: 4px; background: ${ag.urgencia === 'Alta' ? '#ef4444' : ag.urgencia === 'Média' ? '#f59e0b' : '#3b82f6'}`}></div>
                       <div>
                         <h4 style="margin: 0 0 0.2rem 0; font-size: 0.95rem; color: var(--color-text);">{ag.tipo}</h4>
                         <p style="margin: 0; font-size: 0.8rem; color: var(--color-text-muted);">{ag.colaborador}</p>
                       </div>
                    </div>
                    <div style="text-align: right;">
                       <span style="background: white; border: 1px solid var(--color-border); padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; color: var(--color-text); display: inline-block;">
                         {ag.data}
                       </span>
                    </div>
                 </div>
               ))}
             </div>
          </div>

          <!-- Ações Comigo (Gargalos) -->
          <div style="background: white; border-radius: 16px; border: 1px solid var(--color-border); padding: 1.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
             <h2 style="font-size: 1.2rem; margin: 0 0 1.5rem 0; color: var(--color-text); display: flex; align-items: center; gap: 0.5rem;">
               <svg style="width: 20px; height: 20px; color: #f59e0b;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
               Ações Comigo (Gargalos)
             </h2>

             <div style="display: flex; flex-direction: column; gap: 1rem;">
               {listaAcoes.map(acao => (
                 <div style="padding: 1rem; border: 1px solid #fee2e2; border-radius: 8px; background: #fff5f5; position: relative; overflow: hidden;">
                   <div style="position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: #ef4444;"></div>
                   <p style="margin: 0 0 0.3rem 0; font-size: 0.75rem; font-weight: 700; color: #b91c1c; text-transform: uppercase;">{acao.plano}</p>
                   <h4 style="margin: 0 0 0.5rem 0; font-size: 0.9rem; color: #7f1d1d;">{acao.acao}</h4>
                   <div style="display: flex; justify-content: space-between; align-items: center;">
                     <span style="font-size: 0.75rem; color: #991b1b; display: flex; align-items: center; gap: 0.3rem;">
                       <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                       {acao.prazo}
                     </span>
                     <a href="/rh/planos-de-acao" style="font-size: 0.75rem; font-weight: 700; color: #ef4444; text-decoration: none;">RESOLVER &rarr;</a>
                   </div>
                 </div>
               ))}
               <a href="/rh/planos-de-acao" class="btn btn-outline" style="width: 100%; text-align: center; margin-top: 0.5rem; font-size: 0.85rem;">
                 Ver todos os Planos
               </a>
             </div>
          </div>

        </div>

      </div>
    </main>
  </div>
</Layout>

<style>
  .kpi-card:hover {
    transform: translateY(-2px);
    border-color: #cbd5e1 !important;
  }
</style>
