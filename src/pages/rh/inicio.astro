---
import Layout from '../../layouts/Layout.astro';
import SidebarRH from '../../components/SidebarRH.astro';
import { supabase } from '../../lib/supabase';
import { AvaliacaoIndividualService } from '../../services/AvaliacaoIndividualService';

// Proteção SSR
const supabaseClient = supabase(Astro);
let user = null;
let empresaId = null;
let userData = {
  nome: 'Usuário',
  empresa: 'Carregando...',
  saudacao: 'Bem-vindo'
};

// Saudação baseada no horário
const hora = new Date().getHours();
if (hora < 12) userData.saudacao = 'Bom dia';
else if (hora < 18) userData.saudacao = 'Boa tarde';
else userData.saudacao = 'Boa noite';

try {
  const { data } = await supabaseClient.auth.getUser();
  user = data?.user;
  
  if (user) {
    const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome, empresa_id, empresas(nome)').eq('id', user.id).single();
    if (perfil) {
      userData.nome = perfil.nome;
      empresaId = perfil.empresa_id;
      if (perfil.empresas) userData.empresa = (perfil.empresas as any).nome;
    }
  }
} catch (e) {
  console.log("Modo de desenvolvimento ou erro de rede. Usando mocks.");
}

// -------------------------------------------------------------
// VARIAVEIS GLOBAIS DE TELA (INICIADAS ZERADAS)
// -------------------------------------------------------------
let valAtrasadas = 0;
let valDenuncias = 0;
let valAvaliacoes = 0;
let valPgr = '0%';

// Indicadores Espelhados
let stats = { media45: 0, media90: 0, desligamentos: 0 };
let turnover = '0';

let listaAgendamentos: any[] = [];

// -------------------------------------------------------------
// CONSULTAS REAIS NO SUPABASE SE ESTIVER LOGADO
// -------------------------------------------------------------
if (user && empresaId) {
  // 1. Ações Atrasadas (PGR)
  const hoje = new Date().toISOString();
  const { count: cAtrasadas } = await supabaseClient.from('planos_de_acao_pgr')
    .select('*', { count: 'exact', head: true })
    .eq('empresa_id', empresaId)
    .neq('status', 'Concluído')
    .lt('when_end', hoje);
  if (cAtrasadas !== null) valAtrasadas = cAtrasadas;

  // 2. Denúncias não lidas
  const { count: cDenuncias } = await supabaseClient.from('denuncias_anonimas')
    .select('*', { count: 'exact', head: true })
    .eq('empresa_id', empresaId)
    .in('status', ['Nova', 'Em Análise']);
  if (cDenuncias !== null) valDenuncias = cDenuncias;

  // 3. Avaliações Pendentes
  const { count: cAvaliacoes } = await supabaseClient.from('avaliacoes_individuais')
    .select('*', { count: 'exact', head: true })
    .eq('empresa_id', empresaId)
    .eq('status', 'Pendente');
  if (cAvaliacoes !== null) valAvaliacoes = cAvaliacoes;

  // 4. Estatísticas de Avaliação e Turnover
  const avalService = new AvaliacaoIndividualService(supabaseClient, empresaId);
  stats = await avalService.getStats();
  
  const { count: totalColabs } = await supabaseClient
    .from('colaboradores_base')
    .select('id', { count: 'exact', head: true })
    .eq('empresa_id', empresaId);
  
  turnover = totalColabs ? ((stats.desligamentos / totalColabs) * 100).toFixed(1) : '0';

  // 5. Agendamentos Pendentes (Lista)
  const { data: realAg } = await supabaseClient.from('avaliacoes_individuais')
    .select('id, tipo, data_limite, colaboradores_base(nome, cargo)')
    .eq('empresa_id', empresaId)
    .neq('status', 'Concluído')
    .order('data_limite', { ascending: true })
    .limit(4);
  
  if (realAg && realAg.length > 0) {
    listaAgendamentos = realAg.map(ag => {
      const colabName = ag.colaboradores_base ? `${(ag.colaboradores_base as any).nome}` : 'Colaborador Excluído';
      const colabCargo = ag.colaboradores_base ? (ag.colaboradores_base as any).cargo : '';
      const dataObj = new Date(ag.data_limite);
      const isAtrasado = dataObj < new Date();
      return {
        id: ag.id,
        tipo: ag.tipo,
        colaborador: colabName,
        cargo: colabCargo,
        data: dataObj.toLocaleDateString('pt-BR'),
        urgencia: isAtrasado ? 'Alta' : 'Média'
      };
    });
  }
}
---

<Layout title="Início | RH NR1">
  <div class="app-layout">
    <SidebarRH activeMenu="inicio" />

    <main class="main-content">
      <div class="page-container">
        
        <!-- Top Header -->
        <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem;">
          <div>
            <h1 style="font-size: 1.75rem; font-weight: 800; color: var(--color-text); margin: 0;">Visão Geral</h1>
            <p style="color: var(--color-text-muted); font-size: 0.95rem; margin-top: 0.25rem;">{userData.saudacao}, <strong>{userData.nome}</strong>. Veja o resumo da {userData.empresa}.</p>
          </div>
          
          <div style="display: flex; gap: 1.5rem; align-items: center;">
             <div style="position: relative; width: 280px;">
               <input type="text" placeholder="Pesquisar no sistema..." style="width: 100%; padding: 0.75rem 1.25rem 0.75rem 2.75rem; border-radius: var(--radius-pill); border: 1px solid var(--color-border); background: var(--color-background); font-size: 0.875rem; outline: none;" />
               <svg style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); width: 18px; height: 18px; color: var(--color-text-muted);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
             </div>
             
             <div style="display: flex; gap: 0.75rem; align-items: center; padding-left: 1.5rem; border-left: 1px solid var(--color-border);">
               <div style="text-align: right;">
                 <p style="font-size: 0.8rem; font-weight: 700; margin: 0;">{userData.nome}</p>
                 <p style="font-size: 0.7rem; color: var(--color-text-muted); margin: 0;">Gestor RH</p>
               </div>
               <div style="width: 44px; height: 44px; border-radius: 50%; background: var(--color-primary); display: flex; align-items: center; justify-content: center; overflow: hidden; border: 2px solid white; box-shadow: var(--shadow-sm);">
                  <img src={`https://ui-avatars.com/api/?name=${userData.nome}&background=2563eb&color=fff`} alt="Avatar" />
               </div>
             </div>
          </div>
        </header>

        <!-- Grid de KPIs -->
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 2.5rem;">
          
          <div class="kpi-card">
            <div class="kpi-icon" style="background: #eff6ff; color: #2563eb;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
            <div>
              <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; margin-bottom: 0.25rem;">Ações Atrasadas</p>
              <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0;">{valAtrasadas}</h3>
              <p style="font-size: 0.7rem; color: #ef4444; margin-top: 0.1rem;">Urgência no PGR</p>
            </div>
          </div>

          <div class="kpi-card">
            <div class="kpi-icon" style="background: #f0fdf4; color: #16a34a;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            </div>
            <div>
              <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; margin-bottom: 0.25rem;">Denúncias</p>
              <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0;">{valDenuncias}</h3>
              <p style="font-size: 0.7rem; color: #16a34a; margin-top: 0.1rem;">Aguardando Triagem</p>
            </div>
          </div>

          <div class="kpi-card">
            <div class="kpi-icon" style="background: #fefce8; color: #ca8a04;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
            </div>
            <div>
              <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; margin-bottom: 0.25rem;">Avaliações 90D</p>
              <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0;">{valAvaliacoes}</h3>
              <p style="font-size: 0.7rem; color: #ca8a04; margin-top: 0.1rem;">Pendentes hoje</p>
            </div>
          </div>

          <div class="kpi-card">
            <div class="kpi-icon" style="background: #faf5ff; color: #9333ea;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
            </div>
            <div>
              <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; margin-bottom: 0.25rem;">Status PGR</p>
              <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0;">{valPgr}</h3>
              <p style="font-size: 0.7rem; color: #9333ea; margin-top: 0.1rem;">Meta: 100%</p>
            </div>
          </div>
        </div>

        <!-- Painel de People Analytics (Espelhado) -->
        <section style="margin-bottom: 2.5rem;">
           <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem;">
             <h4 style="font-size: 1.1rem; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 0.75rem;">
               <svg style="width: 22px; height: 22px; color: var(--color-primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><polyline points="17 11 19 13 23 9"></polyline></svg>
               Indicadores de Gente & Gestão
             </h4>
             <a href="/rh/avaliacoes-individuais" style="font-size: 0.8rem; color: var(--color-primary); font-weight: 600; text-decoration: none;">Gerenciar Avaliações →</a>
           </div>

           <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
              <div class="card" style="padding: 1.25rem; background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%);">
                <p style="margin: 0; font-size: 0.7rem; color: var(--color-text-muted); font-weight: 700; text-transform: uppercase;">Média Adaptação (45d)</p>
                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.5rem;">
                   <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0; color: #0369a1;">{stats.media45}%</h3>
                   <div style="width: 60px; height: 60px; position: relative;">
                      <svg viewBox="0 0 36 36" style="transform: rotate(-90deg);"><path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e0f2fe" stroke-width="3" /><path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#0ea5e9" stroke-width="3" stroke-dasharray={`${stats.media45}, 100`} /></svg>
                   </div>
                </div>
              </div>

              <div class="card" style="padding: 1.25rem; background: linear-gradient(135deg, #ffffff 0%, #f5f3ff 100%);">
                <p style="margin: 0; font-size: 0.7rem; color: var(--color-text-muted); font-weight: 700; text-transform: uppercase;">Média Efetivação (90d)</p>
                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.5rem;">
                   <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0; color: #4338ca;">{stats.media90}%</h3>
                   <div style="width: 60px; height: 60px; position: relative;">
                      <svg viewBox="0 0 36 36" style="transform: rotate(-90deg);"><path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#f3e8ff" stroke-width="3" /><path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#6366f1" stroke-width="3" stroke-dasharray={`${stats.media90}, 100`} /></svg>
                   </div>
                </div>
              </div>

              <div class="card" style="padding: 1.25rem; background: linear-gradient(135deg, #ffffff 0%, #fef2f2 100%);">
                <p style="margin: 0; font-size: 0.7rem; color: var(--color-text-muted); font-weight: 700; text-transform: uppercase;">Taxa de Turnover</p>
                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.5rem;">
                   <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0; color: #b91c1c;">{turnover}%</h3>
                   <div style="text-align: right;">
                      <span style="font-size: 0.7rem; display: block; font-weight: 700; color: #ef4444;">ALERTA</span>
                      <span style="font-size: 0.65rem; color: var(--color-text-muted);">{stats.desligamentos} desligados</span>
                   </div>
                </div>
              </div>
           </div>
        </section>

        <!-- Seção de Conteúdo -->
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
          
          <section class="card">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
              <h4 style="font-size: 1.1rem; font-weight: 700; margin: 0;">Próximas Atividades</h4>
              <a href="/rh/avaliacoes-individuais" style="font-size: 0.8rem; color: var(--color-primary); font-weight: 600; text-decoration: none;">Ver Agenda</a>
            </div>
            
            <div style="display: flex; flex-direction: column; gap: 1rem;">
              {listaAgendamentos.length === 0 ? (
                <div style="padding: 4rem 2rem; text-align: center; border: 1px dashed var(--color-border); border-radius: 12px; color: var(--color-text-muted);">
                  <p>Tudo em dia! Nenhuma atividade pendente.</p>
                </div>
              ) : (
                listaAgendamentos.map(ag => (
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 1.25rem; background: #f8fafc; border-radius: 16px; border: 1px solid var(--color-border); transition: all 0.2s;" class="activity-item">
                    <div style="display: flex; align-items: center; gap: 1rem;">
                      <div style={`width: 48px; height: 48px; border-radius: 12px; background: white; border: 1px solid var(--color-border); display: flex; align-items: center; justify-content: center; color: ${ag.urgencia === 'Alta' ? '#ef4444' : '#3b82f6'};`}>
                         <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>
                      </div>
                      <div>
                        <p style="font-size: 0.95rem; font-weight: 700; margin: 0;">{ag.colaborador}</p>
                        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin: 0;">{ag.tipo.replace(/_/g, ' ')} • {ag.cargo}</p>
                      </div>
                    </div>
                    <div style="text-align: right;">
                      <p style="font-size: 0.9rem; font-weight: 700; margin: 0;">{ag.data}</p>
                      <span style={`font-size: 0.7rem; font-weight: 800; padding: 0.2rem 0.5rem; border-radius: 4px; background: ${ag.urgencia === 'Alta' ? '#fee2e2' : '#e0f2fe'}; color: ${ag.urgencia === 'Alta' ? '#b91c1c' : '#1d4ed8'};`}>
                        {ag.urgencia.toUpperCase()}
                      </span>
                    </div>
                  </div>
                ))
              )}
            </div>
          </section>

          <aside style="display: flex; flex-direction: column; gap: 1.5rem;">
             <div class="card gradient-blue" style="color: white; border: none; padding: 2rem;">
                <h4 style="margin: 0 0 0.75rem 0; font-size: 1.1rem; font-weight: 700;">Inteligência NR1</h4>
                <p style="font-size: 0.85rem; opacity: 0.9; margin-bottom: 2rem; line-height: 1.5;">Analise os riscos psicossociais da sua empresa com nossa IA treinada em conformidade.</p>
                <a href="/rh/inteligencia-de-dados" class="btn" style="background: white; color: var(--color-primary); width: 100%; font-weight: 700;">VER INSIGHTS</a>
             </div>

             <div class="card">
                <h4 style="margin: 0 0 1.25rem 0; font-size: 1rem; font-weight: 700;">Ações Rápidas</h4>
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                   <a href="/rh/pesquisas" class="quick-action">
                     <div class="action-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg></div>
                     <span>Novo Disparo</span>
                   </a>
                   <a href="/rh/denuncias" class="quick-action">
                     <div class="action-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></div>
                     <span>Canal Ética</span>
                   </a>
                </div>
             </div>
          </aside>

        </div>

      </div>
    </main>
  </div>
</Layout>

<style>
  .activity-item:hover {
    transform: translateX(8px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  .quick-action {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem;
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s;
    background: var(--color-background);
  }

  .quick-action:hover {
    background: var(--color-secondary);
    color: var(--color-primary);
  }

  .action-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }
</style>
