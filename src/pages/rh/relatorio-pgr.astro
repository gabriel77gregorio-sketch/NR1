---
import { supabase } from '../../lib/supabase';
import { MatrizRiscoService } from '../../services/MatrizRiscoService';
import { PlanoAcaoService } from '../../services/PlanoAcaoService';

// SSR: Coletar os Dados Reais para construir o Relatório
const supabaseClient = supabase(Astro);
const user = null; // bypassed

let companyName = "Empresa Demonstração LTDA";
let companyCNPJ = "00.000.000/0001-00";
let companyAddress = "Av. Principal - São Paulo, SP";
let userName = "Acesso Direto Dev";

let matrizGrupos = [];
let planos = [];

const matrizService = new MatrizRiscoService(supabaseClient);
// matrizGrupos = await matrizService.getMatrizRiscoMatematica(); // Movido para o bloco if (user)
if (user) {
  const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome, empresas(nome, id)').eq('id', user.id).single();
  if (perfil) {
    userName = perfil.nome;
    if (perfil.empresas) {
      companyName = (perfil.empresas as any).nome;
      // Simulando CNPJ para fins do PDF caso nao haja na DB yet
    }
  }
  
  const planoService = new PlanoAcaoService(supabaseClient);
  planos = await planoService.getPlanosDeAcao();
  matrizGrupos = await matrizService.getMatrizRiscoMatematica();
} else {
  // Dados Mockados p/ fallback do PDF:
  planos = [
    { what_title: "Implementação Pausas Ergonômicas", who_responsible: "João Silva", status: "Em Andamento", where_location: "Produção", when_end: "2026-12-01", how_method: "Pausas de 10 min a cada 2h..." },
    { what_title: "Diagnóstico Clínico Stress", who_responsible: "Maria Saúde", status: "Aberto", where_location: "Financeiro", when_end: "2026-05-30", how_method: "Contratação de Assessor Psicológico" }
  ];
}

const currentDate = new Date().toLocaleDateString('pt-BR');
const currentDateTime = new Date().toLocaleString('pt-BR');

---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Relatório do PGR - {companyName}</title>
    <!-- Use basic system fonts for clean PDF generation -->
    <style>
      :root {
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-600: #4b5563;
        --gray-800: #1f2937;
        --border-color: #d1d5db;
      }
      
      * {
        box-sizing: border-box;
      }

      body {
        font-family: Arial, Helvetica, sans-serif;
        margin: 0;
        padding: 0;
        color: #000;
        background: #fff;
        font-size: 11pt;
        line-height: 1.4;
      }

      /* A4 Print Layout rules */
      @page {
        size: A4;
        margin: 1.5cm;
      }
      
      .a4-container {
        width: 100%;
        max-width: 21cm;
        margin: 0 auto;
        padding: 1cm;
      }

      .header {
        text-align: center;
        margin-bottom: 2rem;
      }
      
      .header h1 {
        font-size: 16pt;
        margin: 0;
        color: var(--gray-800);
        font-weight: 500;
      }
      
      .header-info {
        display: flex;
        justify-content: space-between;
        font-size: 8pt;
        color: var(--gray-600);
        margin-top: 1.5rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 0.5rem;
      }

      /* Grid / Table Styles mirroring the screenshot */
      .section-title {
        background-color: var(--gray-200);
        padding: 0.5rem 1rem;
        font-weight: bold;
        font-size: 13pt;
        border: 1px solid var(--border-color);
        border-bottom: none;
        margin-top: 1rem;
      }

      .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-top: 1px solid var(--border-color);
        border-left: 1px solid var(--border-color);
        margin-bottom: 1.5rem;
      }

      .info-cell {
        padding: 0.5rem 1rem;
        border-right: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
        font-size: 10pt;
      }

      .info-cell strong {
        display: block;
        font-size: 10pt;
        color: var(--gray-800);
        margin-bottom: 0.2rem;
      }

      .data-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5rem;
        font-size: 10pt;
      }

      .data-table th, .data-table td {
        border: 1px solid var(--border-color);
        padding: 0.5rem 1rem;
        text-align: left;
      }

      .data-table th {
        background-color: var(--gray-100);
        font-weight: bold;
      }
      
      .danger-text {
        color: #dc2626;
        font-weight: bold;
      }

      /* Print Utilities */
      .no-print {
        text-align: center;
        padding: 1rem;
        background: #fdf2f8;
        border-bottom: 1px solid #fbcfe8;
        display: flex;
        justify-content: center;
        gap: 1rem;
      }
      .no-print button {
        background: #6B3896;
        color: white;
        border: none;
        padding: 0.5rem 1.5rem;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
      }
      
      @media print {
        .no-print {
          display: none !important;
        }
        .a4-container {
          padding: 0;
        }
        /* Garantir que as linhas cinzas de fundo fiquem ativas na impressão */
        .section-title, .data-table th {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }
      }

      .footer {
        margin-top: 3rem;
        display: flex;
        justify-content: space-between;
        font-size: 7pt;
        color: var(--gray-600);
        border-top: 1px solid var(--border-color);
        padding-top: 0.5rem;
      }
    </style>
  </head>
  <body>
    
    <div class="no-print">
      <p style="margin: 0; align-self: center; color: #831843;">Preview de Impressão (Matriz PGR). Ajuste "Salvar como PDF" nas origens.</p>
      <button onclick="window.print()">GERAR PDF REPORT</button>
    </div>

    <div class="a4-container">
      
      <!-- Header do Documento -->
      <div class="header">
        <h1>Relatório Anexo PGR - Fatores Psicossociais</h1>
        <h2>Avaliação Ocupacional ({currentDate})</h2>
        
        <div class="header-info">
          <span>Por: {userName}</span>
          <span>Em: {currentDateTime}</span>
        </div>
      </div>

      <!-- Empresa Responsável -->
      <div class="section-title">
        Empresa avaliada
      </div>
      <div class="info-grid">
        <div class="info-cell">
          <strong>Nome</strong>
          {companyName}
        </div>
        <div class="info-cell">
          <strong>Elaboração</strong>
          Assessoria NR1
        </div>
        <div class="info-cell">
          <strong>CPF / CNPJ</strong>
          {companyCNPJ}
        </div>
        <div class="info-cell">
          <strong>Data de Vigência</strong>
          {currentDate} - {new Date(new Date().setFullYear(new Date().getFullYear() + 1)).toLocaleDateString('pt-BR')}
        </div>
        <div class="info-cell" style="grid-column: span 2;">
          <strong>Endereço Sede</strong>
          {companyAddress}
        </div>
      </div>

      <!-- Resumo do Mapeamento -->
      <div class="section-title">
        Inventário de Riscos (Matriz Identificada)
      </div>
      <table class="data-table">
        <thead>
          <tr>
            <th style="width: 35%;">SETOR (GHE)</th>
            <th style="width: 30%;">PERFIL DA FUNÇÃO</th>
            <th style="width: 15%; text-align: center;">GRAU DE RISCO</th>
            <th style="width: 20%; text-align: center;">SCORE TÉCNICO</th>
          </tr>
        </thead>
        <tbody>
          {matrizGrupos.map(g => (
            <tr>
              <td><strong>{g.setor}</strong></td>
              <td>{g.funcao}</td>
              <td style="text-align: center;" class={g.risk === 'Crítico' || g.risk === 'Alto' ? 'danger-text' : ''}>{g.risk}</td>
              <td style="text-align: center;">{g.score} pontos</td>
            </tr>
          ))}
        </tbody>
      </table>

      <!-- Intervenções e Planos -->
      <div class="section-title">
        Plano de Ação (Matriz 5W2H)
      </div>
      <div class="info-grid">
        {planos.length === 0 ? (
          <div class="info-cell" style="grid-column: span 2;">Nenhum plano de ação vigente foi emitido no painel neste documento.</div>
        ) : planos.map((p, index) => (
          <>
            <div class="info-cell" style="grid-column: span 2;">
              <strong>{index + 1}. Ação: {p.what_title}</strong>
              Setor Impactado: {p.where_location} | Responsável: {p.who_responsible}
            </div>
            <div class="info-cell">
              <strong>Prazo de Execução (When)</strong>
              {new Date(p.when_end).toLocaleDateString('pt-BR')}
            </div>
            <div class="info-cell">
              <strong>Situação Atual</strong>
              {p.status}
            </div>
            <div class="info-cell" style="grid-column: span 2;">
              <strong>Procedimento Adotado (How)</strong>
              {p.how_method || 'Não especificado.'}
            </div>
          </>
        ))}
      </div>

      <div class="footer">
        <span>Sistema de Avaliação NR1 • Assessorias Premium</span>
        <span>Página 1</span>
      </div>

    </div>

    <!-- Gatilho de auto-print (Opcional, agiliza pro usuário) -->
    <script>
      // window.onload = function() { window.print(); }
    </script>

  </body>
</html>
