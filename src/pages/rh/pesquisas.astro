---
import Layout from '../../layouts/Layout.astro';
import SidebarRH from '../../components/SidebarRH.astro';
import { supabase } from '../../lib/supabase';
import { ColaboradoresService } from '../../services/ColaboradoresService';
import { CicloService } from '../../services/CicloService';

const supabaseClient = supabase(Astro);
const { data: authData } = await supabaseClient.auth.getUser();
const sessionUser = authData?.user;

const colabService = new ColaboradoresService(supabaseClient);
const cicloService = new CicloService(supabaseClient);

const setores = sessionUser ? await colabService.getSetores() : [];
setores; // Suprime aviso se não for usado no template mas necessário para o script
let ciclos: any[] = [];
let empresaId = '';

if (sessionUser) {
  const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('empresa_id').eq('id', sessionUser.id).single();
  if (perfil) {
    empresaId = perfil.empresa_id;
  }
}

// Fallback para desenvolvimento (NR1 Admin)
if (!empresaId) {
  empresaId = '53294cef-d9b3-4b0e-ae68-d2b7a437bb17';
}

if (sessionUser) {
  ciclos = await cicloService.getCiclos(empresaId);
}

// Lógica de manipulação de formulário via SSR (Criação de Ciclo)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action');

    if (action === 'create_ciclo') {
      const nome = formData.get('ciclo_nome')?.toString();
      if (nome && empresaId) {
        await cicloService.createCiclo(empresaId, nome);
        // Recarregar ciclos após criação
        console.log("Ciclo criado com sucesso!");
      }
    } else if (action === 'delete_ciclo') {
      const id = formData.get('ciclo_id')?.toString();
      if (id) {
        await cicloService.deleteCiclo(id);
        ciclos = await cicloService.getCiclos(empresaId);
        console.log("Ciclo removido com sucesso!");
      }
    }
  } catch (err: any) {
    console.error(err);
  }
}
---

<Layout title="Ciclos de Pesquisa | RH NR1">
  <div class="app-layout">
    <SidebarRH activeMenu="pesquisas" />

    <main class="main-content">
      <div style="padding: 2rem 3rem;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
          <div>
            <h2 style="font-size: 1.5rem; color: var(--color-primary); font-weight: 600; margin: 0;">Ciclos de Avaliação Psicossocial</h2>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-top: 0.25rem;">Agrupe seus disparos em ciclos para comparar indicadores e medir a evolução da empresa.</p>
          </div>
          <div style="display: flex; gap: 1rem;">
            <button class="btn btn-outline btnAbrirModalCiclo" style="border-color: var(--color-primary); color: var(--color-primary);">
              + NOVO CICLO
            </button>
            <button id="btnAbrirModalPesquisa" class="btn btn-primary" disabled={ciclos.length === 0}>
              <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              NOVO DISPARO
            </button>
          </div>
        </div>

        {ciclos.length === 0 ? (
          <div style="background: white; border: 1px dashed var(--color-border); border-radius: 12px; padding: 4rem; text-align: center; color: var(--color-text-muted);">
            <div style="font-size: 3rem; margin-bottom: 1rem;">📋</div>
            <h3 style="font-size: 1.25rem; color: var(--color-text); margin-bottom: 0.5rem;">Nenhum ciclo ativo</h3>
            <p style="max-width: 400px; margin: 0 auto;">Para começar a coletar dados, você precisa criar um Ciclo de Avaliação (ex: Ciclo 2025) utilizando o botão superior.</p>
          </div>
        ) : (
          <div style="display: flex; flex-direction: column; gap: 2.5rem;">
            {ciclos.map((ciclo) => (
              <section style="background: white; border: 1px solid var(--color-border); border-radius: 16px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                <header style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--color-border); background: #fbfbfc; display: flex; justify-content: space-between; align-items: center;">
                  <div>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                      <h3 style="margin: 0; font-size: 1.25rem; color: var(--color-primary); font-weight: 700;">{ciclo.nome}</h3>
                      <span style={`font-size: 0.65rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 999px; text-transform: uppercase; background: ${ciclo.status === 'Ativo' ? '#d1fae5' : '#f1f5f9'}; color: ${ciclo.status === 'Ativo' ? '#065f46' : '#475569'};`}>
                        {ciclo.status}
                      </span>
                    </div>
                    <p style="margin: 0.25rem 0 0 0; font-size: 0.8rem; color: var(--color-text-muted);">Iniciado em {new Date(ciclo.data_inicio).toLocaleDateString('pt-BR')}</p>
                  </div>
                  
                  <!-- Comparativo Real -->
                  <div style="display: flex; gap: 2rem; align-items: center;">
                    <div style="text-align: right;">
                      <p style="margin: 0; font-size: 0.7rem; font-weight: 600; color: var(--color-text-muted);">ÍNDICE GERAL</p>
                      {(() => {
                        let total = 0;
                        let respondidos = 0;
                        
                        ciclo.campanhas_pesquisa?.forEach((camp: any) => {
                          const parts = camp.campanhas_participantes || [];
                          total += parts.length;
                          respondidos += parts.filter((p: any) => p.respondido_em).length;
                        });
                        
                        if (total === 0) {
                          return <p style="margin: 0; font-size: 0.875rem; font-weight: 600; color: var(--color-text-muted);">AGUARDANDO DISPARO</p>;
                        }
                        
                        const taxaEngajamento = Math.round((respondidos / total) * 100);
                        
                        return (
                           <p style="margin: 0; font-size: 1.25rem; font-weight: 800; color: var(--color-text);">
                            {taxaEngajamento}% 
                            <span style={`font-size: 0.8rem; color: ${taxaEngajamento >= 50 ? '#10b981' : '#f59e0b'}; margin-left: 0.5rem;`}>
                              {respondidos}/{total} respostas
                            </span>
                           </p>
                        );
                      })()}
                    </div>
                    <div style="width: 1px; height: 30px; background: var(--color-border);"></div>
                    <a href={`/rh/relatorio-ciclo/${ciclo.id}`} class="btn btn-outline" style="font-size: 0.75rem; padding: 0.5rem 1rem;">RELATÓRIO DO CICLO</a>
                    
                    <form method="POST" onsubmit="return confirm('Tem certeza que deseja excluir este ciclo e todos os dados vinculados? Esta ação é irreversível.');" style="margin: 0;">
                      <input type="hidden" name="action" value="delete_ciclo" />
                      <input type="hidden" name="ciclo_id" value={ciclo.id} />
                      <button type="submit" title="Excluir Ciclo" class="btn-excluir-ciclo" style="background: none; border: none; color: #ef4444; cursor: pointer; padding: 0.5rem; border-radius: 8px; display: flex; align-items: center; justify-content: center; transition: background 0.2s;">
                        <svg style="width: 20px; height: 20px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                      </button>
                    </form>
                  </div>
                </header>

                <div style="padding: 1.5rem 2rem;">
                  <h4 style="font-size: 0.875rem; color: var(--color-text-muted); font-weight: 600; margin-bottom: 1rem;">Disparos Realizados</h4>
                  <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    {ciclo.campanhas_pesquisa.length === 0 && (
                      <div style="padding: 2rem; text-align: center; color: var(--color-text-muted); font-size: 0.875rem; background: #f8fafc; border-radius: 8px; border: 1px dashed var(--color-border);">
                        Nenhuma pesquisa disparada neste ciclo ainda.
                      </div>
                    )}
                    {ciclo.campanhas_pesquisa.map((camp: any) => (
                      <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; border: 1px solid var(--color-border); border-radius: 12px; background: white; transition: all 0.2s;" class="survey-item">
                        <div style="display: flex; align-items: center; gap: 1rem;">
                          <div style="width: 40px; height: 40px; border-radius: 8px; background: #eff6ff; color: #3b82f6; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                          </div>
                          <div>
                            <p style="margin: 0; font-weight: 600; color: var(--color-text);">{camp.titulo}</p>
                            <p style="margin: 0; font-size: 0.75rem; color: var(--color-text-muted);">{new Date(camp.data_programada).toLocaleDateString('pt-BR')} • {camp.campanhas_participantes?.length || 0} destinatários</p>
                          </div>
                        </div>
                        <div style="display: flex; align-items: center; gap: 1rem;">
                          {(() => {
                            const total = camp.campanhas_participantes?.length || 0;
                            const respondidos = camp.campanhas_participantes?.filter((p: any) => p.respondido_em).length || 0;
                            const isConcluido = total > 0 && respondidos >= total;
                            
                            return (
                              <span style={`font-size: 0.65rem; font-weight: 700; padding: 0.25rem 0.6rem; border-radius: 999px; text-transform: uppercase; background: ${isConcluido ? '#dcfce7' : '#e0f2fe'}; color: ${isConcluido ? '#166534' : '#0369a1'};`}>
                                {isConcluido ? 'CONCLUÍDO' : 'EM ANDAMENTO'}
                              </span>
                            );
                          })()}
                          <button class="btn btn-outline" style="padding: 0.4rem; border-radius: 8px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1-2.83 0l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                          </button>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </section>
            ))}
          </div>
        )}
      </div>
    </main>

    <!-- Modal Novo Ciclo -->
    <div id="modalNovoCiclo" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
      <div style="background: white; border-radius: 16px; width: 100%; max-width: 450px; padding: 2rem; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);">
        <h2 style="font-size: 1.25rem; color: var(--color-primary); margin-bottom: 1.5rem; font-weight: 700;">Novo Ciclo de Avaliação</h2>
        <form method="POST">
          <input type="hidden" name="action" value="create_ciclo" />
          <div style="margin-bottom: 1.5rem;">
            <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem;">Nome do Ciclo *</label>
            <input type="text" name="ciclo_nome" placeholder="Ex: Ciclo Anual 2025" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: 8px; outline: none;" />
          </div>
          <div style="display: flex; justify-content: flex-end; gap: 1rem;">
            <button type="button" id="btnFecharModalCiclo" class="btn btn-outline">CANCELAR</button>
            <button type="submit" class="btn btn-primary">CRIAR CICLO</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal Novo Disparo -->
    <div id="modalNovaPesquisa" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
      <div style="background: white; border-radius: var(--radius-lg); width: 100%; max-width: 650px; padding: 2rem; position: relative; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
        <button id="btnFecharModal" style="position: absolute; top: 1rem; right: 1rem; background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-text-muted);">&times;</button>
        <h2 style="font-size: 1.25rem; color: var(--color-primary); margin-bottom: 1.5rem; font-weight: 600;">Configurar Novo Disparo</h2>
        
        <form id="formDisparo" style="display: flex; flex-direction: column; gap: 1.5rem;">
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
              <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">1. SELECIONAR CICLO</label>
              <select id="cicloSelect" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none;">
                {ciclos.filter((c: any) => c.status === 'Ativo').map((c: any) => (
                  <option value={c.id}>{c.nome}</option>
                ))}
              </select>
            </div>
            <div>
              <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">2. CANAL DE ENVIO</label>
              <select id="canalEnvio" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none;">
                <option value="email">📧 E-mail Corporativo (Resend)</option>
                <option value="whatsapp">💬 WhatsApp (Link Direto)</option>
              </select>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
              <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">3. METODOLOGIA</label>
              <select id="metodologiaSelect" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none;">
                <option value="copsoq">COPSOQ II-Br (Versão Curta)</option>
                <option value="hse" disabled>HSE Management Standards (Inativo)</option>
                <option value="jcq" disabled>Job Content Questionnaire (Inativo)</option>
              </select>
            </div>
            <div>
              <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">4. FILTRAR POR SETOR</label>
              <select id="setorSelect" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none;">
                <option value="">Todos os Setores</option>
                {setores.map((s: any) => (
                  <option value={s.id}>{s.nome}</option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">5. MENSAGEM DO E-MAIL/WHATSAPP</label>
            <textarea id="textoEmail" rows="6" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; font-family: inherit;">Olá, como vai? Você tem 10 minutos?&#13;&#10;&#13;&#10;Convidamos você a participar da nossa avaliação de risco psicossocial. Suas respostas são confidenciais. &#13;&#10;&#13;&#10;Responda com calma e sinceridade, os dados serão usados para melhorar o seu ambiente de trabalho!</textarea>
          </div>

          <div style="background: #f0f7ff; border: 1px solid #dbeafe; padding: 1rem; border-radius: 12px; display: flex; gap: 0.75rem; align-items: center;">
            <div style="background: #3b82f6; color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.75rem; font-weight: 800;">i</div>
            <p style="margin: 0; font-size: 0.8rem; color: #1e40af; line-height: 1.4;">
              <strong>Privacidade Garantida:</strong> Cada colaborador receberá um <strong>token de acesso único</strong> via e-mail ou WhatsApp. Isso garante que cada um responda apenas uma vez e protege o anonimato dos dados sensíveis.
            </p>
          </div>

          <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 0.5rem;">
            <button type="button" id="btnCancelarModal" class="btn btn-outline" style="padding: 0.75rem 2rem;">CANCELAR</button>
            <button type="submit" id="btnConfirmarDisparo" class="btn btn-primary" style="padding: 0.75rem 2rem; background: var(--color-primary); color: white; border: none; border-radius: var(--radius-md); font-weight: 600; cursor: pointer;">DISPARAR AGORA</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal de Sucesso e Próximos Passos -->
    <div id="modalSucessoDisparo" style="display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(4px); z-index: 2000; align-items: center; justify-content: center; padding: 1rem;">
      <div style="background: white; border-radius: 24px; width: 100%; max-width: 550px; padding: 2.5rem; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); text-align: center;">
        <div style="width: 80px; height: 80px; background: #dcfce7; color: #16a34a; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem auto; font-size: 2.5rem; animation: scaleUp 0.5s ease-out;">
          ✓
        </div>
        
        <h2 style="font-size: 1.75rem; color: #1e293b; margin-bottom: 0.5rem; font-weight: 800;">Disparo Realizado!</h2>
        <p style="color: #64748b; margin-bottom: 2rem;">As avaliações foram enviadas com sucesso para a sua base.</p>

        <div style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; padding: 1.5rem; margin-bottom: 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div style="text-align: left;">
            <span style="display: block; font-size: 0.7rem; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Destinatários</span>
            <span id="resumoParticipantes" style="font-size: 1.25rem; font-weight: 800; color: #1e293b;">0 Colaboradores</span>
          </div>
          <div style="text-align: left;">
            <span style="display: block; font-size: 0.7rem; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Setores</span>
            <span id="resumoSetores" style="font-size: 1.25rem; font-weight: 800; color: #1e293b;">Selecionados</span>
          </div>
        </div>

        <div style="text-align: left; margin-bottom: 2.5rem;">
          <h4 style="font-size: 0.9rem; color: #1e293b; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
            🚀 Próximos Passos Sugeridos:
          </h4>
          <ul style="margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
            <li style="display: flex; gap: 0.75rem; font-size: 0.875rem; color: #475569;">
              <span style="color: #3b82f6; font-weight: 800;">1.</span>
              <span><strong>Comunique as Equipes:</strong> Envie um aviso geral (Teams/Slack) reforçando que o e-mail de pesquisa já está na caixa de entrada.</span>
            </li>
            <li style="display: flex; gap: 0.75rem; font-size: 0.875rem; color: #475569;">
              <span style="color: #3b82f6; font-weight: 800;">2.</span>
              <span><strong>Monitore o Engajamento:</strong> Acompanhe os indicadores reais aqui no dashboard conforme as respostas forem entrando.</span>
            </li>
            <li style="display: flex; gap: 0.75rem; font-size: 0.875rem; color: #475569;">
              <span style="color: #3b82f6; font-weight: 800;">3.</span>
              <span><strong>Incentive a Participação:</strong> Relembre os colaboradores em 3 dias caso o índice de resposta esteja abaixo de 50%.</span>
            </li>
          </ul>
        </div>

        <button id="btnFecharSucesso" class="btn btn-primary" style="width: 100%; padding: 1rem; font-weight: 700; letter-spacing: 0.025em; border-radius: 12px; box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.3);">
          ENTENDIDO, VOLTAR AO PAINEL
        </button>
      </div>
    </div>

    <style>
      @keyframes scaleUp {
        from { transform: scale(0.8); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
      }
    </style>

  </div>

  <style>
    .survey-item:hover {
      border-color: var(--color-primary) !important;
      background: #f0f7ff !important;
      transform: translateX(4px);
    }
    .btn-excluir-ciclo:hover {
      background: #fee2e2 !important;
    }
  </style>

  <script>
    function initPesquisas() {
      const modalPesquisa = document.getElementById('modalNovaPesquisa');
      const modalCiclo = document.getElementById('modalNovoCiclo');
      const btnFecharModalCiclo = document.getElementById('btnFecharModalCiclo');
      
      const btnAbrirPesquisa = document.getElementById('btnAbrirModalPesquisa');
      
      // Eventos dos Modais
      document.querySelectorAll('.btnAbrirModalCiclo').forEach(btn => {
        btn.addEventListener('click', () => { if(modalCiclo) modalCiclo.style.display = 'flex'; });
      });
      if(btnFecharModalCiclo) btnFecharModalCiclo.addEventListener('click', () => { if(modalCiclo) modalCiclo.style.display = 'none'; });
      
      const btnFecharPesquisa = document.getElementById('btnFecharModal');
      const btnCancelarPesquisa = document.getElementById('btnCancelarModal');
      
      if (btnAbrirPesquisa) btnAbrirPesquisa.addEventListener('click', () => { if(modalPesquisa) modalPesquisa.style.display = 'flex'; });

      const fecharPesquisa = () => { if(modalPesquisa) modalPesquisa.style.display = 'none'; };
      if (btnFecharPesquisa) btnFecharPesquisa.addEventListener('click', fecharPesquisa);
      if (btnCancelarPesquisa) btnCancelarPesquisa.addEventListener('click', fecharPesquisa);

      const btnSalvar = document.getElementById('btnConfirmarDisparo');
      if (btnSalvar) {
        btnSalvar.addEventListener('click', async (e) => {
          e.preventDefault();
          const btnSubmit = btnSalvar as HTMLButtonElement;
          btnSubmit.innerHTML = 'AGUARDE...';
          btnSubmit.disabled = true;
          
          const cicloId = (document.getElementById('cicloSelect') as HTMLSelectElement).value;
          const metodologia = (document.getElementById('metodologiaSelect') as HTMLSelectElement).value;
          const mensagem = (document.getElementById('textoEmail') as HTMLTextAreaElement).value;
          const setorId = (document.getElementById('setorSelect') as HTMLSelectElement).value;
          const canal = (document.getElementById('canalEnvio') as HTMLSelectElement).value;
          
          try {
            const resp = await fetch('/api/campanhas/disparar', {
               method: 'POST',
               headers: {'Content-Type': 'application/json'},
               body: JSON.stringify({ cicloId, metodologia, mensagem, setorId, canal })
            });
            const dat = await resp.json();
            if(!resp.ok) throw new Error(dat.error);
          
          // Mostrar Modal de Sucesso com Resumo
          if (modalPesquisa) modalPesquisa.style.display = 'none';
          const modalSucesso = document.getElementById('modalSucessoDisparo');
          const resumoPart = document.getElementById('resumoParticipantes');
          const resumoSet = document.getElementById('resumoSetores');
          
          if (resumoPart) resumoPart.innerText = `${dat.count || 'Múltiplos'} Colaboradores`;
          if (resumoSet) resumoSet.innerText = setorId ? 'Setor Específico' : 'Toda a Empresa';
          
          if (modalSucesso) modalSucesso.style.display = 'flex';
          
          // Fechar modal de sucesso e recarregar
          document.getElementById('btnFecharSucesso')?.addEventListener('click', () => {
            window.location.reload();
          });

        } catch (err: any) {
          alert("Erro no disparo: " + err.message);
        } finally {
          btnSubmit.disabled = false;
          btnSubmit.innerText = "DISPARAR AGORA";
        }
      });
    }
  }

    document.addEventListener('astro:page-load', initPesquisas);
    // Garantir execução imediata se não houver transição de página (ex: F5)
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      initPesquisas();
    }
  </script>
</Layout>
