---
import Layout from '../../layouts/Layout.astro';
import SidebarRH from '../../components/SidebarRH.astro';
import { supabase } from '../../lib/supabase';
import { ColaboradoresService } from '../../services/ColaboradoresService';

const supabaseClient = supabase(Astro);
let user = null;
try {
  const { data: authData } = await supabaseClient.auth.getUser();
  user = authData?.user;
} catch (e) { }

// Fetch dynamic DB info
const service = new ColaboradoresService(supabaseClient);
const setores = user ? await service.getSetores() : [];

// Mocked data for HR context
const data = { user: { email: 'rh@metalurgica.com.br', name: 'Gestor de RH' }, company: 'Indústria Metalúrgica SA' };

if (user) {
  data.user.email = user.email || '';
  const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome').eq('id', user.id).single();
  if (perfil) data.user.name = perfil.nome;
}

let campanhas: any[] = [];
if (user) {
  const { data: perfilData } = await supabaseClient.from('perfis_usuarios').select('empresa_id').eq('id', user.id).single();
  if (perfilData) {
    const { data: dbCampanhas } = await supabaseClient
      .from('campanhas_pesquisa')
      .select(`
        id, 
        titulo, 
        data_programada, 
        status, 
        campanhas_participantes(count)
      `)
      .eq('empresa_id', perfilData.empresa_id)
      .order('created_at', { ascending: false });

    if (dbCampanhas) {
      campanhas = dbCampanhas.map(c => ({
        id: c.id,
        titulo: c.titulo,
        data: c.data_programada ? new Date(c.data_programada).toLocaleDateString('pt-BR') : '-',
        status: c.status,
        participantes: c.campanhas_participantes?.[0]?.count || 0
      }));
    }
  }
}
---

<Layout title="Pesquisas Validadas | RH NR1">
  <div class="app-layout">
    
    <!-- Sidebar Modular -->
    <SidebarRH activeMenu="pesquisas" />

    <!-- Main Content -->
    <main class="main-content">
      <div style="padding: 2rem 3rem;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
          <div>
            <h2 style="font-size: 1.5rem; color: var(--color-primary); font-weight: 400; margin: 0;">Disparo de Pesquisas NR1</h2>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-top: 0.25rem;">Gerencie o envio de avaliações psicossociais validadas para os colaboradores.</p>
          </div>
          <button id="btnAbrirModal" class="btn btn-primary">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            NOVO DISPARO
          </button>
        </div>

        <!-- Table Content -->
        <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-text);">Campanhas Cadastradas</h3>
        <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden;">
          <div style="display: flex; padding: 1rem; font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); letter-spacing: 0.5px; border-bottom: 1px solid var(--color-border); background: #fbfbfc;">
            <div style="flex: 2;">TÍTULO DA PESQUISA</div>
            <div style="flex: 1; text-align: center;">DATA DO DISPARO</div>
            <div style="flex: 1; text-align: center;">PARTICIPANTES (EMAILS)</div>
            <div style="flex: 1; text-align: center;">STATUS</div>
            <div style="width: 80px; text-align: center;">AÇÕES</div>
          </div>

          <div style="display: flex; flex-direction: column;">
            {campanhas.map((campanha) => (
              <div class="table-row-hover hover:bg-slate-50 transition-colors duration-200" style="display: flex; align-items: center; padding: 1.25rem 1rem; font-size: 0.875rem; border-bottom: 1px solid var(--color-border);">
                <div style="flex: 2;">
                  <div style="font-weight: 500; color: var(--color-text);">{campanha.titulo}</div>
                  <div style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.2rem;">Metodologia Validada</div>
                </div>
                <div style="flex: 1; text-align: center; color: var(--color-text); font-weight: 500;">
                  {campanha.data}
                </div>
                <div style="flex: 1; text-align: center;">
                  <span style="font-weight: 600; color: var(--color-primary); background: var(--color-secondary); padding: 0.15rem 0.5rem; border-radius: 999px;">
                    {campanha.participantes} destinatários
                  </span>
                </div>
                <div style="flex: 1; display: flex; justify-content: center;">
                  <span style={`font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.6rem; border-radius: 999px; text-transform: uppercase; background: ${campanha.status === 'Agendado' ? '#fef3c7' : '#d1fae5'}; color: ${campanha.status === 'Agendado' ? 'var(--color-warning)' : 'var(--color-success)'};`}>
                    {campanha.status}
                  </span>
                </div>
                <div style="width: 80px; text-align: center; color: var(--color-primary); cursor: pointer;">
                  <button title="Gerenciar" style="background: transparent; border: 1px solid var(--color-border); padding: 0.4rem; border-radius: var(--radius-md); cursor: pointer; color: var(--color-primary);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </main>

    <!-- Overlay/Modal mock para Nova Pesquisa -->
    <div id="modalNovaPesquisa" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
      <div style="background: white; border-radius: var(--radius-lg); width: 100%; max-width: 600px; padding: 2rem; position: relative; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
        <button id="btnFecharModal" style="position: absolute; top: 1rem; right: 1rem; background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-text-muted);">&times;</button>
        <h2 style="font-size: 1.25rem; color: var(--color-primary); margin-bottom: 1.5rem; font-weight: 600;">Configurar Novo Disparo de E-mail</h2>
        
        <form style="display: flex; flex-direction: column; gap: 1rem;">
          <div>
            <label style="display: block; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--color-text-muted);">1. METODOLOGIA (APROVADO CIENTIFICAMENTE)</label>
            <select id="metodologiaSelect" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; margin-bottom: 0.5rem;">
              <option value="hse">HSE Management Standards (Recomendado)</option>
              <option value="copsoq">COPSOQ II (Copenhagen Psychosocial Questionnaire)</option>
              <option value="jcq">Job Content Questionnaire (JCQ - Karasek)</option>
            </select>
            
            <div style="background: #f8fafc; padding: 0.75rem; border-radius: var(--radius-md); font-size: 0.75rem; color: var(--color-text); border: 1px solid #e2e8f0; line-height: 1.4;">
              <p id="desc-hse" style="margin: 0; color: #334155;"><strong>HSE Management Standards:</strong> O mais indicado para fins normativos e de auditoria. Foi desenhado como um sistema de gestão: ele não apenas identifica o risco, mas já classifica em "áreas de controle", facilitando a criação do Plano de Ação exigido pela NR 01.</p>
              <p id="desc-copsoq" style="margin: 0; display: none; color: #334155;"><strong>COPSOQ II:</strong> Excelente se a empresa for grande e você precisar de dados muito robustos para justificar investimentos em saúde mental, pois ele cobre desde o ambiente físico até a confiança vertical na diretoria.</p>
              <p id="desc-jcq" style="margin: 0; display: none; color: #334155;"><strong>JCQ (Karasek):</strong> Funciona bem como uma triagem rápida para setores específicos (ex: produção ou call center), mas pode ser "raso" para um inventário de riscos completo da NR 01.</p>
            </div>
          </div>
          <div style="display: flex; gap: 1rem;">
             <div style="flex: 1;">
               <label style="display: block; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--color-text-muted);">2. DATA DO DISPARO</label>
               <input type="datetime-local" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none;" />
             </div>
             <div style="flex: 1;">
               <label style="display: block; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--color-text-muted);">3. DEPARTAMENTOS/FILIAIS ALVO</label>
               <div style="border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0.75rem; max-height: 120px; overflow-y: auto; background: white;">
                 <label style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem; font-size: 0.875rem; border-bottom: 1px dashed var(--color-border); padding-bottom: 0.5rem;"><input type="checkbox" checked /> <strong>Todos os Setores (Empresa Inteira)</strong></label>
                 {setores.length === 0 && <span style="font-size: 0.8rem; color: var(--color-text-muted);">Configure os setores em "Configurações".</span>}
                 {setores.map(s => (
                   <label style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.4rem; font-size: 0.875rem; color: var(--color-text);"><input type="checkbox" /> {s.nome}</label>
                 ))}
               </div>
             </div>
          </div>
          <div>
            <label style="display: block; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--color-text-muted);">4. TEXTO PADRÃO DO E-MAIL</label>
            <textarea id="textoEmail" rows="4" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; resize: none; font-family: inherit;">Olá, [Nome]&#13;&#10;Sua saúde e bem-estar no trabalho são importantes para nós. Convidamos você a participar da nossa avaliação de risco psicossocial anual, de caráter confidencial.&#13;&#10;Clique no link abaixo para preencher o questionário.</textarea>
          </div>

          <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
            <button type="button" id="btnCancelarModal" class="btn btn-outline">CANCELAR</button>
            <button type="button" id="btnSalvarModal" class="btn btn-primary">CRIAR E AGENDAR CAMPANHA</button>
          </div>
        </form>
      </div>
    </div>

  </div>

  <script>
    function initPesquisasModal() {
      const modal = document.getElementById('modalNovaPesquisa');
      const btnAbrir = document.getElementById('btnAbrirModal');
      const btnFechar = document.getElementById('btnFecharModal');
      const btnCancelar = document.getElementById('btnCancelarModal');
      const btnSalvar = document.getElementById('btnSalvarModal');

      const selectMetodologia = document.getElementById('metodologiaSelect');
      const descHse = document.getElementById('desc-hse');
      const descCopsoq = document.getElementById('desc-copsoq');
      const descJcq = document.getElementById('desc-jcq');

      if (selectMetodologia) {
        selectMetodologia.addEventListener('change', (e) => {
          const target = e.target as HTMLSelectElement;
          if (descHse) descHse.style.display = target.value === 'hse' ? 'block' : 'none';
          if (descCopsoq) descCopsoq.style.display = target.value === 'copsoq' ? 'block' : 'none';
          if (descJcq) descJcq.style.display = target.value === 'jcq' ? 'block' : 'none';
        });
      }

      if (btnAbrir && modal) {
        btnAbrir.addEventListener('click', () => { modal.style.display = 'flex'; });
      }

      const fechar = () => { if(modal) modal.style.display = 'none'; };

      if (btnFechar) btnFechar.addEventListener('click', fechar);
      if (btnCancelar) btnCancelar.addEventListener('click', fechar);
      
      if (btnSalvar) {
        btnSalvar.addEventListener('click', async () => {
          btnSalvar.innerHTML = 'AGUARDE... DISPARANDO E-MAILS';
          btnSalvar.setAttribute('disabled', 'true');
          
          const metodologiaSelect = document.getElementById('metodologiaSelect') as HTMLSelectElement;
          const textoEmail = document.getElementById('textoEmail') as HTMLTextAreaElement;
          
          try {
            const resp = await fetch('/api/campanhas/disparar', {
               method: 'POST',
               headers: {'Content-Type': 'application/json'},
               body: JSON.stringify({
                  metodologia: metodologiaSelect ? metodologiaSelect.value : 'hse',
                  mensagem: textoEmail ? textoEmail.value : ''
               })
            });
            const dat = await resp.json();
            if(!resp.ok) throw new Error(dat.error);
            alert('Sucesso! ' + dat.message);
            fechar();
          } catch(e:any) {
             alert('Erro ao disparar pesquisa: ' + e.message);
          } finally {
             btnSalvar.removeAttribute('disabled');
             btnSalvar.innerHTML = 'CRIAR E AGENDAR CAMPANHA';
          }
        });
      }

      if (modal) {
         modal.addEventListener('click', (e) => {
            if (e.target === modal) fechar();
         });
      }
    }

    document.addEventListener('DOMContentLoaded', initPesquisasModal);
    document.addEventListener('astro:page-load', initPesquisasModal);
    initPesquisasModal();
  </script>
</Layout>
