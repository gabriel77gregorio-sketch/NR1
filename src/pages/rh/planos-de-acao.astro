---
import Layout from '../../layouts/Layout.astro';
import SidebarRH from '../../components/SidebarRH.astro';
import { supabase } from '../../lib/supabase';
import { PlanoAcaoService } from '../../services/PlanoAcaoService';

// SSR: Obter cliente do Supabase e validar autenticação
const supabaseClient = supabase(Astro);
let user = null;
try {
  const { data: authData } = await supabaseClient.auth.getUser();
  user = authData?.user;
} catch (e) { }
const planoAcaoService = new PlanoAcaoService(supabaseClient);

// Para demonstração interativa enquanto o login real está mockado, caso não haja User real, caímos para um mock seguro
let planos: any[] = [];
let equipe: any[] = [];
let colaboradores: any[] = [];
let data = { user: { email: 'rh@empresa.com', name: 'Acesso Público Dev' }, company: 'Empresa Teste' };

// Autopreenchimento Inteligente vindo do Dashboard (CRIAR PGR)
const prefillSector = Astro.url.searchParams.get('sector') || '';
const prefillScore = Astro.url.searchParams.get('score') || '';
const prefillRisk = Astro.url.searchParams.get('risk') || '';
const prefillWhy = prefillRisk ? `Nível ${prefillRisk} (Score NR1: ${prefillScore}) mapeado na matriz` : '';
const autoOpen = prefillSector ? "true" : "false";

if (user) {
  // Handlers de formulário POST
  if (Astro.request.method === "POST") {
    try {
      const formData = await Astro.request.formData();
      await planoAcaoService.criarPlanoDeAcao({
        what_title: formData.get("what_title")?.toString() || '',
        why_reason: formData.get("why_reason")?.toString() || '',
        where_location: formData.get("where_location")?.toString() || '',
        when_start: new Date().toISOString(),
        when_end: formData.get("when_end")?.toString() || '',
        who_responsible: formData.get("who_responsible")?.toString() || '',
        responsavel_id: formData.get("responsavel_id")?.toString() || undefined,
        pendente_com_id: formData.get("historico_responsavel_id")?.toString() || undefined,
        how_method: formData.get("how_method")?.toString() || '',
        how_much_cost: parseFloat(formData.get("how_much_cost")?.toString() || '0'),
        status: 'Aberto'
      }, {
        responsavel_id: formData.get("historico_responsavel_id")?.toString() || null,
        descricao: formData.get("historico_descricao")?.toString() || '',
        data_prevista_checkpoint: formData.get("historico_data")?.toString() || null
      });
    } catch (e) {
      console.error("Erro ao salvar plano 5w2h: ", e);
    }
  }

  // Busca final de planos após qualquer alteração via POST
  planos = await planoAcaoService.getPlanosDeAcao();
  data.user.email = user.email || '';
  
  const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome, empresa_id').eq('id', user.id).single();
  if (perfil) {
    data.user.name = perfil.nome;
    const { data: eq } = await supabaseClient.from('perfis_usuarios').select('id, nome, role').eq('empresa_id', perfil.empresa_id);
    if(eq) equipe = eq;
    
    const { data: cols } = await supabaseClient.from('colaboradores_base').select('id, nome, cargo').eq('empresa_id', perfil.empresa_id);
    if(cols) colaboradores = cols;
  }
} else {
  // Fallback Dev se o bypass de login estiver ativo:
  planos = [
    { id: 'dev-1', what_title: 'Programa de Prevenção ao Burnout', who_responsible: 'Psicologia Interna', when_end: '2026-11-30', status: 'Em Andamento', where_location: 'Matriz - Administrativo' },
    { id: 'dev-2', what_title: 'Integração SSMA', who_responsible: 'Ergonomia', when_end: '2026-06-15', status: 'Atrasado', where_location: 'Fábrica 02' }
  ];
}
---

<Layout title="Gestão de Planos de Ação (5W2H) | RH NR1">
  <div class="app-layout">
    
    <!-- Sidebar Modular -->
    <SidebarRH activeMenu="planos" />

    <!-- Overlay/Modal Detalhes e Linha do Tempo -->
    <div id="modalDetalhesPlano" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 1100; align-items: center; justify-content: center; padding: 1rem;">
      <div id="printableArea" style="background: white; border-radius: var(--radius-lg); width: 100%; max-width: 900px; max-height: 94vh; overflow-y: auto; position: relative; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
        
        <!-- Cabeçalho Exclusivo para Impressão (Oculto no Navegador) -->
        <div class="only-print" style="display: none; padding-bottom: 1.5rem; border-bottom: 2px solid #000; margin-bottom: 2rem; justify-content: space-between; align-items: center;">
          <div style="display: flex; align-items: center; gap: 1rem;">
            <div style="width: 40px; height: 40px; background: var(--color-primary); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 1.2rem;">NR</div>
            <div>
              <h1 style="font-size: 1.2rem; margin: 0; font-weight: 700; color: #000;">RELATÓRIO DE PLANO DE AÇÃO (5W2H)</h1>
              <p style="font-size: 0.75rem; margin: 0; color: #666;">Sistema NR1 - Gestão de Conformidade e Prevenção</p>
            </div>
          </div>
          <div style="text-align: right;">
            <p style="font-size: 0.7rem; margin: 0; font-weight: 600;">Data do Relatório: {new Date().toLocaleDateString('pt-BR')}</p>
            <p style="font-size: 0.6rem; margin: 0; color: #888;">Documento Gerado Digitalmente</p>
          </div>
        </div>

        <!-- Header Modal (Visível no Navegador) -->
        <div class="no-print" style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: flex-start; background: #f8fafc; border-radius: var(--radius-lg) var(--radius-lg) 0 0;">
          <div>
            <div id="detalheStatus" style="font-size: 0.65rem; font-weight: 700; padding: 0.25rem 0.75rem; border-radius: 999px; text-transform: uppercase; margin-bottom: 0.5rem; display: inline-block;">STATUS</div>
            <h2 id="detalheTitulo" style="font-size: 1.5rem; color: var(--color-primary); font-weight: 700; margin: 0;">Título da Ação</h2>
            <p id="detalheSubtitulo" style="color: var(--color-text-muted); font-size: 0.875rem; margin-top: 0.25rem;">Setor • Prazo Final: 00/00/0000</p>
          </div>
          <div style="display: flex; gap: 0.75rem;">
            <button id="btnImprimirPlano" style="background: white; border: 1px solid var(--color-border); padding: 0.5rem 1rem; border-radius: var(--radius-md); cursor: pointer; display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: var(--color-text);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
              IMPRIMIR RELATÓRIO
            </button>
            <button id="btnFecharDetalhes" style="background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-text-muted);">&times;</button>
          </div>
        </div>

        <div id="reportContent" style="padding: 2.5rem; display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 3rem;">
          <!-- Coluna 1: Informações Gerais -->
          <div>
            <!-- Visível apenas no Print -->
            <div class="only-print" style="display: none; margin-bottom: 2rem;">
               <h2 id="printTitulo" style="font-size: 1.8rem; margin: 0; color: #000; font-weight: 800;"></h2>
               <div style="display: flex; gap: 1rem; margin-top: 0.5rem;">
                  <span id="printStatus" style="font-weight: 700; font-size: 0.8rem; text-transform: uppercase;"></span>
                  <span id="printSubtitulo" style="color: #666; font-size: 0.9rem;"></span>
               </div>
            </div>

            <section style="margin-bottom: 2.5rem;">
              <h3 style="font-size: 0.85rem; font-weight: 800; color: #000; text-transform: uppercase; margin-bottom: 1.5rem; letter-spacing: 0.05em; border-left: 4px solid var(--color-primary); padding-left: 0.75rem;">Detalhamento da Metodologia 5W2H</h3>
              <div style="display: grid; gap: 1.5rem;">
                <div style="background: #f8fafc; padding: 1rem; border-radius: 8px;">
                  <label style="display: block; font-size: 0.7rem; color: var(--color-text-muted); font-weight: 700; margin-bottom: 0.25rem;">O QUE SERÁ FEITO (WHAT)</label>
                  <p id="infoWhat" style="font-weight: 600; color: #000; font-size: 1rem; margin: 0;"></p>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                  <div>
                    <label style="display: block; font-size: 0.7rem; color: var(--color-text-muted); font-weight: 700; margin-bottom: 0.25rem;">MOTIVAÇÃO (WHY)</label>
                    <p id="infoWhy" style="font-size: 0.9rem; color: var(--color-text); margin: 0; line-height: 1.5;"></p>
                  </div>
                  <div>
                    <label style="display: block; font-size: 0.7rem; color: var(--color-text-muted); font-weight: 700; margin-bottom: 0.25rem;">LOCAL DE APLICAÇÃO (WHERE)</label>
                    <p id="infoWhere" style="font-size: 0.9rem; color: var(--color-text); margin: 0;"></p>
                  </div>
                </div>
                <div>
                  <label style="display: block; font-size: 0.7rem; color: var(--color-text-muted); font-weight: 700; margin-bottom: 0.25rem;">MÉTODO DE EXECUÇÃO (HOW)</label>
                  <p id="infoHow" style="font-size: 0.95rem; background: #fff; padding: 1.25rem; border-radius: 8px; border: 1px solid var(--color-border); color: #334155; margin: 0; line-height: 1.6;"></p>
                </div>
                <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 1.5rem; background: #f1f5f9; padding: 1rem; border-radius: 8px;">
                  <div>
                    <label style="display: block; font-size: 0.7rem; color: var(--color-text-muted); font-weight: 700; margin-bottom: 0.25rem;">RESPONSÁVEL PELA EXECUÇÃO (WHO)</label>
                    <p id="infoWho" style="font-weight: 700; color: var(--color-primary); margin: 0;"></p>
                  </div>
                  <div>
                    <label style="display: block; font-size: 0.7rem; color: var(--color-text-muted); font-weight: 700; margin-bottom: 0.25rem;">ORÇAMENTO ESTIMADO</label>
                    <p id="infoCost" style="font-weight: 700; color: #15803d; margin: 0;"></p>
                  </div>
                </div>
              </div>
            </section>

            <!-- Campo de Assinatura exclusivo para Print -->
            <div class="only-print" style="display: none; margin-top: 4rem; grid-template-columns: 1fr 1fr; gap: 4rem;">
               <div style="border-top: 1px solid #000; text-align: center; padding-top: 0.5rem;">
                  <p style="font-size: 0.75rem; margin: 0; font-weight: 700;">Assinatura do Responsável</p>
                  <p style="font-size: 0.65rem; color: #666; margin: 0;">Cargo / Departamento</p>
               </div>
               <div style="border-top: 1px solid #000; text-align: center; padding-top: 0.5rem;">
                  <p style="font-size: 0.75rem; margin: 0; font-weight: 700;">Aprovação Segurança do Trabalho</p>
                  <p style="font-size: 0.65rem; color: #666; margin: 0;">Carimbo / Visto</p>
               </div>
            </div>
          </div>

          <!-- Coluna 2: Linha do Tempo -->
          <div style="border-left: 1px solid var(--color-border); padding-left: 2.5rem;">
            <h3 style="font-size: 0.85rem; font-weight: 800; color: #000; text-transform: uppercase; margin-bottom: 2rem; letter-spacing: 0.05em;">Trilha de Rastreabilidade</h3>
            
            <div id="timelineContainer" style="display: flex; flex-direction: column; gap: 2rem; position: relative;">
               <!-- Linha vertical decorativa -->
               <div style="position: absolute; left: 7px; top: 0; bottom: 0; width: 2px; background: #e2e8f0; z-index: 0;"></div>
               
               <!-- Items da Timeline serão inseridos aqui -->
               <div id="timelineLoading" style="text-align: center; padding: 1rem; color: var(--color-text-muted); font-size: 0.875rem;">
                 Carregando rastro de auditoria...
               </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <main class="main-content">
      <div style="padding: 2rem 3rem;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
          <div>
            <h2 style="font-size: 1.5rem; color: var(--color-primary); font-weight: 400; margin: 0;">Planos de Ação (5W2H)</h2>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-top: 0.25rem;">Planeje e faça a gestão das medidas preventivas exigidas pela NR-1 e pelo mapeamento de riscos.</p>
          </div>
          <button id="btnAbrirModal5w2h" class="btn btn-primary">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            NOVO PLANO 5W2H
          </button>
        </div>

        <!-- Tabela -->
        <div style="background: white; border-top: 1px solid var(--color-border);">
          <div style="display: flex; padding: 1rem 0; font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); letter-spacing: 0.5px; border-bottom: 1px solid var(--color-border);">
            <div style="width: 40px; text-align: center;"></div>
            <div style="flex: 2;">AÇÃO PREVENTIVA (WHAT)</div>
            <div style="flex: 1;">RESPONSÁVEL (WHO)</div>
            <div style="flex: 1;">ÁREA/SETOR (WHERE)</div>
            <div style="flex: 1; text-align: center;">PRAZO (WHEN)</div>
            <div style="flex: 1; text-align: center;">SITUAÇÃO</div>
            <div style="width: 80px; text-align: center;">AÇÕES</div>
          </div>

          <div style="display: flex; flex-direction: column;">
            {planos.length === 0 ? (
              <div style="padding: 2rem; text-align: center; color: var(--color-text-muted);">
                Nenhum Plano de Ação cadastrado ainda. Use o botão acima para injetar a primeira matriz.
              </div>
            ) : planos.map((plano) => (
              <div class="table-row-hover hover:bg-slate-50 transition-colors duration-200" style="display: flex; align-items: center; padding: 1.25rem 0; font-size: 0.875rem; border-bottom: 1px solid #f1f5f9;">
                <div style="width: 40px; text-align: center;">
                  <input type="checkbox" style="width: 16px; height: 16px; border: 1px solid var(--color-border); border-radius: 4px;" />
                </div>
                <div style="flex: 2;">
                  <div style="font-weight: 600; font-size: 0.95rem; color: var(--color-primary); margin-bottom: 0.25rem;">{plano.what_title}</div>
                  <div style="font-size: 0.75rem; color: var(--color-text-muted);">Motivador: {(plano as any).why_reason?.substring(0, 50) || 'Não especificado'}...</div>
                </div>
                <div style="flex: 1; color: var(--color-text-muted); font-weight: 500;">
                  <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                     <div style="width: 24px; height: 24px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; font-size: 0.6rem; color: var(--color-text-muted);">
                       {(plano.responsavel_id && equipe.find(e => e.id === plano.responsavel_id) ? equipe.find(e => e.id === plano.responsavel_id).nome : plano.who_responsible).substring(0,2).toUpperCase()}
                     </div>
                     {plano.responsavel_id && equipe.find(e => e.id === plano.responsavel_id) ? equipe.find(e => e.id === plano.responsavel_id).nome : plano.who_responsible}
                     
                     {plano.pendente_com_id && (
                        <span title="Gargalo Operacional Identificado" style="font-size: 0.6rem; background: #fee2e2; color: #b91c1c; padding: 0.2rem 0.4rem; border-radius: 4px; display: flex; align-items: center; gap: 0.2rem; margin-top: 0.2rem;">
                          <svg style="width: 10px; height: 10px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                          Travado com: {equipe.find(e => e.id === plano.pendente_com_id)?.nome}
                        </span>
                     )}
                  </div>
                </div>
                <div style="flex: 1; color: var(--color-text-muted);">
                  {plano.where_location}
                </div>
                <div style="flex: 1; text-align: center; color: var(--color-text); font-weight: 500; font-family: monospace;">
                  {new Date(plano.when_end).toLocaleDateString('pt-BR')}
                </div>
                <div style="flex: 1; display: flex; justify-content: center;">
                  <span style={`font-size: 0.65rem; font-weight: 600; padding: 0.3rem 0.6rem; border-radius: 999px; text-transform: uppercase; background: ${plano.status === 'Atrasado' ? '#fee2e2' : (plano.status === 'Em Andamento' || plano.status === 'Aberto' ? '#e0f2fe' : '#dcfce7')}; color: ${plano.status === 'Atrasado' ? '#b91c1c' : (plano.status === 'Em Andamento' || plano.status === 'Aberto' ? '#0369a1' : '#15803d')};`}>
                    {plano.status}
                  </span>
                </div>
                <div style="width: 80px; text-align: center; color: var(--color-primary); cursor: pointer; display: flex; gap: 0.5rem; justify-content: center;">
                  <button title="Ver Detalhes e Timeline" class="btnVerDetalhes" data-plano={JSON.stringify(plano)} style="background: transparent; border: 1px solid var(--color-border); padding: 0.4rem; border-radius: var(--radius-md); cursor: pointer; color: var(--color-primary);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                  </button>
                  <button title="Gerenciar Gargalo" class="btnGerenciarAcao" data-id={plano.id} style="background: transparent; border: 1px solid var(--color-border); padding: 0.4rem; border-radius: var(--radius-md); cursor: pointer; color: var(--color-primary);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </main>

    <!-- Overlay/Modal Gerenciar Ação -->
    <div id="modalGerenciarAcao" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
      <div style="background: white; border-radius: var(--radius-lg); width: 100%; max-width: 500px; padding: 2.5rem; position: relative; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
        <button id="btnFecharGerenciar" style="position: absolute; top: 1.5rem; right: 1.5rem; background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-text-muted);">&times;</button>
        <h2 style="font-size: 1.3rem; color: var(--color-primary); margin-bottom: 0.5rem; font-weight: 600;">Gerenciar Pendência</h2>
        <p style="color: var(--color-text-muted); font-size: 0.85rem; margin-bottom: 2rem;">Ação sob sua responsabilidade. Escolha como deseja prosseguir:</p>
        
        <form id="formGerenciar" style="display: flex; flex-direction: column; gap: 1.5rem;">
           <div>
             <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">AÇÃO A TOMAR *</label>
             <select id="selectAcaoTomar" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; background: white;">
               <option value="encaminhar">Encaminhar para próximo responsável (Repassar Gargalo)</option>
               <option value="encerrar">Encerrar Plano de Ação (Concluído)</option>
             </select>
           </div>
           
           <div id="divProximoResponsavel">
             <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">ENCAMINHAR PARA *</label>
             <select id="proximoResponsavelSelect" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; background: white;">
                <optgroup label="Gestores / Acesso ao Sistema">
                  {equipe.map(membro => (
                    <option value={`USER_${membro.id}`}>{membro.nome} ({membro.role})</option>
                  ))}
                </optgroup>
                {colaboradores.length > 0 && (
                <optgroup label="Quadro de Colaboradores (Sem Acesso Direto)">
                  {colaboradores.map(membro => (
                    <option value={membro.id}>{membro.nome} ({membro.cargo})</option>
                  ))}
                </optgroup>
                )}
             </select>
           </div>
           
           <div>
             <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">JUSTIFICATIVA / OBSERVAÇÃO</label>
             <textarea id="justificativaGerenciar" rows="2" placeholder="Descreva o que foi feito ou o motivo do encaminhamento..." style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; resize: none; font-family: inherit;"></textarea>
           </div>
           
           <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
             <button type="button" id="btnCancelarGerenciar" class="btn btn-outline" style="padding: 0.75rem 1.5rem;">CANCELAR</button>
             <button type="button" id="btnSalvarGerenciar" class="btn btn-primary" style="padding: 0.75rem 1.5rem;">APLICAR AÇÃO</button>
           </div>
        </form>
      </div>
    </div>

    <!-- Overlay/Modal 5W2H Segura (SSR) -->
    <div id="modal5w2h" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
      <div style="background: white; border-radius: var(--radius-lg); width: 100%; max-width: 800px; padding: 2.5rem; position: relative; max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
        <button id="btnFecharModal5w2h" style="position: absolute; top: 1.5rem; right: 1.5rem; background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-text-muted);">&times;</button>
        <h2 style="font-size: 1.5rem; color: var(--color-primary); margin-bottom: 0.5rem; font-weight: 600;">Estruturar Novo Plano de Ação</h2>
        <p style="color: var(--color-text-muted); font-size: 0.85rem; margin-bottom: 2rem;">Preencha a matriz 5W2H conforme diretrizes do PGR e mapa de riscos.</p>
        
        <form method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
             <div>
               <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">1. AÇÃO DIRETIVA (WHAT) *</label>
               <input name="what_title" type="text" placeholder="Ex: Substituição das cadeiras por modelo ergonômico" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; transition: border-color 0.2s;" />
             </div>
             <div>
               <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">2. JUSTIFICATIVA LEGAL (WHY) *</label>
               <input name="why_reason" type="text" value={prefillWhy} placeholder="Ex: Risco ergonômico mapeado na Matriz Setor Administrativo" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; transition: border-color 0.2s;" />
             </div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem;">
             <div>
               <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">3. LOCAL IMPACTADO (WHERE) *</label>
               <input name="where_location" type="text" value={prefillSector} placeholder="Ex: Escritório Sede" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none;" />
             </div>
             <div>
               <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">4. RESPONSÁVEL TÉC. (WHO) *</label>
               <select name="responsavel_id" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; background: white;">
                 <option value="">Selecione o Responsável...</option>
                 <optgroup label="Gestores / Acesso ao Sistema">
                   <option value={`USER_${user?.id}`}>Eu Mesmo ({data.user.name})</option>
                   {equipe.map(membro => (
                     <option value={`USER_${membro.id}`}>{membro.nome} ({membro.role})</option>
                   ))}
                 </optgroup>
                 {colaboradores.length > 0 && (
                 <optgroup label="Quadro de Colaboradores (Sem Acesso Direto)">
                   {colaboradores.map(membro => (
                     <option value={membro.id}>{membro.nome} ({membro.cargo})</option>
                   ))}
                 </optgroup>
                 )}
               </select>
             </div>
             <div>
               <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">5. DATA LIMITE (WHEN) *</label>
               <input name="when_end" type="date" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; font-family: inherit;" />
             </div>
          </div>

          <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem;">
             <div>
               <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">6. PROCEDIMENTO OPERACIONAL (HOW) *</label>
               <textarea name="how_method" rows="2" placeholder="Passo a passo da implementação da medida preventiva..." required style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; resize: none; font-family: inherit;"></textarea>
             </div>
             <div>
               <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">7. ORÇAMENTO (HOW MUCH)</label>
               <div style="position: relative;">
                 <span style="position: absolute; left: 1rem; top: 0.75rem; color: var(--color-text-muted); font-weight: 500;">R$</span>
                 <input name="how_much_cost" type="number" step="0.01" placeholder="0.00" required style="width: 100%; padding: 0.75rem 0.75rem 0.75rem 2.5rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; font-family: monospace; font-size: 1rem;" />
               </div>
             </div>
          </div>

          <div style="border-top: 1px dashed var(--color-border); padding-top: 1.5rem; margin-top: 0.5rem;">
            <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: #b91c1c;">HISTÓRICO DE AÇÃO E CHECKPOINTS (OPCIONAL)</label>
            <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 1rem;">Defina quem está com a pendência atual (gargalo) e a data prevista para o próximo checkpoint de acompanhamento.</p>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1rem;">
              <div>
                <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">RESPONSÁVEL ATUAL (Gargalo)</label>
                <select name="historico_responsavel_id" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; background: white;">
                  <option value="">Ação fluindo normalmente (Sem pendências)</option>
                  <optgroup label="Gestores / Acesso ao Sistema">
                    <option value={`USER_${user?.id}`}>Travado com: Eu Mesmo ({data.user.name})</option>
                    {equipe.map(membro => (
                      <option value={`USER_${membro.id}`}>Travado com: {membro.nome} ({membro.role})</option>
                    ))}
                  </optgroup>
                  {colaboradores.length > 0 && (
                  <optgroup label="Quadro de Colaboradores (Sem Acesso Direto)">
                    {colaboradores.map(membro => (
                      <option value={membro.id}>Travado com: {membro.nome} ({membro.cargo})</option>
                    ))}
                  </optgroup>
                  )}
                </select>
              </div>
              <div>
                <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">DATA PREVISTA DO CHECKPOINT</label>
                <input name="historico_data" type="date" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; font-family: inherit;" />
              </div>
            </div>
            <div>
              <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">DESCRIÇÃO DO STATUS ATUAL</label>
              <textarea name="historico_descricao" rows="2" placeholder="Descreva o que falta para prosseguir (ex: Aguardando aprovação financeira)" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; resize: none; font-family: inherit;"></textarea>
            </div>
          </div>

          <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
            <button type="button" id="btnCancelarModal5w2h" class="btn btn-outline" style="padding: 0.75rem 1.5rem;">CANCELAR</button>
            <button type="submit" class="btn btn-primary" style="padding: 0.75rem 1.5rem;">
              <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
              SALVAR MATRIZ DE AÇÃO
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Div oculta para passar variável do astro para o JS interno -->
    <div id="pgr-data" data-auto-open={autoOpen} style="display: none;"></div>

  </div>

  <script>
    function initPgrModal() {
      const modal = document.getElementById('modal5w2h');
      const btnAbrir = document.getElementById('btnAbrirModal5w2h');
      const btnFechar = document.getElementById('btnFecharModal5w2h');
      const btnCancelar = document.getElementById('btnCancelarModal5w2h');
      const dataStore = document.getElementById('pgr-data');

      if (btnAbrir && modal) {
        btnAbrir.addEventListener('click', () => { modal.style.display = 'flex'; });
      }

      const fechar = () => { if(modal) modal.style.display = 'none'; };

      if (btnFechar) btnFechar.addEventListener('click', fechar);
      if (btnCancelar) btnCancelar.addEventListener('click', fechar);

      if (modal) {
         modal.addEventListener('click', (e) => {
            if (e.target === modal) fechar();
         });
      }

      // Lógica do Modal de Detalhes
      const modalDetalhes = document.getElementById('modalDetalhesPlano');
      const btnFecharDetalhes = document.getElementById('btnFecharDetalhes');
      const btnImprimirPlano = document.getElementById('btnImprimirPlano');
      const timelineContainer = document.getElementById('timelineContainer');
      const btnsDetalhes = document.querySelectorAll('.btnVerDetalhes');

      const fecharDetalhes = () => { if(modalDetalhes) modalDetalhes.style.display = 'none'; };
      if (btnFecharDetalhes) btnFecharDetalhes.addEventListener('click', fecharDetalhes);
      
      if (modalDetalhes) {
        modalDetalhes.addEventListener('click', (e) => { if(e.target === modalDetalhes) fecharDetalhes(); });
      }

      if (btnImprimirPlano) {
        btnImprimirPlano.addEventListener('click', () => {
          window.print();
        });
      }

      btnsDetalhes.forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const plano = JSON.parse(btn.getAttribute('data-plano') || '{}');
          
          if (!modalDetalhes) return;
          
          // Preencher Dados Básicos
          const titulo = plano.what_title;
          const subtitulo = `${plano.where_location} • Prazo: ${new Date(plano.when_end).toLocaleDateString('pt-BR')}`;
          const status = plano.status;
          
          document.getElementById('detalheTitulo')!.innerText = titulo;
          document.getElementById('detalheSubtitulo')!.innerText = subtitulo;
          document.getElementById('printTitulo')!.innerText = titulo;
          document.getElementById('printSubtitulo')!.innerText = subtitulo;
          document.getElementById('infoWhat')!.innerText = titulo;
          document.getElementById('infoWhy')!.innerText = plano.why_reason;
          document.getElementById('infoWhere')!.innerText = plano.where_location;
          document.getElementById('infoHow')!.innerText = plano.how_method;
          document.getElementById('infoWho')!.innerText = plano.who_responsible || 'Responsável não definido';
          document.getElementById('infoCost')!.innerText = new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(plano.how_much_cost || 0);
          
          const statusEl = document.getElementById('detalheStatus')!;
          const printStatusEl = document.getElementById('printStatus')!;
          statusEl.innerText = status;
          printStatusEl.innerText = `STATUS: ${status}`;
          
          const color = plano.status === 'Atrasado' ? '#b91c1c' : (plano.status === 'Concluído' ? '#15803d' : '#0369a1');
          const bgColor = plano.status === 'Atrasado' ? '#fee2e2' : (plano.status === 'Concluído' ? '#dcfce7' : '#e0f2fe');
          
          statusEl.style.background = bgColor;
          statusEl.style.color = color;
          printStatusEl.style.color = color;

          modalDetalhes.style.display = 'flex';
          
          // Buscar Histórico via API
          if (timelineContainer) {
            timelineContainer.innerHTML = '<div style="position: absolute; left: 7px; top: 0; bottom: 0; width: 2px; background: #e2e8f0; z-index: 0;"></div><div style="text-align: center; padding: 1rem; color: var(--color-text-muted); font-size: 0.875rem;">Carregando histórico...</div>';
            
            try {
              const res = await fetch(`/api/planos/${plano.id}/historico`);
              const historico = await res.json();
              
              let html = '<div style="position: absolute; left: 7px; top: 0; bottom: 0; width: 2px; background: #e2e8f0; z-index: 0;"></div>';
              
              if (historico.length === 0) {
                html += '<div style="text-align: center; padding: 1rem; color: var(--color-text-muted); font-size: 0.875rem; position: relative; z-index: 1; background: white;">Nenhum registro de movimentação ainda.</div>';
              } else {
                historico.forEach((step: any) => {
                  html += `
                    <div style="position: relative; z-index: 1; padding-left: 1.5rem;">
                      <div style="position: absolute; left: 0; top: 5px; width: 16px; height: 16px; border-radius: 50%; background: white; border: 3px solid var(--color-primary);"></div>
                      <div style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); margin-bottom: 0.25rem;">
                        ${new Date(step.created_at).toLocaleDateString('pt-BR')} ${new Date(step.created_at).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'})}
                      </div>
                      <div style="font-size: 0.875rem; font-weight: 600; color: var(--color-primary);">${step.responsavel_nome}</div>
                      <p style="font-size: 0.825rem; color: var(--color-text); margin: 0.25rem 0 0;">${step.descricao}</p>
                      ${step.data_prevista_checkpoint ? `<div style="font-size: 0.7rem; color: #b91c1c; font-weight: 600; margin-top: 0.4rem; display: flex; align-items: center; gap: 0.25rem;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Checkpoint: ${new Date(step.data_prevista_checkpoint).toLocaleDateString('pt-BR')}</div>` : ''}
                    </div>
                  `;
                });
              }
              timelineContainer.innerHTML = html;
            } catch (err) {
              timelineContainer.innerHTML = '<div style="text-align: center; padding: 1rem; color: #ef4444; font-size: 0.875rem; position: relative; z-index: 1; background: white;">Erro ao carregar linha do tempo.</div>';
            }
          }
        });
      });

      // Lógica do Modal de Gerenciar Ação
      const modalGerenciar = document.getElementById('modalGerenciarAcao');
      const btnFecharGerenciar = document.getElementById('btnFecharGerenciar');
      const btnCancelarGerenciar = document.getElementById('btnCancelarGerenciar');
      const selectAcaoTomar = document.getElementById('selectAcaoTomar');
      const divProximoResponsavel = document.getElementById('divProximoResponsavel');
      const btnSalvarGerenciar = document.getElementById('btnSalvarGerenciar');
      // currentPlanoId removido para evitar avisos de build.

      const btnsGerenciar = document.querySelectorAll('.btnGerenciarAcao');
      btnsGerenciar.forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          if (modalGerenciar) modalGerenciar.style.display = 'flex';
        });
      });

      const fecharGerenciar = () => { if(modalGerenciar) modalGerenciar.style.display = 'none'; };
      if (btnFecharGerenciar) btnFecharGerenciar.addEventListener('click', fecharGerenciar);
      if (btnCancelarGerenciar) btnCancelarGerenciar.addEventListener('click', fecharGerenciar);
      
      if (selectAcaoTomar && divProximoResponsavel) {
        selectAcaoTomar.addEventListener('change', (e) => {
          const val = (e.target as HTMLSelectElement).value;
          if (val === 'encerrar') {
             divProximoResponsavel.style.display = 'none';
          } else {
             divProximoResponsavel.style.display = 'block';
          }
        });
      }
      
      if (btnSalvarGerenciar) {
        btnSalvarGerenciar.addEventListener('click', () => {
           alert('Ação registrada com sucesso! Notificações disparadas para os envolvidos.');
           fecharGerenciar();
           // Na vida real, enviaria via fetch para uma API de atualização.
           setTimeout(() => window.location.reload(), 500);
        });
      }
      
      if (modalGerenciar) {
         modalGerenciar.addEventListener('click', (e) => {
            if (e.target === modalGerenciar) fecharGerenciar();
         });
      }
      
      // Auto-open logic using dataset
      if (dataStore && dataStore.dataset.autoOpen === "true" && modal) {
         modal.style.display = 'flex';
      }
    }

    document.addEventListener('DOMContentLoaded', initPgrModal);
    document.addEventListener('astro:page-load', initPgrModal);
    initPgrModal();
  </script>
  <style>
    @media print {
      /* Esconder absolutamente tudo que não seja o modal */
      body * {
        visibility: hidden !important;
      }
      
      #modalDetalhesPlano, #modalDetalhesPlano * {
        visibility: visible !important;
      }

      /* Resetar posicionamento do modal para preencher a folha */
      #modalDetalhesPlano {
        position: absolute !important;
        left: 0 !important;
        top: 0 !important;
        width: 100% !important;
        height: auto !important;
        display: block !important;
        background: white !important;
        padding: 0 !important;
        margin: 0 !important;
        overflow: visible !important;
        z-index: 9999 !important;
      }

      #printableArea {
        width: 100% !important;
        max-width: none !important;
        box-shadow: none !important;
        margin: 0 !important;
        padding: 0 !important;
        overflow: visible !important;
        border-radius: 0 !important;
      }

      .only-print {
        display: flex !important;
      }

      .no-print {
        display: none !important;
      }

      #reportContent {
        display: block !important; /* Em print, colunas empilham melhor ou o layout deve ser ajustado */
        padding: 0 !important;
      }

      section {
        page-break-inside: avoid;
        margin-top: 2rem !important;
      }

      #timelineContainer {
        margin-top: 3rem !important;
        padding-left: 0 !important;
        border-left: none !important;
      }

      #timelineContainer > div {
        page-break-inside: avoid;
      }

      /* Forçar cores de fundo na impressão */
      * {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }
    }
  </style>
</Layout>
