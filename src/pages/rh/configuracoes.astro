---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import { ColaboradoresService } from '../../services/ColaboradoresService';

const supabaseClient = supabase(Astro);
const { data: { user } } = await supabaseClient.auth.getUser();

let data = { user: { email: 'rh@empresa.com', name: 'Gestão RH' }, company: 'Empresa Teste / Mock' };

if (user) {
  data.user.email = user.email || '';
  const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome, empresas(nome)').eq('id', user.id).single();
  if (perfil) {
    data.user.name = perfil.nome;
    if (perfil.empresas) data.company = (perfil.empresas as any).nome;
  }
}

const service = new ColaboradoresService(supabaseClient);
let message = '';
let isError = false;

// Handle Form Submissions via SSR
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action');

    if (action === 'add_setor') {
      const nome = formData.get('setor_nome')?.toString();
      if (nome) await service.addSetor(nome);
      message = "Setor adicionado com sucesso!";
    } else if (action === 'del_setor') {
      const id = formData.get('setor_id')?.toString();
      if (id) await service.deleteSetor(id);
      message = "Setor removido com sucesso!";
    } else if (action === 'add_colaborador') {
      const nome = formData.get('colab_nome')?.toString();
      const email = formData.get('colab_email')?.toString();
      const cargo = formData.get('colab_cargo')?.toString();
      const setorId = formData.get('colab_setor')?.toString();
      if (nome && email && cargo) {
        await service.addColaborador(nome, email, cargo, setorId || null);
        message = "Colaborador adicionado com sucesso!";
      }
    } else if (action === 'del_colaborador') {
      const id = formData.get('colab_id')?.toString();
      if (id) await service.deleteColaborador(id);
      message = "Colaborador removido!";
    }
  } catch (err: any) {
    isError = true;
    message = "Erro: " + err.message;
  }
}

// Fetch lists
const setores = await service.getSetores();
const colaboradores = await service.getColaboradores();
---

<Layout title="Cadastro de Base | RH NR1">
  <div class="app-layout">
    
    <!-- Sidebar RH / Empresa -->
    <aside class="sidebar">
      <div style="padding: 1.5rem 1rem; border-bottom: 1px solid var(--color-border); display: flex; align-items: center; justify-content: space-between;">
        <h1 style="color: var(--color-primary); font-size: 1.25rem; font-weight: 600; margin: 0; display: flex; align-items: center; gap: 0.5rem; line-height: 1.2;">
          <svg style="width: 24px; height: 24px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          {data.company}
        </h1>
      </div>
      
      <div style="padding: 1rem; border-bottom: 1px solid var(--color-border); background: #fbfbfc;">
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
          <div style="width: 36px; height: 36px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; color: var(--color-text-muted);">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </div>
          <div>
            <p style="font-size: 0.8rem; font-weight: 600; color: var(--color-text); margin: 0;">{data.user.name}</p>
            <p style="font-size: 0.7rem; color: var(--color-text-muted); margin: 0;">{data.user.email}</p>
          </div>
        </div>
      </div>

      <nav style="flex: 1; padding: 1rem 0; overflow-y: auto;">
        <ul style="list-style: none; margin: 0; padding: 0;">
          <li>
            <a href="/rh/dashboard" style="display: flex; align-items: center; padding: 0.75rem 1rem; color: var(--color-text); text-decoration: none; font-size: 0.8rem; font-weight: 500; gap: 0.75rem;">
               <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
              DASHBOARD MATRIZ
            </a>
          </li>
          <li>
            <a href="/rh/pesquisas" style="display: flex; align-items: center; padding: 0.75rem 1rem; color: var(--color-text); text-decoration: none; font-size: 0.8rem; font-weight: 500; gap: 0.75rem;">
               <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              DISPAROS DE PESQUISA
            </a>
          </li>
          <li>
            <a href="/rh/planos-de-acao" style="display: flex; align-items: center; padding: 0.75rem 1rem; color: var(--color-text); text-decoration: none; font-size: 0.8rem; font-weight: 500; gap: 0.75rem;">
               <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              PLANOS DE AÇÃO (PGR)
            </a>
          </li>
          <li>
            <a href="/rh/denuncias" style="display: flex; align-items: center; padding: 0.75rem 1rem; color: var(--color-text); text-decoration: none; font-size: 0.8rem; font-weight: 500; gap: 0.75rem;">
               <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
              CANAL DE DENÚNCIAS
            </a>
          </li>
          <li style="background: white; border-left: 3px solid var(--color-primary); margin-top: 2rem; border-top: 1px solid var(--color-border);">
            <a href="/rh/configuracoes" style="display: flex; align-items: center; padding: 0.75rem 1rem; color: var(--color-primary); text-decoration: none; font-size: 0.8rem; font-weight: 600; gap: 0.75rem;">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33h.09a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
              CONFIGURAÇÕES
            </a>
          </li>
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <div style="padding: 2rem 3rem;">
        
        <div style="margin-bottom: 2rem;">
          <h2 style="font-size: 1.5rem; color: var(--color-primary); font-weight: 400; margin: 0;">Organograma e Colaboradores</h2>
          <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-top: 0.25rem;">Gerencie os setores (GHE) e cadastre a lista de funcionários que receberão as pesquisas.</p>
        </div>

        {message && (
          <div style={`padding: 1rem; margin-bottom: 2rem; border-radius: 4px; font-weight: 600; font-size: 0.875rem; ${isError ? 'background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca;' : 'background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0;'}`}>
            {message}
          </div>
        )}

        <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem;">
          
          <!-- SECTORS MANAGEMENT -->
          <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; display: flex; flex-direction: column;">
             <div style="padding: 1rem 1.5rem; border-bottom: 1px solid var(--color-border); background: #fbfbfc;">
               <h3 style="margin: 0; font-size: 1rem; color: var(--color-text); display: flex; align-items: center; gap: 0.5rem;">
                 <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
                 Setores / GHE
               </h3>
             </div>
             <div style="padding: 1.5rem;">
               <form method="POST" style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem;">
                 <input type="hidden" name="action" value="add_setor" />
                 <input type="text" name="setor_nome" placeholder="Nome do Novo Setor..." required style="flex: 1; padding: 0.5rem; border: 1px solid var(--color-border); border-radius: 4px; outline: none; font-size: 0.875rem;" />
                 <button type="submit" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.75rem;">+ ADICIONAR</button>
               </form>

               <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                 {setores.length === 0 && <span style="font-size: 0.875rem; color: var(--color-text-muted);">Nenhum setor cadastrado.</span>}
                 {setores.map(setor => (
                   <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: 4px; background: #f8fafc;">
                     <span style="font-size: 0.875rem; font-weight: 500;">{setor.nome}</span>
                     <form method="POST" style="margin: 0;">
                       <input type="hidden" name="action" value="del_setor" />
                       <input type="hidden" name="setor_id" value={setor.id} />
                       <button type="submit" style="background: none; border: none; color: var(--color-danger); cursor: pointer; padding: 0;">
                         <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                       </button>
                     </form>
                   </div>
                 ))}
               </div>
             </div>
          </div>

          <!-- EMPLOYEES MANAGEMENT -->
          <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; display: flex; flex-direction: column;">
             <div style="padding: 1rem 1.5rem; border-bottom: 1px solid var(--color-border); background: #fbfbfc;">
               <h3 style="margin: 0; font-size: 1rem; color: var(--color-text); display: flex; align-items: center; gap: 0.5rem;">
                 <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                 Quadro de Colaboradores
               </h3>
             </div>
             <div style="padding: 1.5rem;">
               <div style="background: #f8fafc; border: 1px dashed var(--color-border); padding: 1rem; border-radius: 4px; margin-bottom: 1.5rem;">
                 <form method="POST" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                   <input type="hidden" name="action" value="add_colaborador" />
                   
                   <div>
                     <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--color-text-muted);">Nome Completo *</label>
                     <input type="text" name="colab_nome" required style="width: 100%; padding: 0.5rem; border: 1px solid var(--color-border); border-radius: 4px; outline: none; font-size: 0.875rem;" />
                   </div>
                   
                   <div>
                     <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--color-text-muted);">E-mail Corporativo *</label>
                     <input type="email" name="colab_email" required style="width: 100%; padding: 0.5rem; border: 1px solid var(--color-border); border-radius: 4px; outline: none; font-size: 0.875rem;" />
                   </div>
                   
                   <div>
                     <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--color-text-muted);">Cargo / Função *</label>
                     <input type="text" name="colab_cargo" required style="width: 100%; padding: 0.5rem; border: 1px solid var(--color-border); border-radius: 4px; outline: none; font-size: 0.875rem;" />
                   </div>
                   
                   <div>
                     <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--color-text-muted);">Setor (GHE vinculável)</label>
                     <select name="colab_setor" style="width: 100%; padding: 0.5rem; border: 1px solid var(--color-border); border-radius: 4px; outline: none; font-size: 0.875rem; background: white;">
                       <option value="">-- Selecione o Setor --</option>
                       {setores.map(s => (
                         <option value={s.id}>{s.nome}</option>
                       ))}
                     </select>
                   </div>
                   
                   <div style="grid-column: span 2; display: flex; justify-content: flex-end; margin-top: 0.5rem;">
                     <button type="submit" class="btn btn-primary" style="padding: 0.4rem 1.5rem; font-size: 0.75rem;">+ REGISTRAR COLABORADOR</button>
                   </div>
                 </form>
               </div>

               <div style="border: 1px solid var(--color-border); border-radius: 4px; overflow: hidden;">
                 <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
                   <thead style="background: #fbfbfc; border-bottom: 1px solid var(--color-border);">
                     <tr>
                       <th style="text-align: left; padding: 0.75rem 1rem; color: var(--color-text-muted); font-weight: 600; font-size: 0.75rem;">NOME & E-MAIL</th>
                       <th style="text-align: left; padding: 0.75rem 1rem; color: var(--color-text-muted); font-weight: 600; font-size: 0.75rem;">CARGO / SETOR</th>
                       <th style="text-align: right; padding: 0.75rem 1rem;"></th>
                     </tr>
                   </thead>
                   <tbody>
                     {colaboradores.length === 0 && (
                       <tr><td colspan="3" style="padding: 1rem; text-align: center; color: var(--color-text-muted);">Nenhum colaborador na base.</td></tr>
                     )}
                     {colaboradores.map(c => (
                       <tr style="border-bottom: 1px solid var(--color-border);">
                         <td style="padding: 0.75rem 1rem;">
                           <div style="font-weight: 600; color: var(--color-text);">{c.nome}</div>
                           <div style="font-size: 0.75rem; color: var(--color-text-muted);">{c.email}</div>
                         </td>
                         <td style="padding: 0.75rem 1rem;">
                           <div style="color: var(--color-text);">{c.cargo}</div>
                           <div style="font-size: 0.75rem; color: var(--color-primary);">{c.departamentos_unidades?.nome || 'Sem Setor'}</div>
                         </td>
                         <td style="padding: 0.75rem 1rem; text-align: right;">
                           <form method="POST" style="margin: 0; display: inline-block;">
                             <input type="hidden" name="action" value="del_colaborador" />
                             <input type="hidden" name="colab_id" value={c.id} />
                             <button type="submit" title="Remover" style="background: none; border: none; color: var(--color-danger); cursor: pointer; padding: 0;">
                               <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                             </button>
                           </form>
                         </td>
                       </tr>
                     ))}
                   </tbody>
                 </table>
               </div>

             </div>
          </div>

        </div>

      </div>
    </main>

  </div>
</Layout>
