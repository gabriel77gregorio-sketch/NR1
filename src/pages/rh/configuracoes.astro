---
import Layout from '../../layouts/Layout.astro';
import SidebarRH from '../../components/SidebarRH.astro';
import { supabase } from '../../lib/supabase';
import { ColaboradoresService } from '../../services/ColaboradoresService';

const supabaseClient = supabase(Astro);
let user = null;
try {
  const { data: authData } = await supabaseClient.auth.getUser();
  user = authData?.user;
} catch (e) { }

let data = { user: { email: 'rh@empresa.com', name: 'Gestão RH' }, company: 'Empresa Teste / Mock' };

if (user) {
  data.user.email = user.email || '';
  const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome, empresas(nome)').eq('id', user.id).single();
  if (perfil) {
    data.user.name = perfil.nome;
    if (perfil.empresas) data.company = (perfil.empresas as any).nome;
  }
}

function calcularTempoCasa(dataAdmissao: string | null) {
  if (!dataAdmissao) return '-';
  const inicio = new Date(dataAdmissao);
  const hoje = new Date();
  const diffTime = hoje.getTime() - inicio.getTime();
  if (diffTime < 0) return 'Futuro';
  const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
  
  if (diffDays < 30) return `${diffDays} dias`;
  if (diffDays < 365) {
    const meses = Math.floor(diffDays / 30);
    return `${meses} ${meses === 1 ? 'mês' : 'meses'}`;
  }
  const anos = Math.floor(diffDays / 365);
  const meses = Math.floor((diffDays % 365) / 30);
  return `${anos} ${anos === 1 ? 'ano' : 'anos'}${meses > 0 ? ` e ${meses} ${meses === 1 ? 'mês' : 'meses'}` : ''}`;
}

const service = new ColaboradoresService(supabaseClient);
let message = '';
let isError = false;

// Handle Form Submissions via SSR
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action');

    if (action === 'add_setor') {
      const nome = formData.get('setor_nome')?.toString();
      if (nome) await service.addSetor(nome);
      message = "Setor adicionado com sucesso!";
    } else if (action === 'del_setor') {
      const id = formData.get('setor_id')?.toString();
      if (id) await service.deleteSetor(id);
      message = "Setor removido com sucesso!";
    } else if (action === 'add_colaborador') {
      const nome = formData.get('colab_nome')?.toString();
      const email = formData.get('colab_email')?.toString();
      const cargo = formData.get('colab_cargo')?.toString();
      const setorId = formData.get('colab_setor')?.toString();
      const whatsapp = formData.get('colab_whatsapp')?.toString();
      const dataAdmissao = formData.get('colab_data_admissao')?.toString();
      if (nome && email && cargo) {
        await service.addColaborador(nome, email, cargo, setorId || null, whatsapp || null, dataAdmissao || null);
        message = "Colaborador adicionado com sucesso!";
      }
    } else if (action === 'del_colaborador') {
      const id = formData.get('colab_id')?.toString();
      if (id) await service.deleteColaborador(id);
      message = "Colaborador removido!";
    }
  } catch (err: any) {
    isError = true;
    message = "Erro: " + err.message;
  }
}

// Fetch lists
const setores = user ? await service.getSetores() : [];
const colaboradores = user ? await service.getColaboradores() : [];
---

<Layout title="Cadastro de Base | RH NR1">
  <div class="app-layout">
    
    <!-- Sidebar Modular -->
    <SidebarRH activeMenu="configuracoes" />

    <!-- Main Content -->
    <main class="main-content">
      <div class="page-container">
        
        <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem;">
          <div>
            <h1 style="font-size: 1.75rem; font-weight: 800; color: var(--color-text); margin: 0;">Configurações</h1>
            <p style="color: var(--color-text-muted); font-size: 0.95rem; margin-top: 0.25rem;">Gerencie os setores (GHE) e cadastre a lista de colaboradores da <strong>{data.company}</strong>.</p>
          </div>
          <label class="btn btn-primary" style="cursor: pointer;">
            <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
            IMPORTAR PLANILHA
            <input type="file" accept=".xlsx, .xls, .csv" style="display: none;" onchange="alert('Processando planilha...')" />
          </label>
        </header>

        {message && (
          <div style={`padding: 1rem 1.5rem; margin-bottom: 2rem; border-radius: 12px; font-weight: 600; font-size: 0.875rem; display: flex; align-items: center; gap: 0.75rem; ${isError ? 'background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca;' : 'background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0;'}`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v4M12 16h.01"></path></svg>
            {message}
          </div>
        )}

        <div style="display: grid; grid-template-columns: 320px 1fr; gap: 2rem; align-items: start;">
          
          <!-- SECTORS MANAGEMENT -->
          <div class="card" style="padding: 1.5rem; border-radius: 24px;">
             <div style="margin-bottom: 1.5rem;">
               <h3 style="margin: 0; font-size: 1rem; font-weight: 700; color: var(--color-text); display: flex; align-items: center; gap: 0.75rem;">
                 <svg style="width: 20px; height: 20px; color: var(--color-primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
                 Setores / GHE
               </h3>
             </div>
             
             <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem;">
               <input type="hidden" name="action" value="add_setor" />
               <input type="text" name="setor_nome" placeholder="Novo Setor..." required style="padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-background); outline: none; font-size: 0.875rem;" />
               <button type="submit" class="btn btn-outline" style="width: 100%;">+ ADICIONAR</button>
             </form>

             <div style="display: flex; flex-direction: column; gap: 0.75rem;">
               <p style="font-size: 0.7rem; font-weight: 800; color: var(--color-text-muted); text-transform: uppercase;">Setores Ativos</p>
               {setores.length === 0 && <span style="font-size: 0.875rem; color: var(--color-text-muted); opacity: 0.6;">Nenhum setor.</span>}
               {setores.map(setor => (
                 <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.875rem; border-radius: 12px; background: var(--color-background); border: 1px solid var(--color-border);">
                   <span style="font-size: 0.875rem; font-weight: 600;">{setor.nome}</span>
                   <form method="POST" style="margin: 0;">
                     <input type="hidden" name="action" value="del_setor" />
                     <input type="hidden" name="setor_id" value={setor.id} />
                     <button type="submit" style="background: none; border: none; color: #94a3b8; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#94a3b8'">
                       <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                     </button>
                   </form>
                 </div>
               ))}
             </div>
          </div>

          <!-- EMPLOYEES MANAGEMENT -->
          <div style="display: flex; flex-direction: column; gap: 2rem;">
             <!-- Form de Cadastro -->
             <div class="card" style="border-radius: 24px; padding: 2rem;">
                <h3 style="margin: 0 0 1.5rem 0; font-size: 1rem; font-weight: 700; color: var(--color-text); display: flex; align-items: center; gap: 0.75rem;">
                  <svg style="width: 20px; height: 20px; color: var(--color-primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
                  Novo Colaborador
                </h3>
                
                <form method="POST" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;">
                  <input type="hidden" name="action" value="add_colaborador" />
                  
                  <div style="grid-column: span 1;">
                    <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">NOME COMPLETO</label>
                    <input type="text" name="colab_nome" required style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-background); outline: none; font-size: 0.875rem;" />
                  </div>
                  
                  <div style="grid-column: span 1;">
                    <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">E-MAIL</label>
                    <input type="email" name="colab_email" required style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-background); outline: none; font-size: 0.875rem;" />
                  </div>
                  
                  <div style="grid-column: span 1;">
                    <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">WHATSAPP</label>
                    <input type="text" name="colab_whatsapp" placeholder="DDD+Número" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-background); outline: none; font-size: 0.875rem;" />
                  </div>

                  <div style="grid-column: span 1;">
                    <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">DATA DE ADMISSÃO</label>
                    <input type="date" name="colab_data_admissao" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-background); outline: none; font-size: 0.875rem;" />
                  </div>
                  
                  <div>
                    <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">CARGO</label>
                    <input type="text" name="colab_cargo" required style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-background); outline: none; font-size: 0.875rem;" />
                  </div>
                  
                  <div>
                    <label style="display: block; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text-muted);">SETOR / GHE</label>
                    <select name="colab_setor" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-background); outline: none; font-size: 0.875rem;">
                      <option value="">Nenhum Setor</option>
                      {setores.map(s => (
                        <option value={s.id}>{s.nome}</option>
                      ))}
                    </select>
                  </div>

                  <div style="display: flex; align-items: flex-end;">
                    <button type="submit" class="btn btn-primary" style="width: 100%;">CADASTRAR</button>
                  </div>
                </form>
             </div>

             <!-- Tabela -->
             <div class="card" style="border-radius: 24px; padding: 0; overflow: hidden;">
                <div style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--color-border);">
                  <h4 style="margin: 0; font-size: 1rem; font-weight: 700;">Base de Colaboradores</h4>
                </div>
                <div style="overflow-x: auto;">
                  <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
                    <thead>
                      <tr style="text-align: left; background: var(--color-background);">
                        <th style="padding: 1rem 2rem; color: var(--color-text-muted); font-weight: 700; font-size: 0.7rem; text-transform: uppercase;">Colaborador</th>
                        <th style="padding: 1rem 2rem; color: var(--color-text-muted); font-weight: 700; font-size: 0.7rem; text-transform: uppercase;">Cargo & Setor</th>
                        <th style="padding: 1rem 2rem; color: var(--color-text-muted); font-weight: 700; font-size: 0.7rem; text-transform: uppercase;">Tempo de Casa</th>
                        <th style="padding: 1rem 2rem; color: var(--color-text-muted); font-weight: 700; font-size: 0.7rem; text-transform: uppercase; text-align: right;">Ações</th>
                      </tr>
                    </thead>
                    <tbody>
                      {colaboradores.length === 0 && (
                        <tr><td colspan="3" style="padding: 4rem; text-align: center; color: var(--color-text-muted);">Nenhum colaborador cadastrado ainda.</td></tr>
                      )}
                      {colaboradores.map(c => (
                        <tr style="border-bottom: 1px solid var(--color-border); transition: background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                          <td style="padding: 1rem 2rem;">
                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                              <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--color-secondary); color: var(--color-primary); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.75rem;">
                                {c.nome.charAt(0)}
                              </div>
                              <div>
                                <p style="font-weight: 700; color: var(--color-text); margin: 0;">{c.nome}</p>
                                <p style="font-size: 0.75rem; color: var(--color-text-muted); margin: 0;">{c.email}</p>
                              </div>
                            </div>
                          </td>
                          <td style="padding: 1rem 2rem;">
                            <p style="font-weight: 600; color: var(--color-text); margin: 0;">{c.cargo}</p>
                            <p style="font-size: 0.75rem; color: var(--color-primary); margin: 0;">{c.departamentos_unidades?.nome || 'Sem Setor'}</p>
                          </td>
                          <td style="padding: 1rem 2rem;">
                            <p style="font-weight: 600; color: var(--color-text); margin: 0;">{calcularTempoCasa(c.data_admissao)}</p>
                            <p style="font-size: 0.75rem; color: var(--color-text-muted); margin: 0;">{c.data_admissao ? new Date(c.data_admissao).toLocaleDateString('pt-BR') : 'Sem data'}</p>
                          </td>
                          <td style="padding: 1rem 2rem; text-align: right;">
                            <form method="POST" style="margin: 0;">
                              <input type="hidden" name="action" value="del_colaborador" />
                              <input type="hidden" name="colab_id" value={c.id} />
                              <button type="submit" style="background: none; border: none; color: #94a3b8; cursor: pointer; padding: 0.5rem; border-radius: 8px; transition: all 0.2s;" onmouseover="this.style.background='#fee2e2'; this.style.color='#ef4444'" onmouseout="this.style.background='transparent'; this.style.color='#94a3b8'">
                                <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                              </button>
                            </form>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
             </div>
          </div>

        </div>

      </div>
    </main>

  </div>
</Layout>
