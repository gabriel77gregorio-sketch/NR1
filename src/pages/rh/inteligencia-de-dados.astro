---
import Layout from '../../layouts/Layout.astro';
import SidebarRH from '../../components/SidebarRH.astro';
import { supabase } from '../../lib/supabase';
import { AvaliacaoIndividualService } from '../../services/AvaliacaoIndividualService';

const supabaseClient = supabase(Astro);
let user = null;
try {
  const { data: authData } = await supabaseClient.auth.getUser();
  user = authData?.user;
} catch (e) { }

let kpis = { denuncias: 0, atestados: 0, dias: 0, avaliacoes: 0, turnover: '0.0' };

if (user) {
  const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('role, empresa_id').eq('id', user.id).single();
  if (perfil && !['Master', 'Diretoria', 'Segurança_Trabalho', 'RH', 'Admin_RH', 'SuperAdmin'].includes(perfil.role)) {
    return Astro.redirect('/rh/dashboard');
  }

  if (perfil) {
     const empId = perfil.empresa_id;

     // Denúncias
     const { count: cDenuncias } = await supabaseClient.from('denuncias_anonimas').select('*', { count: 'exact', head: true }).eq('empresa_id', empId).in('status', ['Nova', 'Em Análise', 'Pendente', 'Nova Denúncia']);
     kpis.denuncias = cDenuncias || 0;

     // Avaliações
     const { count: cAvaliacoes } = await supabaseClient.from('respostas_avaliacoes').select('*', { count: 'exact', head: true }).eq('empresa_id', empId);
     kpis.avaliacoes = cAvaliacoes || 0;

     // Atestados
     const { data: atestados } = await supabaseClient.from('atestados_medicos').select('dias_afastamento').eq('empresa_id', empId);
     if (atestados) {
       kpis.atestados = atestados.length;
       kpis.dias = atestados.reduce((acc, curr) => acc + (curr.dias_afastamento || 0), 0);
     }

     // Turnover
     const avalService = new AvaliacaoIndividualService(supabaseClient, empId);
     const stats = await avalService.getStats();
     const { count: totalColabs } = await supabaseClient.from('colaboradores_base').select('id', { count: 'exact', head: true }).eq('empresa_id', empId);
     kpis.turnover = totalColabs ? ((stats.desligamentos / totalColabs) * 100).toFixed(1) : '0.0';
  }
}
---

<Layout title="Inteligência de Dados | RH NR1">
  <div class="app-layout">
    <SidebarRH activeMenu="inteligencia-de-dados" />
    <main class="main-content" style="background: #fafafa;">
      <div style="padding: 2.5rem 3.5rem;">
        
        <!-- Header IA -->
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem;">
          <div>
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
               <div style="width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, #d946ef 0%, #8b5cf6 100%); display: flex; align-items: center; justify-content: center; color: white; box-shadow: 0 4px 15px rgba(217, 70, 239, 0.3);">
                  <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                     <path d="M12 2a2 2 0 0 1 2 2c0 1.1-.9 2-2 2s-2-.9-2-2 2-2 2-2z"/>
                     <path d="M19 8a2 2 0 0 1 2 2c0 1.1-.9 2-2 2s-2-.9-2-2 2-2 2-2z"/>
                     <path d="M5 8a2 2 0 0 1 2 2c0 1.1-.9 2-2 2s-2-.9-2-2 2-2 2-2z"/>
                     <path d="M12 16a2 2 0 0 1 2 2c0 1.1-.9 2-2 2s-2-.9-2-2 2-2 2-2z"/>
                     <path d="M12 8v8"/>
                     <path d="M7 10l5 4"/>
                     <path d="M17 10l-5 4"/>
                  </svg>
               </div>
               <h2 style="font-size: 1.8rem; color: #1e293b; font-weight: 700; margin: 0; letter-spacing: -0.5px;">Inteligência Preditiva NR1</h2>
            </div>
            <p style="color: var(--color-text-muted); font-size: 0.95rem; margin-top: 0; max-width: 600px;">
              Cruzamento automático de indicadores de saúde, denúncias e clima organizacional utilizando IA Generativa.
            </p>
          </div>
          <button id="btnGerar" class="btn btn-primary" style="background: linear-gradient(135deg, #d946ef 0%, #8b5cf6 100%); border: none; box-shadow: 0 4px 15px rgba(217, 70, 239, 0.2); gap: 0.5rem; padding: 0.75rem 1.5rem; font-weight: 700; font-size: 0.85rem; cursor: pointer;">
            <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>
            GERAR DIAGNÓSTICO
          </button>
        </div>

        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 2.5rem;">
           <div class="card" style="padding: 1.25rem;">
             <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); margin: 0 0 0.5rem 0; text-transform: uppercase;">Atestados Médicos</p>
             <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0; color: #0f172a;">{kpis.atestados} <span style="font-size: 0.8rem; font-weight: 600; color: var(--color-text-muted);">({kpis.dias} dias)</span></h3>
           </div>
           <div class="card" style="padding: 1.25rem;">
             <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); margin: 0 0 0.5rem 0; text-transform: uppercase;">Denúncias Ativas</p>
             <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0; color: #0f172a;">{kpis.denuncias}</h3>
           </div>
           <div class="card" style="padding: 1.25rem;">
             <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); margin: 0 0 0.5rem 0; text-transform: uppercase;">Avaliações NR1</p>
             <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0; color: #0f172a;">{kpis.avaliacoes}</h3>
           </div>
           <div class="card" style="padding: 1.25rem;">
             <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); margin: 0 0 0.5rem 0; text-transform: uppercase;">Taxa de Turnover</p>
             <h3 style="font-size: 1.5rem; font-weight: 800; margin: 0; color: #0f172a;">{kpis.turnover}%</h3>
           </div>
        </div>

        <div id="loading" style="display: none; padding: 4rem; text-align: center;">
           <svg style="width: 48px; height: 48px; color: #d946ef; animation: spin 1s linear infinite;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" stroke-dasharray="16 16"></circle></svg>
           <p style="font-weight: 600; color: var(--color-text-muted); margin-top: 1rem;">O motor de IA da NR1 está cruzando os dados da base...</p>
        </div>

        <div id="resultado" style="display: none;">
           <div class="card" style="margin-bottom: 2rem; border-top: 4px solid #8b5cf6;">
             <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
               <h3 style="font-size: 1.2rem; font-weight: 700; margin: 0;">Análise do Cenário Atual</h3>
               <span id="badge-risco" style="padding: 0.4rem 1rem; border-radius: 99px; font-weight: 800; font-size: 0.75rem;">RISCO MÉDIO</span>
             </div>
             <p id="texto-analise" style="font-size: 1rem; line-height: 1.7; color: var(--color-text); margin: 0;"></p>
           </div>

           <h3 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 1rem;">Planos de Ação Sugeridos</h3>
           <div id="planos-container" style="display: grid; gap: 1.5rem;">
             <!-- Planos renderizados aqui via JS -->
           </div>
        </div>

        <div id="initial-state" style="text-align: center; padding: 4rem 2rem; background: white; border-radius: 16px; border: 1px dashed var(--color-border);">
           <svg style="width: 48px; height: 48px; color: #cbd5e1; margin: 0 auto 1rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
           <h3 style="font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem; font-size: 1.2rem;">Pronto para analisar</h3>
           <p style="color: var(--color-text-muted); max-width: 400px; margin: 0 auto; line-height: 1.5;">Clique no botão superior "Gerar Diagnóstico" para que nossa IA leia os KPIs atuais e emita um parecer preditivo.</p>
        </div>

      </div>
    </main>
  </div>
</Layout>

<script is:inline define:vars={{ kpis }}>
  const btnGerar = document.getElementById('btnGerar');
  const loading = document.getElementById('loading');
  const resultado = document.getElementById('resultado');
  const initialState = document.getElementById('initial-state');
  
  const txtAnalise = document.getElementById('texto-analise');
  const badgeRisco = document.getElementById('badge-risco');
  const planosContainer = document.getElementById('planos-container');

  btnGerar.addEventListener('click', async () => {
    initialState.style.display = 'none';
    resultado.style.display = 'none';
    loading.style.display = 'block';
    
    try {
      const res = await fetch('/api/rh/inteligencia/gerar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ kpis })
      });
      
      const data = await res.json();
      
      if (!res.ok) throw new Error(data.error || 'Erro ao gerar análise');

      // Preencher análise
      txtAnalise.textContent = data.analise_cenario;
      
      // Risco
      badgeRisco.textContent = `RISCO ${data.nivel_risco_geral.toUpperCase()}`;
      if (data.nivel_risco_geral.toLowerCase().includes('alto')) {
        badgeRisco.style.background = '#fee2e2'; badgeRisco.style.color = '#ef4444';
      } else if (data.nivel_risco_geral.toLowerCase().includes('médio') || data.nivel_risco_geral.toLowerCase().includes('medio')) {
        badgeRisco.style.background = '#fef3c7'; badgeRisco.style.color = '#f59e0b';
      } else {
        badgeRisco.style.background = '#dcfce7'; badgeRisco.style.color = '#10b981';
      }

      // Renderizar planos
      planosContainer.innerHTML = '';
      data.planos_acao.forEach(plano => {
        let corPrioridade = '#3b82f6';
        let bgPrioridade = '#eff6ff';
        if (plano.prioridade.toLowerCase() === 'alta') { corPrioridade = '#ef4444'; bgPrioridade = '#fee2e2'; }
        if (plano.prioridade.toLowerCase() === 'baixa') { corPrioridade = '#10b981'; bgPrioridade = '#dcfce7'; }

        planosContainer.innerHTML += `
          <div class="card" style="padding: 1.5rem; display: flex; gap: 1.5rem; align-items: flex-start; border-left: 4px solid ${corPrioridade};">
            <div style="flex: 1;">
              <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; align-items: center;">
                <h4 style="font-weight: 700; margin: 0; font-size: 1rem;">${plano.titulo}</h4>
                <span style="font-size: 0.65rem; font-weight: 800; padding: 0.2rem 0.6rem; border-radius: 4px; background: ${bgPrioridade}; color: ${corPrioridade}; text-transform: uppercase;">${plano.prioridade} Prioridade</span>
              </div>
              <p style="font-size: 0.9rem; color: var(--color-text-muted); margin: 0; line-height: 1.5;">${plano.descricao}</p>
            </div>
          </div>
        `;
      });

      loading.style.display = 'none';
      resultado.style.display = 'block';
    } catch (e) {
      alert(e.message);
      loading.style.display = 'none';
      initialState.style.display = 'block';
    }
  });
</script>

<style>
  @keyframes spin { 100% { transform: rotate(360deg); } }
</style>
