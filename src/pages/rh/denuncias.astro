---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const supabaseClient = supabase(Astro);
const { data: { user } } = await supabaseClient.auth.getUser();

// Mocked data fallback
const data = { user: { email: 'rh@empresa.com', name: 'Comitê de Ética' }, company: 'Empresa Teste' };

if (user) {
  data.user.email = user.email || '';
  const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome').eq('id', user.id).single();
  if (perfil) data.user.name = perfil.nome;
}

let denuncias: any[] = [];
if (user) {
  const { data: perfilData } = await supabaseClient.from('perfis_usuarios').select('empresa_id').eq('id', user.id).single();
  if (perfilData) {
    const { data: dbDenuncias } = await supabaseClient
      .from('denuncias_anonimas')
      .select('*')
      .eq('empresa_id', perfilData.empresa_id)
      .order('created_at', { ascending: false });

    if (dbDenuncias) {
      denuncias = dbDenuncias.map(d => ({
        protocolo: d.protocolo,
        data: d.created_at ? new Date(d.created_at).toLocaleDateString('pt-BR') : '-',
        severidade: 'Pendente',
        status: d.status || 'Nova Denúncia',
        ultima_att: d.created_at ? new Date(d.created_at).toLocaleDateString('pt-BR') : '-'
      }));
    }
  }
}

---

<Layout title="Canal de Denúncias | RH NR1">
  <div class="app-layout">
    
    <!-- Sidebar RH / Empresa -->
    <aside class="sidebar">
      <div style="padding: 1.5rem 1rem; border-bottom: 1px solid var(--color-border); display: flex; align-items: center; justify-content: space-between;">
        <h1 style="color: var(--color-primary); font-size: 1.25rem; font-weight: 600; margin: 0; display: flex; align-items: center; gap: 0.5rem; line-height: 1.2;">
          <svg style="width: 24px; height: 24px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          {data.company}
        </h1>
      </div>
      
      <div style="padding: 1rem; border-bottom: 1px solid var(--color-border); background: #fbfbfc;">
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
          <div style="width: 36px; height: 36px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; color: var(--color-text-muted);">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <div>
            <p style="font-size: 0.8rem; font-weight: 600; color: var(--color-text); margin: 0;">{data.user.name}</p>
            <p style="font-size: 0.7rem; color: var(--color-text-muted); margin: 0;">Visão Restrita</p>
          </div>
        </div>
      </div>

      <nav style="flex: 1; padding: 1rem 0; overflow-y: auto;">
        <ul style="list-style: none; margin: 0; padding: 0;">
          <li>
            <a href="/rh/dashboard" style="display: flex; align-items: center; padding: 0.75rem 1rem; color: var(--color-text); text-decoration: none; font-size: 0.8rem; font-weight: 500; gap: 0.75rem;">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
              DASHBOARD MATRIZ
            </a>
          </li>
          <li>
            <a href="/rh/pesquisas" style="display: flex; align-items: center; padding: 0.75rem 1rem; color: var(--color-text); text-decoration: none; font-size: 0.8rem; font-weight: 500; gap: 0.75rem;">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              DISPAROS DE PESQUISA
            </a>
          </li>
          <li>
            <a href="/rh/planos-de-acao" style="display: flex; align-items: center; padding: 0.75rem 1rem; color: var(--color-text); text-decoration: none; font-size: 0.8rem; font-weight: 500; gap: 0.75rem;">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              PLANOS DE AÇÃO (PGR)
            </a>
          </li>
          <li style="background: white; border-left: 3px solid var(--color-danger);">
            <a href="/rh/denuncias" style="display: flex; align-items: center; padding: 0.75rem 1rem; color: var(--color-danger); text-decoration: none; font-size: 0.8rem; font-weight: 600; gap: 0.75rem;">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
              CANAL DE DENÚNCIAS
            </a>
          </li>
          <li style="margin-top: 2rem; border-top: 1px solid var(--color-border); padding-top: 0.5rem;">
            <a href="/rh/configuracoes" style="display: flex; align-items: center; padding: 0.75rem 1rem; color: var(--color-text); text-decoration: none; font-size: 0.8rem; font-weight: 500; gap: 0.75rem;">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33h.09a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
              CONFIGURAÇÕES
            </a>
          </li>
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <div style="padding: 2rem 3rem;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
          <div>
            <h2 style="font-size: 1.5rem; color: var(--color-danger); font-weight: 400; margin: 0;">Tratamento de Denúncias Anônimas</h2>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-top: 0.25rem;">Ambiente restrito. Avalie relatados de desvios e assédios com total sigilo.</p>
          </div>
          <div style="display: flex; gap: 1rem;">
             <a href="/rh/relatorio-denuncias" target="_blank" class="btn btn-outline" style="border-color: var(--color-danger); color: var(--color-danger); text-decoration: none; display: flex; align-items: center;">
              <svg style="width: 16px; height: 16px; margin-right: 0.5rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              GERAR RELATÓRIO PDF
            </a>
          </div>
        </div>

        <!-- Indicadores -->
        <div style="display: flex; gap: 1rem; margin-bottom: 2rem;">
          <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem 1.5rem; flex: 1;">
            <div style="font-size: 0.75rem; color: var(--color-text-muted); font-weight: 600;">NOVAS (7 DIAS)</div>
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--color-danger);">1</div>
          </div>
          <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem 1.5rem; flex: 1;">
            <div style="font-size: 0.75rem; color: var(--color-text-muted); font-weight: 600;">EM APURAÇÃO</div>
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--color-warning);">1</div>
          </div>
          <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem 1.5rem; flex: 1;">
            <div style="font-size: 0.75rem; color: var(--color-text-muted); font-weight: 600;">RESOLVIDAS</div>
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--color-text);">1</div>
          </div>
        </div>

        <!-- Table Content -->
        <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-text);">Caixa de Entrada de Ocorrências</h3>
        <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden;">
          <div style="display: flex; padding: 1rem; font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); letter-spacing: 0.5px; border-bottom: 1px solid var(--color-border); background: #fbfbfc;">
            <div style="flex: 1.5;">PROTOCOLO E DATA</div>
            <div style="flex: 1; text-align: center;">SEVERIDADE EST.</div>
            <div style="flex: 1; text-align: center;">ÚLTIMA INTERAÇÃO</div>
            <div style="flex: 1; text-align: center;">STATUS DO COMITÊ</div>
            <div style="width: 100px; text-align: center;">AÇÕES</div>
          </div>

          <div style="display: flex; flex-direction: column;">
            {denuncias.map((denuncia) => (
              <div style="display: flex; align-items: center; padding: 1.25rem 1rem; font-size: 0.875rem; border-bottom: 1px solid var(--color-border);">
                <div style="flex: 1.5;">
                  <div style="font-weight: 600; color: var(--color-text); font-family: monospace; font-size: 1rem;">{denuncia.protocolo}</div>
                  <div style="color: var(--color-text-muted); font-size: 0.75rem; margin-top: 0.2rem;">Registrada em {denuncia.data}</div>
                </div>
                <div style="flex: 1; text-align: center;">
                  <span style={`font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.6rem; border-radius: 999px; text-transform: uppercase; background: ${denuncia.severidade === 'Crítica' ? '#fee2e2' : (denuncia.severidade === 'Alta' ? '#ffedd5' : '#f1f5f9')}; color: ${denuncia.severidade === 'Crítica' ? 'var(--color-danger)' : (denuncia.severidade === 'Alta' ? 'var(--color-warning)' : 'var(--color-text-muted)')};`}>
                    {denuncia.severidade}
                  </span>
                </div>
                <div style="flex: 1; text-align: center; color: var(--color-text-muted);">
                  {denuncia.ultima_att}
                </div>
                <div style="flex: 1; display: flex; justify-content: center;">
                  <span style={`font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.6rem; border-radius: 999px; text-transform: uppercase; background: ${denuncia.status === 'Nova Denúncia' ? '#fee2e2' : (denuncia.status === 'Em Apuração' ? '#e0e7ff' : '#d1fae5')}; color: ${denuncia.status === 'Nova Denúncia' ? 'var(--color-danger)' : (denuncia.status === 'Em Apuração' ? 'var(--color-primary)' : 'var(--color-success)')};`}>
                    {denuncia.status}
                  </span>
                </div>
                <div style="width: 100px; text-align: center;">
                  <button class="btn btn-outline" style="font-size: 0.65rem; padding: 0.3rem 0.6rem; color: var(--color-text);">TRATAR</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </main>

  </div>
</Layout>
