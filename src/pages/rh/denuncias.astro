---
import Layout from '../../layouts/Layout.astro';
import SidebarRH from '../../components/SidebarRH.astro';
import { supabase } from '../../lib/supabase';

const supabaseClient = supabase(Astro);
let user = null;
try {
  const { data: authData } = await supabaseClient.auth.getUser();
  user = authData?.user;
} catch (e) { }

// Mocked data fallback
const data = { user: { email: 'rh@empresa.com', name: 'Comitê de Ética' }, company: 'Empresa Teste' };

if (user) {
  data.user.email = user.email || '';
  const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome').eq('id', user.id).single();
  if (perfil) data.user.name = perfil.nome;
}

let denuncias: any[] = [];
if (user) {
  const { data: perfilData } = await supabaseClient.from('perfis_usuarios').select('empresa_id').eq('id', user.id).single();
  if (perfilData) {
    const { data: dbDenuncias } = await supabaseClient
      .from('denuncias_anonimas')
      .select('*')
      .eq('empresa_id', perfilData.empresa_id)
      .order('created_at', { ascending: false });

    if (dbDenuncias) {
      denuncias = dbDenuncias.map(d => ({
        protocolo: d.protocolo,
        data: d.created_at ? new Date(d.created_at).toLocaleDateString('pt-BR') : '-',
        data_iso: d.created_at || new Date().toISOString(),
        texto: d.texto,
        severidade: 'Pendente',
        status: d.status || 'Nova Denúncia',
        ultima_att: d.created_at ? new Date(d.created_at).toLocaleDateString('pt-BR') : '-'
      }));
    }
  }
}
---

<Layout title="Canal de Denúncias | RH NR1">
  <div class="app-layout">
    
    <!-- Sidebar Modular -->
    <SidebarRH activeMenu="denuncias" />

    <!-- Main Content -->
    <main class="main-content">
      <div style="padding: 2rem 3rem;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
          <div>
            <h2 style="font-size: 1.5rem; color: var(--color-danger); font-weight: 400; margin: 0;">Tratamento de Denúncias Anônimas</h2>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-top: 0.25rem;">Ambiente restrito. Avalie relatados de desvios e assédios com total sigilo.</p>
          </div>
          <div style="display: flex; gap: 1rem;">
             <a href="/rh/relatorio-denuncias" target="_blank" class="btn btn-outline" style="border-color: var(--color-danger); color: var(--color-danger); text-decoration: none; display: flex; align-items: center;">
              <svg style="width: 16px; height: 16px; margin-right: 0.5rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              GERAR RELATÓRIO PDF
            </a>
          </div>
        </div>

        <!-- Indicadores -->
        <div style="display: flex; gap: 1rem; margin-bottom: 2rem;">
          <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem 1.5rem; flex: 1;">
            <div style="font-size: 0.75rem; color: var(--color-text-muted); font-weight: 600;">NOVAS (TOTAL)</div>
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--color-danger);">{denuncias.filter(d => d.status === 'Nova Denúncia').length}</div>
          </div>
          <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem 1.5rem; flex: 1;">
            <div style="font-size: 0.75rem; color: var(--color-text-muted); font-weight: 600;">EM APURAÇÃO</div>
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--color-warning);">{denuncias.filter(d => d.status === 'Em Apuração').length}</div>
          </div>
        </div>
        
        <!-- Link de Divulgação do Canal -->
        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
          <div style="display: flex; align-items: center; gap: 1rem;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: #fee2e2; display: flex; align-items: center; justify-content: center; color: #ef4444; flex-shrink: 0;">
              <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
            </div>
            <div>
              <h3 style="margin: 0; font-size: 0.95rem; font-weight: 700; color: #1e293b;">Link Público do Canal de Denúncia</h3>
              <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: #64748b;">Este link deve ser divulgado em canais oficiais (E-mail, Mural, WhatsApp).</p>
            </div>
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem; background: #f8fafc; padding: 0.5rem 0.5rem 0.5rem 1rem; border: 1px solid #e2e8f0; border-radius: 8px; flex: 1; max-width: 500px;">
            <code id="canalLink" style="font-size: 0.85rem; color: #ef4444; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">/canal-de-denuncia</code>
            <button id="btnCopiarLink" class="btn" style="padding: 0.5rem 1rem; font-size: 0.75rem; background: #ef4444; color: white; border: none; white-space: nowrap; font-weight: 700; border-radius: 6px; cursor: pointer;">COPIAR LINK</button>
          </div>
        </div>

        <!-- Filtros -->
        <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem; margin-bottom: 1.5rem; display: flex; gap: 1.5rem; align-items: center;">
          <div style="font-size: 0.85rem; font-weight: 600; color: var(--color-text-muted);">FILTRAR POR:</div>
          <select id="filtroStatus" style="padding: 0.5rem; border: 1px solid var(--color-border); border-radius: 4px; outline: none; font-size: 0.85rem; background: #fbfbfc;">
             <option value="todas">Todas as Situações</option>
             <option value="Nova Denúncia">Novas Denúncias (Não lidas)</option>
             <option value="Em Apuração">Em Apuração (Tratativa)</option>
             <option value="Resolvida">Resolvidas / Fechadas</option>
          </select>
          <select id="filtroPeriodo" style="padding: 0.5rem; border: 1px solid var(--color-border); border-radius: 4px; outline: none; font-size: 0.85rem; background: #fbfbfc;">
             <option value="todos">Qualquer Data</option>
             <option value="7">Últimos 7 dias</option>
             <option value="30">Últimos 30 dias</option>
          </select>
        </div>

        <!-- Table Content -->
        <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-text);">Caixa de Entrada de Ocorrências</h3>
        <div style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden;">
          <div style="display: flex; padding: 1rem; font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); letter-spacing: 0.5px; border-bottom: 1px solid var(--color-border); background: #fbfbfc;">
            <div style="flex: 1.5;">PROTOCOLO E DATA</div>
            <div style="flex: 1; text-align: center;">SEVERIDADE EST.</div>
            <div style="flex: 1; text-align: center;">ÚLTIMA INTERAÇÃO</div>
            <div style="flex: 1; text-align: center;">STATUS DO COMITÊ</div>
            <div style="width: 100px; text-align: center;">AÇÕES</div>
          </div>

          <div id="listaDenuncias" style="display: flex; flex-direction: column;">
            {denuncias.length === 0 ? (
               <div style="padding: 3rem; text-align: center; color: var(--color-text-muted);">
                 Nenhuma denúncia encontrada na caixa de entrada.
               </div>
            ) : denuncias.map((denuncia) => (
              <div class="denuncia-row" data-status={denuncia.status} data-date={denuncia.data_iso} data-texto={denuncia.texto} data-protocolo={denuncia.protocolo} style="display: flex; align-items: center; padding: 1.25rem 1rem; font-size: 0.875rem; border-bottom: 1px solid var(--color-border);">
                <div style="flex: 1.5;">
                  <div style="font-weight: 600; color: var(--color-text); font-family: monospace; font-size: 1rem;">{denuncia.protocolo}</div>
                  <div style="color: var(--color-text-muted); font-size: 0.75rem; margin-top: 0.2rem;">Registrada em {denuncia.data}</div>
                </div>
                <div style="flex: 1; text-align: center;">
                  <span style={`font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.6rem; border-radius: 999px; text-transform: uppercase; background: ${denuncia.severidade === 'Crítica' ? '#fee2e2' : (denuncia.severidade === 'Alta' ? '#ffedd5' : '#f1f5f9')}; color: ${denuncia.severidade === 'Crítica' ? 'var(--color-danger)' : (denuncia.severidade === 'Alta' ? 'var(--color-warning)' : 'var(--color-text-muted)')};`}>
                    {denuncia.severidade}
                  </span>
                </div>
                <div style="flex: 1; text-align: center; color: var(--color-text-muted);">
                  {denuncia.ultima_att}
                </div>
                <div style="flex: 1; display: flex; justify-content: center;">
                  <span style={`font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.6rem; border-radius: 999px; text-transform: uppercase; background: ${denuncia.status === 'Nova Denúncia' ? '#fee2e2' : (denuncia.status === 'Em Apuração' ? '#e0e7ff' : '#d1fae5')}; color: ${denuncia.status === 'Nova Denúncia' ? 'var(--color-danger)' : (denuncia.status === 'Em Apuração' ? 'var(--color-primary)' : 'var(--color-success)')};`}>
                    {denuncia.status}
                  </span>
                </div>
                <div style="width: 100px; text-align: center;">
                  <button class="btn btn-outline btnTratar" data-protocolo={denuncia.protocolo} data-texto={denuncia.texto} data-status={denuncia.status} style="font-size: 0.65rem; padding: 0.3rem 0.6rem; color: var(--color-text); cursor: pointer;">TRATAR</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </main>

    <!-- Overlay/Modal Tratamento de Denúncia -->
    <div id="modalTratamento" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
      <div style="background: white; border-radius: var(--radius-lg); width: 100%; max-width: 700px; padding: 2.5rem; position: relative; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); max-height: 90vh; overflow-y: auto;">
        <button id="btnFecharTratamento" style="position: absolute; top: 1.5rem; right: 1.5rem; background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-text-muted);">&times;</button>
        <h2 style="font-size: 1.3rem; color: var(--color-danger); margin-bottom: 0.5rem; font-weight: 600;">Apurar Denúncia: <span id="modalProtocoloText" style="color: var(--color-text);"></span></h2>
        <p style="color: var(--color-text-muted); font-size: 0.85rem; margin-bottom: 2rem;">Leia atentamente o relato original. Modifique o status de apuração de acordo com a investigação.</p>
        
        <div style="background: #f8fafc; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1.5rem; margin-bottom: 2rem; font-family: monospace; font-size: 0.85rem; color: var(--color-text); white-space: pre-wrap; line-height: 1.5;" id="modalRelatoCompleto">
          <!-- Texto da denúncia será injetado aqui -->
        </div>

        <form id="formTratamento" style="display: flex; flex-direction: column; gap: 1.5rem;">
           <div>
             <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">ATUALIZAR STATUS DA INVESTIGAÇÃO</label>
             <select id="selectStatusTratamento" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; background: white;">
               <option value="Nova Denúncia">Nova Denúncia (Pendente)</option>
               <option value="Em Apuração">Em Apuração (Tratativa Iniciada)</option>
               <option value="Resolvida">Resolvida / Arquivada (Conclusão)</option>
             </select>
           </div>
           
           <div>
             <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">AÇÃO TOMADA PELO COMITÊ DE ÉTICA</label>
             <textarea id="textoAcaoTomada" rows="3" placeholder="Descreva os fatos apurados, sindicâncias abertas ou advertências aplicadas..." style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); outline: none; resize: none; font-family: inherit;"></textarea>
           </div>

           <div>
             <label style="display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text-muted);">EVIDÊNCIAS DE INVESTIGAÇÃO (ANEXOS RESTRITOS)</label>
             <div style="border: 2px dashed var(--color-border); padding: 1.5rem; border-radius: var(--radius-md); text-align: center; color: var(--color-text-muted); font-size: 0.8rem; cursor: pointer; background: #fafafa;">
               Clique para anexar atas, imagens de câmeras, depoimentos... (Apenas o comitê terá acesso)
             </div>
           </div>
           
           <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
             <button type="button" id="btnCancelarTratamento" class="btn btn-outline" style="padding: 0.75rem 1.5rem;">FECHAR</button>
             <button type="button" id="btnSalvarTratamento" class="btn btn-primary" style="padding: 0.75rem 1.5rem; background: var(--color-danger); border-color: var(--color-danger);">
               SALVAR APURAÇÃO
             </button>
           </div>
        </form>
      </div>
    </div>

  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
       // Filtros
       const filtroStatus = document.getElementById('filtroStatus');
       const filtroPeriodo = document.getElementById('filtroPeriodo');
       const rows = document.querySelectorAll('.denuncia-row');

       const aplicarFiltros = () => {
         const status = (filtroStatus as HTMLSelectElement).value;
         const periodoStr = (filtroPeriodo as HTMLSelectElement).value;
         const agora = new Date();

         rows.forEach(row => {
           const rowStatus = row.getAttribute('data-status');
           const rowDateISO = row.getAttribute('data-date');
           const rowDate = new Date(rowDateISO || '');
           
           // Status Match
           let matchStatus = false;
           if (status === 'todas') matchStatus = true;
           else if (status === 'Resolvida' && rowStatus === 'Resolvida') matchStatus = true;
           else if (status === rowStatus) matchStatus = true;
           
           // Date Match
           let matchDate = true;
           if (periodoStr !== 'todos') {
             const dias = parseInt(periodoStr);
             const difMs = agora.getTime() - rowDate.getTime();
             const difDias = difMs / (1000 * 60 * 60 * 24);
             if (difDias > dias) matchDate = false;
           }

           if (matchStatus && matchDate) {
             (row as HTMLElement).style.display = 'flex';
           } else {
             (row as HTMLElement).style.display = 'none';
           }
         });
       };

       if (filtroStatus) filtroStatus.addEventListener('change', aplicarFiltros);
       if (filtroPeriodo) filtroPeriodo.addEventListener('change', aplicarFiltros);

       // Modal Logic
       const modal = document.getElementById('modalTratamento');
       const btnFechar = document.getElementById('btnFecharTratamento');
       const btnCancelar = document.getElementById('btnCancelarTratamento');
       const btnSalvar = document.getElementById('btnSalvarTratamento');
       
       const modalProtocoloText = document.getElementById('modalProtocoloText');
       const modalRelatoCompleto = document.getElementById('modalRelatoCompleto');
       const selectStatusTratamento = document.getElementById('selectStatusTratamento');

       const btnsTratar = document.querySelectorAll('.btnTratar');
       btnsTratar.forEach(btn => {
         btn.addEventListener('click', (e) => {
            const target = e.currentTarget as HTMLButtonElement;
            const protocolo = target.getAttribute('data-protocolo');
            const texto = target.getAttribute('data-texto');
            const status = target.getAttribute('data-status');
            
            if (modalProtocoloText) modalProtocoloText.textContent = protocolo;
            if (modalRelatoCompleto) modalRelatoCompleto.textContent = texto || 'Nenhum texto informado.';
            if (selectStatusTratamento) (selectStatusTratamento as HTMLSelectElement).value = status || '';

            if (modal) modal.style.display = 'flex';
         });
       });

       const fecharModal = () => { if (modal) modal.style.display = 'none'; };
       if (btnFechar) btnFechar.addEventListener('click', fecharModal);
       if (btnCancelar) btnCancelar.addEventListener('click', fecharModal);
       if (modal) modal.addEventListener('click', (e) => { if (e.target === modal) fecharModal(); });
       
       if (btnSalvar) {
         btnSalvar.addEventListener('click', () => {
           alert('Status da denúncia atualizado e ações registradas no histórico confidencial.');
           fecharModal();
         });
       }

       // Cópia do Link do Canal
       const btnCopiar = document.getElementById('btnCopiarLink');
       const linkCode = document.getElementById('canalLink');
       if (btnCopiar && linkCode) {
         btnCopiar.addEventListener('click', () => {
           const urlCompleta = window.location.origin + linkCode.textContent;
           navigator.clipboard.writeText(urlCompleta).then(() => {
             const originalText = btnCopiar.textContent;
             btnCopiar.textContent = 'COPIADO!';
             btnCopiar.style.background = '#10b981';
             setTimeout(() => {
               btnCopiar.textContent = originalText;
               btnCopiar.style.background = '#ef4444';
             }, 2000);
           });
         });
       }
    });
  </script>
</Layout>
