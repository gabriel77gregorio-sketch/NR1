    position: relative;
    z-index: 1;
  }
  
  .risk-card:hover {
    transform: translateY(-5px);
  }

  .card-tooltip {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    color: white;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 10;
    border-radius: 14px;
    text-align: center;
  }

  .risk-card:hover .card-tooltip {
    opacity: 1;
    visibility: visible;
  }

  .risk-card:hover .card-icon {
    transform: scale(1.1);
    opacity: 0.05;
  }

  .table-row:hover {
    background: #fbfbfc;
  }

  @keyframes pulse {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
    70% { transform: scale(1.02); box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
  }
</style>
