---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import { ClienteMasterService } from '../../services/ClienteMasterService';

const supabaseClient = supabase(Astro);
const { data: { user } } = await supabaseClient.auth.getUser();

if (!user) {
  return Astro.redirect('/login');
}

const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome, role').eq('id', user.id).single();

if (!perfil || perfil.role !== 'SuperAdmin') {
  return Astro.redirect('/rh/dashboard');
}

const masterService = new ClienteMasterService();
let msgErro = null;
let msgSucesso = null;

// Salvar configurações globais
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "save_config") {
      await masterService.salvarConfiguracoes({
        nome_plataforma: formData.get("nome_plataforma")?.toString(),
        email_suporte: formData.get("email_suporte")?.toString(),
        modo_manutencao: formData.get("modo_manutencao") === "on",
        limite_usuarios_trial: parseInt(formData.get("limite_usuarios_trial")?.toString() || "10")
      });
      msgSucesso = "Configurações globais atualizadas!";
    } else if (action === "delete_cliente") {
      const empresaId = formData.get("empresa_id")?.toString();
      if (empresaId) {
        await masterService.deletarCliente(empresaId);
        msgSucesso = "Cliente removido com sucesso!";
      }
    }
  } catch (err: any) {
    msgErro = err.message || "Erro ao processar solicitação.";
  }
}

// Carregar Dados
const config = await masterService.getConfiguracoes();
const clients = await masterService.listarClientes();

// Cálculo de uso técnico (proxy)
const usageData = clients.map(c => ({
  nome: c.nome,
  id: c.id,
  colaboradores: c.colaboradores_base?.[0]?.count || 0,
  pesquisas: c.campanhas_pesquisa?.[0]?.count || 0,
  denuncias: c.denuncias_anonimas?.[0]?.count || 0,
  planos: c.planos_de_acao_pgr?.[0]?.count || 0,
  total_rows: (c.colaboradores_base?.[0]?.count || 0) + (c.campanhas_pesquisa?.[0]?.count || 0) + (c.denuncias_anonimas?.[0]?.count || 0) + (c.planos_de_acao_pgr?.[0]?.count || 0)
}));

const totalRowsSystem = usageData.reduce((acc, curr) => acc + curr.total_rows, 0);
---

<Layout title="Configurações Master | NR1">
  <div class="app-layout" style="background: #fdfbff; background-image: radial-gradient(#e2e8f0 0.5px, transparent 0.5px); background-size: 24px 24px; min-height: 100vh; display: flex;">
    
    <!-- Sidebar (Identica ao dashboard para consistencia) -->
    <aside class="sidebar" style="width: 280px; background: white; border-right: 1px solid var(--color-border); box-shadow: 4px 0 24px rgba(0,0,0,0.02); display: flex; flex-direction: column;">
      <div style="padding: 2rem 1.5rem; border-bottom: 1px solid var(--color-border);">
        <h1 class="gradient-text" style="font-size: 1.75rem; margin: 0; display: flex; align-items: center; gap: 0.75rem; letter-spacing: -0.5px;">
          <div style="width: 32px; height: 32px; background: var(--color-primary); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white;">
            <svg style="width: 20px; height: 20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
          </div>
          NR1 MASTER
        </h1>
      </div>
      
      <nav style="flex: 1; padding: 1.5rem 1rem;">
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          <li>
            <a href="/dashboard" class="nav-link" style="display: flex; align-items: center; padding: 0.875rem 1.25rem; color: var(--color-text-muted); border-radius: 12px; text-decoration: none; font-size: 0.9rem; font-weight: 500; gap: 1rem; transition: all 0.2s;">
              <svg style="width: 20px; height: 20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
              Gestão de Clientes
            </a>
          </li>
          <li>
            <a href="/adm/configuracoes" class="nav-link active" style="display: flex; align-items: center; padding: 0.875rem 1.25rem; background: var(--color-secondary); color: var(--color-primary); border-radius: 12px; text-decoration: none; font-size: 0.9rem; font-weight: 600; gap: 1rem; transition: all 0.2s;">
              <svg style="width: 20px; height: 20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33h.09a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
              Configurações
            </a>
          </li>
        </ul>
      </nav>

      <div style="padding: 1.5rem; border-top: 1px solid var(--color-border);">
        <a href="/login" style="display: flex; align-items: center; color: var(--color-danger); text-decoration: none; font-size: 0.9rem; font-weight: 600; gap: 1rem; padding: 0.75rem 1.25rem; border-radius: 12px; transition: background 0.2s;">
          <svg style="width: 20px; height: 20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Encerrar Sessão
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content" style="flex: 1; padding: 2.5rem 3.5rem;">
      
      {msgErro && (
        <div class="glass" style="background: #fff5f5; border-color: #feb2b2; color: #c53030; padding: 1.25rem; border-radius: var(--radius-lg); margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;">
          <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
          <span style="font-weight: 500;">{msgErro}</span>
        </div>
      )}

      {msgSucesso && (
        <div class="glass" style="background: #f0fff4; border-color: #9ae6b4; color: #276749; padding: 1.25rem; border-radius: var(--radius-lg); margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;">
          <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
          <span style="font-weight: 500;">{msgSucesso}</span>
        </div>
      )}

      <header style="margin-bottom: 3rem;">
        <h2 style="font-size: 2.25rem; font-weight: 800; color: var(--color-text); margin: 0; letter-spacing: -1px;">Configurações do Sistema</h2>
        <p style="color: var(--color-text-muted); font-size: 1.125rem; margin-top: 0.5rem;">Ajustes globais da plataforma e auditoria técnica de recursos.</p>
      </header>

      <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 2.5rem;">
        
        <!-- Preferências Globais -->
        <section>
          <div class="card" style="padding: 2rem;">
            <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem;">
              <svg style="width: 20px; height: 20px; color: var(--color-primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
              Preferências da Plataforma
            </h3>
            
            <form method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
              <input type="hidden" name="action" value="save_config" />
              
              <div>
                <label style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; margin-bottom: 0.5rem;">Nome da Aplicação</label>
                <input type="text" name="nome_plataforma" value={config.nome_plataforma} style="width: 100%; padding: 0.875rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 10px; outline: none;" />
              </div>

              <div>
                <label style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; margin-bottom: 0.5rem;">E-mail de Suporte Técnico</label>
                <input type="email" name="email_suporte" value={config.email_suporte} style="width: 100%; padding: 0.875rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 10px; outline: none;" />
              </div>

              <div>
                <label style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; margin-bottom: 0.5rem;">Limite de Usuários (Trial)</label>
                <input type="number" name="limite_usuarios_trial" value={config.limite_usuarios_trial} style="width: 100%; padding: 0.875rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 10px; outline: none;" />
              </div>

              <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: #f8fafc; border-radius: 10px;">
                <div>
                  <p style="font-size: 0.875rem; font-weight: 700; color: var(--color-text); margin: 0;">Modo Manutenção</p>
                  <p style="font-size: 0.75rem; color: var(--color-text-muted); margin: 0;">Bloqueia o acesso de todos os clientes.</p>
                </div>
                <input type="checkbox" name="modo_manutencao" checked={config.modo_manutencao} style="width: 20px; height: 20px; accent-color: var(--color-primary);" />
              </div>

              <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; border-radius: 10px; font-weight: 700;">
                SALVAR ALTERAÇÕES
              </button>
            </form>
          </div>
        </section>

        <!-- Uso Técnico por Cliente -->
        <section>
          <div class="card" style="padding: 0; overflow: hidden;">
            <div style="padding: 2rem; border-bottom: 1px solid var(--color-border);">
              <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.75rem;">
                <svg style="width: 20px; height: 20px; color: #0891b2;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path><path d="M22 12A10 10 0 0 0 12 2v10z"></path></svg>
                Métricas de Uso de Dados
              </h3>
              <p style="font-size: 0.875rem; color: var(--color-text-muted); margin: 0;">Detalhamento de volumetria por tenant (empresa).</p>
            </div>

            <div style="overflow-x: auto;">
              <table style="width: 100%; border-collapse: collapse;">
                <thead>
                  <tr style="background: #f8fafc; border-bottom: 1px solid var(--color-border);">
                    <th style="padding: 1rem 1.5rem; text-align: left; font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase;">Cliente</th>
                    <th style="padding: 1rem 1.5rem; text-align: center; font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase;">Funcionários</th>
                    <th style="padding: 1rem 1.5rem; text-align: center; font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase;">Pesquisas</th>
                    <th style="padding: 1rem 1.5rem; text-align: center; font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase;">Ações/Docs</th>
                    <th style="padding: 1rem 1.5rem; text-align: center; font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase;">Peso DB</th>
                    <th style="padding: 1rem 1.5rem; text-align: center; font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase;">Ações</th>
                  </tr>
                </thead>
                <tbody>
                  {usageData.map((data) => (
                    <tr style="border-bottom: 1px solid #f1f5f9;">
                      <td style="padding: 1rem 1.5rem; font-weight: 600; color: var(--color-text);">{data.nome}</td>
                      <td style="padding: 1rem 1.5rem; text-align: center;">{data.colaboradores}</td>
                      <td style="padding: 1rem 1.5rem; text-align: center;">{data.pesquisas}</td>
                      <td style="padding: 1rem 1.5rem; text-align: center;">{data.planos + data.denuncias}</td>
                      <td style="padding: 1rem 1.5rem; text-align: center;">
                        <div style="display: flex; align-items: center; gap: 0.5rem; justify-content: center;">
                          <div style="flex: 1; min-width: 60px; height: 6px; background: #e2e8f0; border-radius: 3px; overflow: hidden;">
                            <div style={`width: ${Math.min((data.total_rows / (totalRowsSystem || 1)) * 100, 100)}%; height: 100%; background: var(--color-primary);`}></div>
                          </div>
                          <span style="font-size: 0.7rem; font-weight: 700; color: var(--color-text-muted);">
                             {((data.total_rows / (totalRowsSystem || 1)) * 100).toFixed(1)}%
                          </span>
                        </div>
                      </td>
                      <td style="padding: 1rem 1.5rem; text-align: center;">
                        <form method="POST" onsubmit="return confirm('Excluir este cliente permanentemente?');" style="margin: 0;">
                          <input type="hidden" name="action" value="delete_cliente" />
                          <input type="hidden" name="empresa_id" value={data.id} />
                          <button type="submit" title="Excluir Cliente" style="background: #fff1f2; border: 1px solid #fecaca; width: 32px; height: 32px; border-radius: 6px; color: #ef4444; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                          </button>
                        </form>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div style="padding: 1.5rem; background: #f8fafc; border-top: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center;">
               <span style="font-size: 0.8rem; color: var(--color-text-muted);">Total de registros gerenciados:</span>
               <span style="font-weight: 800; color: var(--color-primary);">{totalRowsSystem} rows</span>
            </div>
          </div>
        </section>

      </div>
    </main>
  </div>
</Layout>

<style>
  .nav-link:hover {
    background: #f8fafc;
    color: var(--color-primary) !important;
  }
  .nav-link.active {
    background: var(--color-secondary);
    color: var(--color-primary) !important;
  }
</style>
