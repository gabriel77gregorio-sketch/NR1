---
import { supabase } from '../lib/supabase';

const supabaseClient = supabase(Astro);
const { data: { session } } = await supabaseClient.auth.getSession();

if (session) {
  const { data: perfil } = await supabaseClient
    .from('perfis_usuarios')
    .select('role')
    .eq('id', session.user.id)
    .single();
    
  if (perfil?.role === 'SuperAdmin') {
    return Astro.redirect('/dashboard');
  } else {
    return Astro.redirect('/rh/dashboard');
  }
}

return Astro.redirect('/login');
---

<Layout title="Dashboard">
  <main class="container" style="padding-top: 4rem;">
    <div class="card" style="text-align: center; max-width: 600px; margin: 0 auto;">
      <h1 style="margin-bottom: 1rem; color: var(--color-primary);">Segurament</h1>
      <p style="color: var(--color-text-muted); margin-bottom: 2rem;">
        Plataforma em modo SSR ativa. O sistema está aguardando configurações de autenticação.
      </p>
      <a href="/login" class="btn btn-primary">Acessar Sistema</a>
    </div>
  </main>
</Layout>
