---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import { ClienteMasterService } from '../services/ClienteMasterService';

const supabaseClient = supabase(Astro);
const { data: { user } } = await supabaseClient.auth.getUser();

if (!user) {
  return Astro.redirect('/login');
}

let userPerfil = { email: user.email || '', name: 'Admin Master' };
const { data: perfil } = await supabaseClient.from('perfis_usuarios').select('nome, role').eq('id', user.id).single();

if (!perfil || perfil.role !== 'SuperAdmin') {
  return Astro.redirect('/rh/inicio');
}

userPerfil.name = perfil.nome;

const masterService = new ClienteMasterService();
let msgErro = null;
let msgSucesso = null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    await masterService.provisionarNovoCliente({
      nome_empresa: formData.get("nome_empresa")?.toString() || '',
      cnpj: formData.get("cnpj")?.toString() || '',
      nome_admin: formData.get("nome_admin")?.toString() || '',
      email_admin: formData.get("email_admin")?.toString() || '',
      senha_provisoria: formData.get("senha_provisoria")?.toString() || '',
    });
    msgSucesso = "Cliente e acessos criados com sucesso!";
  } catch (err: any) {
    msgErro = err.message || "Erro desconhecido ao provisionar cliente.";
  }
}

let clientsDb = [];
try {
  clientsDb = await masterService.listarClientes();
} catch (e) {
  console.log("Erro ao carregar clientes.");
}

// Estatísticas globais
const totalClientes = clientsDb.length;
const totalPlanos = (clientsDb || []).reduce((acc, c) => acc + (c.planos_de_acao_pgr?.[0]?.count || 0), 0);
const totalDenuncias = (clientsDb || []).reduce((acc, c) => acc + (c.denuncias_anonimas?.[0]?.count || 0), 0);
---

<Layout title="Master Admin Dashboard">
  <div class="app-layout" style="background: #fdfbff; background-image: radial-gradient(#e2e8f0 0.5px, transparent 0.5px); background-size: 24px 24px;">
    
    <!-- Sidebar Premium -->
    <aside class="sidebar" style="width: 280px; background: white; border-right: 1px solid var(--color-border); box-shadow: 4px 0 24px rgba(0,0,0,0.02);">
      <div style="padding: 2rem 1.5rem; border-bottom: 1px solid var(--color-border);">
        <h1 class="gradient-text" style="font-size: 1.75rem; margin: 0; display: flex; align-items: center; gap: 0.75rem; letter-spacing: -0.5px;">
          <div style="width: 32px; height: 32px; background: var(--color-primary); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white;">
            <svg style="width: 20px; height: 20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
          </div>
          NR1 MASTER
        </h1>
      </div>
      
      <div style="padding: 1.5rem; border-bottom: 1px solid var(--color-border);">
        <div style="display: flex; align-items: center; gap: 1rem; padding: 0.75rem; background: #f8fafc; border-radius: var(--radius-lg);">
          <div style="width: 40px; height: 40px; border-radius: 12px; background: var(--color-secondary); display: flex; align-items: center; justify-content: center; color: var(--color-primary);">
            <svg style="width: 24px; height: 24px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </div>
          <div style="overflow: hidden;">
            <p style="font-size: 0.875rem; font-weight: 700; color: var(--color-text); margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{userPerfil.name}</p>
            <p style="font-size: 0.75rem; color: var(--color-text-muted); margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{userPerfil.email}</p>
          </div>
        </div>
      </div>

      <nav style="flex: 1; padding: 1.5rem 1rem;">
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          <li>
            <a href="#" style="display: flex; align-items: center; padding: 0.875rem 1.25rem; background: var(--color-secondary); color: var(--color-primary); border-radius: 12px; text-decoration: none; font-size: 0.9rem; font-weight: 600; gap: 1rem; transition: all 0.2s;">
              <svg style="width: 20px; height: 20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
              Gestão de Clientes
            </a>
          </li>
          <li>
            <a href="/adm/configuracoes" class="nav-link" style="display: flex; align-items: center; padding: 0.875rem 1.25rem; color: var(--color-text-muted); border-radius: 12px; text-decoration: none; font-size: 0.9rem; font-weight: 500; gap: 1rem; transition: all 0.2s;">
              <svg style="width: 20px; height: 20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33h.09a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
              Configurações
            </a>
          </li>
        </ul>
      </nav>

      <div style="padding: 1.5rem; border-top: 1px solid var(--color-border);">
        <a href="/login" style="display: flex; align-items: center; color: var(--color-danger); text-decoration: none; font-size: 0.9rem; font-weight: 600; gap: 1rem; padding: 0.75rem 1.25rem; border-radius: 12px; transition: background 0.2s;">
          <svg style="width: 20px; height: 20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Encerrar Sessão
        </a>
      </div>
    </aside>

    <!-- Main Content Premium -->
    <main class="main-content" style="padding: 2.5rem 3.5rem;">
      
      <!-- Top Feedback Messages -->
      {msgErro && (
        <div class="glass" style="background: #fff5f5; border-color: #feb2b2; color: #c53030; padding: 1.25rem; border-radius: var(--radius-lg); margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;">
          <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
          <span style="font-weight: 500;">{msgErro}</span>
        </div>
      )}

      {msgSucesso && (
        <div class="glass" style="background: #f0fff4; border-color: #9ae6b4; color: #276749; padding: 1.25rem; border-radius: var(--radius-lg); margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;">
          <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
          <span style="font-weight: 500;">{msgSucesso}</span>
        </div>
      )}

      <!-- Dashboard Header -->
      <header style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem;">
        <div>
          <h2 style="font-size: 2.25rem; font-weight: 800; color: var(--color-text); margin: 0; letter-spacing: -1px;">Gerenciamento de Clientes</h2>
          <p style="color: var(--color-text-muted); font-size: 1.125rem; margin-top: 0.5rem;">Controle centralizado de tenants e acessos do ecossistema NR1.</p>
        </div>
        <button id="btnNovoCliente" class="btn btn-primary" style="padding: 0.875rem 1.75rem; font-size: 0.9rem; box-shadow: 0 10px 15px -3px rgba(107, 56, 150, 0.3);">
          <svg style="width: 20px; height: 20px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          NOVO CLIENTE
        </button>
      </header>

      <!-- Stats Overview Cards -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
        <div class="card" style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div style="padding: 0.5rem; background: #f0f9ff; color: #0369a1; border-radius: 10px;">
              <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <span style="font-size: 0.75rem; font-weight: 700; color: #059669; background: #ecfdf5; padding: 0.25rem 0.5rem; border-radius: 6px;">+12%</span>
          </div>
          <div>
            <p style="font-size: 0.875rem; font-weight: 600; color: var(--color-text-muted); margin: 0;">Total de Clientes</p>
            <p style="font-size: 1.75rem; font-weight: 800; color: var(--color-text); margin: 0;">{totalClientes}</p>
          </div>
        </div>

        <div class="card" style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div style="padding: 0.5rem; background: #fff7ed; color: #c2410c; border-radius: 10px;">
              <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
            </div>
          </div>
          <div>
            <p style="font-size: 0.875rem; font-weight: 600; color: var(--color-text-muted); margin: 0;">Planos Ativos (PGR)</p>
            <p style="font-size: 1.75rem; font-weight: 800; color: var(--color-text); margin: 0;">{totalPlanos}</p>
          </div>
        </div>

        <div class="card" style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div style="padding: 0.5rem; background: #fdf2f8; color: #be185d; border-radius: 10px;">
              <svg style="width: 24px; height: 24px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
            <span style="font-size: 0.75rem; font-weight: 700; color: #dc2626; background: #fef2f2; padding: 0.25rem 0.5rem; border-radius: 6px;">Critico</span>
          </div>
          <div>
            <p style="font-size: 0.875rem; font-weight: 600; color: var(--color-text-muted); margin: 0;">Alertas Pendentes</p>
            <p style="font-size: 1.75rem; font-weight: 800; color: var(--color-text); margin: 0;">{totalDenuncias}</p>
          </div>
        </div>
      </div>

      <!-- Main Data Table Container -->
      <div class="card" style="padding: 0; overflow: hidden; border: none; box-shadow: var(--shadow-lg);">
        <!-- Table Header / Actions -->
        <div style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center; background: #fafafa;">
          <div style="position: relative; width: 400px;">
            <svg style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--color-text-muted); width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" placeholder="Filtrar por nome ou CNPJ..." style="width: 100%; padding: 0.75rem 1rem 0.75rem 3rem; border: 1px solid var(--color-border); border-radius: 12px; font-family: inherit; font-size: 0.875rem; outline: none; background: white; transition: border-color 0.2s;" />
          </div>
          <div style="display: flex; gap: 0.75rem;">
            <button class="btn btn-outline" style="border-radius: 10px; text-transform: none; font-size: 0.875rem;">
              <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              Exportar
            </button>
          </div>
        </div>

        <!-- Table Content -->
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; min-width: 800px;">
            <thead>
              <tr style="background: #f8fafc; border-bottom: 1px solid var(--color-border);">
                <th style="padding: 1.25rem 2rem; text-align: left; font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Cliente</th>
                <th style="padding: 1.25rem 2rem; text-align: center; font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Indicadores Ativos</th>
                <th style="padding: 1.25rem 2rem; text-align: center; font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Tenant ID</th>
                <th style="padding: 1.25rem 2rem; text-align: center; font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Status</th>
                <th style="padding: 1.25rem 2rem; text-align: center; font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Ação</th>
              </tr>
            </thead>
            <tbody>
              {clientsDb.length === 0 ? (
                <tr>
                  <td colspan="5" style="padding: 4rem; text-align: center; color: var(--color-text-muted);">
                    <div style="display: flex; flex-direction: column; align-items: center; gap: 1rem;">
                      <svg style="width: 48px; height: 48px; color: #e2e8f0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                      <p>Nenhum cliente registrado na plataforma.</p>
                    </div>
                  </td>
                </tr>
              ) : clientsDb.map((client) => {
                const numPlanos = client.planos_de_acao_pgr?.[0]?.count || 0;
                const numDenuncias = client.denuncias_anonimas?.[0]?.count || 0;
                const numCampanhas = client.campanhas_pesquisa?.[0]?.count || 0;

                return (
                  <tr style="border-bottom: 1px solid #f1f5f9; transition: background 0.2s;">
                    <td style="padding: 1.5rem 2rem;">
                      <div style="display: flex; flex-direction: column;">
                        <span style="font-weight: 700; color: var(--color-text); font-size: 1rem;">{client.nome}</span>
                        <span style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.25rem;">CNPJ: {client.cnpj}</span>
                      </div>
                    </td>
                    <td style="padding: 1.5rem 2rem; text-align: center;">
                      <div style="display: flex; gap: 0.5rem; justify-content: center;">
                        <div title="Planos de Ação" style="display: flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.75rem; background: #f0f9ff; color: #0369a1; border-radius: 8px; font-size: 0.75rem; font-weight: 700;">
                          <svg style="width: 14px; height: 14px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                          {numPlanos}
                        </div>
                        <div title="Denúncias" style="display: flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.75rem; background: #fff1f2; color: #be123c; border-radius: 8px; font-size: 0.75rem; font-weight: 700;">
                          <svg style="width: 14px; height: 14px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path></svg>
                          {numDenuncias}
                        </div>
                        <div title="Campanhas" style="display: flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.75rem; background: #f0fdf4; color: #15803d; border-radius: 8px; font-size: 0.75rem; font-weight: 700;">
                          <svg style="width: 14px; height: 14px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle></svg>
                          {numCampanhas}
                        </div>
                      </div>
                    </td>
                    <td style="padding: 1.5rem 2rem; text-align: center;">
                      <code style="background: #f1f5f9; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; color: #475569;">{client.id.split('-')[0]}...</code>
                    </td>
                    <td style="padding: 1.5rem 2rem; text-align: center;">
                      <span style="display: inline-flex; align-items: center; gap: 0.35rem; background: #ecfdf5; color: #065f46; padding: 0.35rem 0.75rem; border-radius: 999px; font-size: 0.75rem; font-weight: 700;">
                        <span style="width: 6px; height: 6px; background: #10b981; border-radius: 50%;"></span>
                        Ativo
                      </span>
                    </td>
                    <td style="padding: 1.5rem 2rem; text-align: center;">
                      <a href="/login" class="btn btn-outline" style="padding: 0.5rem; min-width: 0; width: 36px; height: 36px; border-radius: 8px; color: var(--color-primary);">
                        <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                      </a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </main>

    <!-- Premium Creation Modal -->
    <div id="modalCliente" style="display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px); z-index: 1000; align-items: center; justify-content: center; padding: 1.5rem;">
      <div class="glass" style="background: white; border-radius: var(--radius-xl); width: 100%; max-width: 550px; padding: 2.5rem; position: relative; box-shadow: var(--shadow-xl); border: none;">
        <button id="btnFecharModal" style="position: absolute; top: 1.5rem; right: 1.5rem; background: #f1f5f9; border: none; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--color-text-muted); transition: all 0.2s;">&times;</button>
        
        <header style="margin-bottom: 2rem;">
          <h2 style="font-size: 1.5rem; font-weight: 800; color: var(--color-text); margin: 0; letter-spacing: -0.5px;">Provisionar Cliente</h2>
          <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-top: 0.5rem; line-height: 1.5;">Configuração de novo ambiente isolado e credenciais administrativas para o cliente.</p>
        </header>
        
        <form method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">
            <div style="grid-column: span 2;">
              <label style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--color-text); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Razão Social da Empresa</label>
              <input name="nome_empresa" type="text" required placeholder="Ex: Indústrias Brasil Ltda" style="width: 100%; padding: 0.875rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 12px; outline: none; font-family: inherit; font-size: 0.9rem;" />
            </div>
            <div>
              <label style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--color-text); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">CNPJ</label>
              <input id="inputCnpj" name="cnpj" type="text" required placeholder="00.000.000/0001-00" maxlength="18" style="width: 100%; padding: 0.875rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 12px; outline: none; font-family: inherit; font-size: 0.9rem;" />
            </div>
            <div>
              <label style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--color-text); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Nome do Admin RH</label>
              <input name="nome_admin" type="text" required placeholder="Ex: Maria Souza" style="width: 100%; padding: 0.875rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 12px; outline: none; font-family: inherit; font-size: 0.9rem;" />
            </div>
          </div>

          <div style="padding-top: 1.25rem; border-top: 1px dashed #e2e8f0; display: flex; flex-direction: column; gap: 1.25rem;">
            <div>
              <label style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--color-text); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">E-mail de Acesso (Login)</label>
              <input name="email_admin" type="email" required placeholder="admin@cliente.com.br" style="width: 100%; padding: 0.875rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 12px; outline: none; font-family: inherit; font-size: 0.9rem;" />
            </div>
            <div>
              <label style="display: block; font-size: 0.75rem; font-weight: 700; color: var(--color-text); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Senha Provisória</label>
              <input name="senha_provisoria" type="text" required placeholder="Mínimo 6 caracteres" style="width: 100%; padding: 0.875rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 12px; outline: none; font-family: inherit; font-size: 0.9rem;" />
            </div>
          </div>

          <div style="margin-top: 1.5rem;">
            <button id="btnSubmitProvisionar" type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; border-radius: 12px; font-size: 0.9rem; box-shadow: 0 4px 6px -1px rgba(107, 56, 150, 0.1);">
              <span id="labelSubmit">CRIAR CLIENTE NO SUPABASE</span>
              <span id="labelLoading" style="display: none; align-items: center; gap: 0.5rem;">
                <svg class="animate-spin" style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10" stroke-opacity="0.25"></circle><path d="M4 12a8 8 0 0 1 8-8" stroke-opacity="1"></path></svg>
                PROCESSANDO...
              </span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <style>
    .nav-link:hover {
      background: #f8fafc;
      color: var(--color-primary) !important;
    }
  </style>

  <script>
    function initDashboard() {
      const btnAbrir = document.getElementById('btnNovoCliente');
      const btnFechar = document.getElementById('btnFecharModal');
      const modal = document.getElementById('modalCliente');
      const form = modal?.querySelector('form');
      const inputCnpj = document.getElementById('inputCnpj') as HTMLInputElement;
      const btnSubmit = document.getElementById('btnSubmitProvisionar') as HTMLButtonElement;
      const labelSubmit = document.getElementById('labelSubmit');
      const labelLoading = document.getElementById('labelLoading');

      if (btnAbrir && modal) {
        btnAbrir.addEventListener('click', () => {
          modal.style.display = 'flex';
        });
      }

      if (btnFechar && modal) {
        btnFechar.addEventListener('click', () => {
          modal.style.display = 'none';
        });
      }

      if (modal) {
        modal.addEventListener('click', (e) => {
          if (e.target === modal) {
            modal.style.display = 'none';
          }
        });
      }

      if (inputCnpj) {
        inputCnpj.addEventListener('input', (e) => {
          let value = (e.target as HTMLInputElement).value.replace(/\D/g, '');
          if (value.length > 14) value = value.slice(0, 14);
          
          let maskedValue = '';
          if (value.length <= 2) maskedValue = value;
          else if (value.length <= 5) maskedValue = `${value.slice(0, 2)}.${value.slice(2)}`;
          else if (value.length <= 8) maskedValue = `${value.slice(0, 2)}.${value.slice(2, 5)}.${value.slice(5)}`;
          else if (value.length <= 12) maskedValue = `${value.slice(0, 2)}.${value.slice(2, 5)}.${value.slice(5, 8)}/${value.slice(8)}`;
          else maskedValue = `${value.slice(0, 2)}.${value.slice(2, 5)}.${value.slice(5, 8)}/${value.slice(8, 12)}-${value.slice(12)}`;
          
          (e.target as HTMLInputElement).value = maskedValue;
        });
      }

      if (form) {
        form.addEventListener('submit', () => {
          if (btnSubmit && labelSubmit && labelLoading) {
            btnSubmit.disabled = true;
            labelSubmit.style.display = 'none';
            labelLoading.style.display = 'flex';
            labelLoading.style.justifyContent = 'center';
          }
        });
      }
    }

    document.addEventListener('DOMContentLoaded', initDashboard);
    document.addEventListener('astro:page-load', initDashboard);
    initDashboard();
  </script>
</Layout>
