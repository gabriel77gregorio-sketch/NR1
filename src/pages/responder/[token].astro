---
import { supabase } from '../../lib/supabase';

// Lógica SSR Segura
const { token } = Astro.params;

let status = "carregando"; // 'pendente', 'concluido', 'invalido'
let messageErro = "";

// Para simular a visualização enquanto o banco DB não tem uma campanha 100% gravada
// Fallback inteligente para garantir sua visualização
if (!token || token.length < 10) {
  status = "invalido";
  messageErro = "O link fornecido está quebrado ou ausente.";
} else {
  status = "pendente"; // Mocking sucesso de leitura do DB
}

// Intercepta a Submissão (Finalização da pesquisa)
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    // Exemplo do que chegará: data.get("q1") // "Nunca", etc
    
    // Aqui fariamos a Query real no DB do Supabase usando a SERVICE KEY para gravar a Array de Respostas,
    // e dar Update table campanhas_participantes set status_resposta = 'Concluído'
    
    // Sucesso forçado para nossa demonstração visual
    status = "concluido";
    
  } catch (err) {
    console.error(err);
  }
}

// Questões Mockadas para demonstração
const mockPerguntas = [
  { id: 'q1', text: "O seu trabalho exige que você trabalhe muito rápido?" },
  { id: 'q2', text: "Você tem a possibilidade de influenciar na quantidade de trabalho que lhe é atribuído?" },
  { id: 'q3', text: "As suas tarefas de trabalho costumam ter sentido para você?" },
  { id: 'q4', text: "Você recebe informações adequadas para ser capaz de fazer o seu trabalho com qualidade?" },
  { id: 'q5', text: "Com que frequência você esconde seus sentimentos no local de trabalho?" }
];

const alternativas = ["Sempre", "Frequentemente", "Às vezes", "Raramente", "Nunca/Quase Nunca"];
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Avaliação Confidencial | RH NR1</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --color-primary: #6B3896; 
        --color-primary-hover: #5A2A82;
        --color-background: #F8F7F4;
        --color-surface: #FFFFFF;
        --color-text: #333333;
        --color-text-muted: #7E7E7E;
        --color-border: #E8E8E8;
        --radius-lg: 1rem;
        --radius-md: 0.5rem;
      }
      body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        background-color: var(--color-background);
        color: var(--color-text);
        -webkit-font-smoothing: antialiased;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
      .header {
        text-align: center;
        margin-bottom: 2.5rem;
      }
      .card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 2rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
      }
      .question-text {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        color: var(--color-text);
        line-height: 1.5;
      }
      
      /* Botões de Múltipla Escolha - Design Mobile First Responsivo */
      .radio-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }
      .radio-option {
        position: relative;
        display: flex;
        align-items: center;
        padding: 1rem;
        border: 2px solid var(--color-border);
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: all 0.2s ease;
        background: var(--color-surface);
      }
      .radio-option:hover {
        border-color: #E3D9EE;
        background: #F8F7F4;
      }
      .radio-option input[type="radio"] {
        position: absolute;
        opacity: 0;
      }
      .radio-option .radio-label {
        font-weight: 500;
        font-size: 0.95rem;
        color: var(--color-text);
        padding-left: 2rem;
      }
      .radio-option .custom-radio {
        position: absolute;
        width: 20px;
        height: 20px;
        border: 2px solid var(--color-border);
        border-radius: 50%;
        left: 1rem;
        transition: all 0.2s ease;
      }
      /* Estado Checked Visual */
      .radio-option input[type="radio"]:checked ~ .custom-radio {
        border-color: var(--color-primary);
        background-color: var(--color-primary);
        box-shadow: inset 0 0 0 4px var(--color-surface);
      }
      .radio-option input[type="radio"]:checked ~ .radio-label {
        color: var(--color-primary);
        font-weight: 700;
      }
      .radio-option:has(input[type="radio"]:checked) {
        border-color: var(--color-primary);
        background: #faf5ff;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 2rem;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 9999px;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        width: 100%;
        gap: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .btn-primary {
        background: var(--color-primary);
        color: white;
      }
      .btn-primary:hover {
        background: var(--color-primary-hover);
        transform: translateY(-2px);
      }
    </style>
  </head>
  <body>
    
    <div class="container">
      <div class="header">
        <div style="display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; background: #e2e8f0; border-radius: 12px; margin-bottom: 1rem; color: var(--color-primary);">
           <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        </div>
        <h1 style="color: var(--color-primary); font-size: 1.5rem; margin: 0 0 0.5rem 0;">Protocolo NR-1 Confidencial</h1>
        <p style="color: var(--color-text-muted); font-size: 0.85rem; margin: 0;">Sua participação ajuda a criar um ambiente de trabalho mais humano e seguro.</p>
      </div>

      {status === 'invalido' && (
        <div class="card" style="text-align: center; padding: 4rem 2rem;">
          <svg style="width: 48px; height: 48px; color: #ef4444; margin-bottom: 1rem; display: inline-block;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
          <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem;">Acesso Negado</h2>
          <p style="color: var(--color-text-muted);">{messageErro}</p>
        </div>
      )}

      {status === 'concluido' && (
        <div class="card" style="text-align: center; padding: 4rem 2rem; border-color: #10b981;">
          <div style="width: 64px; height: 64px; background: #dcfce7; color: #10b981; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
            <svg style="width: 32px; height: 32px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; color: #065f46;">Muito obrigado!</h2>
          <p style="color: var(--color-text-muted); line-height: 1.5;">Suas respostas foram criptografadas e enviadas para análise estatística do Departamento de Saúde Ocupacional.</p>
          <p style="color: var(--color-text-muted); font-size: 0.8rem; margin-top: 2rem;">Você pode fechar esta página.</p>
        </div>
      )}

      {status === 'pendente' && (
        <form method="POST">
          <div style="background: #e0f2fe; color: #0369a1; padding: 1rem; border-radius: var(--radius-md); margin-bottom: 2rem; font-size: 0.85rem; display: flex; gap: 0.75rem; align-items: flex-start;">
            <svg style="width: 20px; height: 20px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            <div>
              <strong>Respostas em Sigilo.</strong> Nenhuma informação de identidade será cruzada ao gerar a Matriz de Riscos Psicossociais pelo seu RH. Suas respostas são inteiramente agrupadas.
            </div>
          </div>

          <!-- Question Loop -->
          {mockPerguntas.map((perg, idx) => (
            <div class="card">
              <div style="font-size: 0.75rem; font-weight: 700; color: var(--color-primary); margin-bottom: 0.5rem; text-transform: uppercase;">
                Questão {idx + 1} de {mockPerguntas.length}
              </div>
              <div class="question-text">
                {perg.text}
              </div>
              
              <div class="radio-group">
                {alternativas.map((alt) => (
                  <label class="radio-option">
                    <input type="radio" name={perg.id} value={alt} required />
                    <span class="custom-radio"></span>
                    <span class="radio-label">{alt}</span>
                  </label>
                ))}
              </div>
            </div>
          ))}

          <div style="margin-top: 3rem; margin-bottom: 4rem;">
            <button type="submit" class="btn btn-primary">
               GRAVAR MINHAS RESPOSTAS
               <svg style="width: 20px; height: 20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 16 16 12 12 8"></polyline><line x1="8" y1="12" x2="16" y2="12"></line></svg>
            </button>
          </div>
        </form>
      )}

    </div>

  </body>
</html>
