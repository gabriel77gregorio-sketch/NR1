---
import { createClient } from '@supabase/supabase-js';

const { token } = Astro.params;
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || process.env.PUBLIC_SUPABASE_URL;
const serviceKey = import.meta.env.SUPABASE_SERVICE_KEY || process.env.SUPABASE_SERVICE_KEY;
const supabaseAdmin = createClient(supabaseUrl, serviceKey, { auth: { persistSession: false } });

let status = "pendente"; // 'pendente', 'concluido', 'invalido'
let messageErro = "";
let participanteData: any = null;
let templateQuestoes: any[] = [];
let empresaId = "";
let templateId = "";

// 1. Validar Token e buscar Campanha/Metodologia
try {
  const { data: participante, error: pError } = await supabaseAdmin
    .from('campanhas_participantes')
    .select(`
      *,
      campanhas_pesquisa (
        id,
        titulo,
        empresa_id,
        metodologia_id,
        metodologias_pesquisa (nome)
      ),
      colaboradores_base (
        id,
        departamento_id
      )
    `)
    .eq('token_acesso', token)
    .single();

  if (pError || !participante) {
    status = "invalido";
    messageErro = "O link fornecido é inválido ou expirou.";
  } else if (participante.status_resposta === 'Concluído') {
    status = "concluido";
  } else {
    participanteData = participante;
    empresaId = participante.campanhas_pesquisa.empresa_id;

    // Buscar o template de perguntas para COPSOQ
    const { data: template } = await supabaseAdmin
      .from('formularios_templates')
      .select('id, questoes')
      .ilike('titulo', '%COPSOQ%')
      .single();
    
    templateQuestoes = template?.questoes || [];
    templateId = template?.id || "";
  }
} catch (e) {
  status = "invalido";
  messageErro = "Erro ao processar sua solicitação.";
}

// 2. Intercepta a Submissão (Finalização da pesquisa)
if (Astro.request.method === "POST" && status === "pendente") {
  try {
    const formData = await Astro.request.formData();
    const respostasProcessadas: any[] = [];
    let redFlagsCount = 0;

    // Lógica de Conversão e Pontuação
    templateQuestoes.forEach(eixo => {
      eixo.perguntas.forEach((p: any) => {
        const valorString = formData.get(p.id)?.toString();
        if (valorString) {
          const valorOriginal = parseInt(valorString);
          let pontos = 0;
          const escala = [0, 25, 50, 75, 100];
          
          if (p.polaridade === 'Inversa') {
            pontos = escala[5 - valorOriginal];
          } else {
            pontos = escala[valorOriginal - 1];
          }

          // Se for Eixo 6 (Red Flags), checar se houve ocorrência (valor > 1)
          if (eixo.tipo === 'RedFlag' && valorOriginal > 1) {
            redFlagsCount++;
          }

          respostasProcessadas.push({
            pergunta_id: p.id,
            valor_original: valorOriginal,
            pontos: pontos,
            eixo: eixo.eixo,
            tipo: eixo.tipo || 'Normal'
          });
        }
      });
    });

    // 3. Salvar Respostas Anônimas
    const { error: insertError } = await supabaseAdmin.from('respostas_avaliacoes').insert({
      empresa_id: empresaId,
      formulario_id: templateId, // ID correto do template (FK)
      respostas: {
        detalhes: respostasProcessadas,
        setor_id: participanteData.colaboradores_base?.departamento_id,
        red_flags: redFlagsCount,
        data_resposta: new Date().toISOString()
      }
    });

    if (insertError) {
      console.error('Erro detalhado ao salvar respostas_avaliacoes:', insertError);
      throw new Error('Falha ao salvar no banco de dados');
    }

    // 4. Marcar participante como concluído
    const { error: updateError } = await supabaseAdmin.from('campanhas_participantes')
      .update({ status_resposta: 'Concluído', respondido_em: new Date().toISOString() })
      .eq('id', participanteData.id);

    if (updateError) {
      console.error('Erro ao atualizar status_resposta:', updateError);
    }

    status = "concluido";
  } catch (err) {
    console.error('Erro ao salvar respostas:', err);
    status = "invalido";
    messageErro = "Falha ao salvar suas respostas. Tente novamente.";
  }
}

const alternativas = [
  { valor: 1, texto: "Nunca / Quase nunca / Nada" },
  { valor: 2, texto: "Raramente / Um pouco" },
  { valor: 3, texto: "Às vezes / Moderadamente" },
  { valor: 4, texto: "Frequentemente / Muito" },
  { valor: 5, texto: "Sempre / Quase sempre / Extremamente" }
];
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Avaliação COPSOQ II | RH NR1</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --color-primary: #6B3896; 
        --color-primary-hover: #5A2A82;
        --color-background: #F8F7F4;
        --color-surface: #FFFFFF;
        --color-text: #333333;
        --color-text-muted: #7E7E7E;
        --color-border: #E8E8E8;
        --radius-lg: 1rem;
        --radius-md: 0.5rem;
      }
      body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        background-color: var(--color-background);
        color: var(--color-text);
        -webkit-font-smoothing: antialiased;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
      .header {
        text-align: center;
        margin-bottom: 2.5rem;
      }
      .card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
      }
      .eixo-title {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--color-primary);
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        letter-spacing: 1px;
        border-left: 4px solid var(--color-primary);
        padding-left: 0.75rem;
      }
      .question-block {
        margin-bottom: 2.5rem;
      }
      .question-text {
        font-size: 1.05rem;
        font-weight: 600;
        margin-bottom: 1.25rem;
        color: var(--color-text);
        line-height: 1.5;
      }
      .radio-group {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      .radio-option {
        position: relative;
        display: flex;
        align-items: center;
        padding: 0.85rem 1rem;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: all 0.2s ease;
      }
      .radio-option:hover {
        border-color: var(--color-primary);
        background: #fdfaff;
      }
      .radio-option input[type="radio"] {
        position: absolute;
        opacity: 0;
      }
      .radio-label {
        font-size: 0.9rem;
        font-weight: 500;
        padding-left: 2rem;
      }
      .custom-radio {
        position: absolute;
        width: 18px;
        height: 18px;
        border: 2px solid var(--color-border);
        border-radius: 50%;
        left: 1rem;
      }
      input[type="radio"]:checked ~ .custom-radio {
        border-color: var(--color-primary);
        background: var(--color-primary);
        box-shadow: inset 0 0 0 3px white;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1.25rem;
        font-size: 1rem;
        font-weight: 700;
        border-radius: 999px;
        cursor: pointer;
        border: none;
        width: 100%;
        transition: all 0.3s;
      }
      .btn-primary {
        background: var(--color-primary);
        color: white;
        box-shadow: 0 10px 15px -3px rgba(107, 56, 150, 0.3);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 25px -5px rgba(107, 56, 150, 0.4);
      }
    </style>
  </head>
  <body>
    
    <div class="container">
      <div class="header">
        <h1 style="color: var(--color-primary); font-size: 1.5rem; margin-bottom: 0.5rem;">Pesquisa COPSOQ II-Br</h1>
        <p style="color: var(--color-text-muted); font-size: 0.85rem;">Protocolo de Avaliação Psicossocial de acordo com a NR-1</p>
      </div>

      {status === 'invalido' && (
        <div class="card" style="text-align: center; padding: 4rem 2rem;">
          <h2 style="color: #ef4444;">Ops!</h2>
          <p>{messageErro}</p>
          <a href="/" style="color: var(--color-primary); font-weight: 600;">Voltar ao Início</a>
        </div>
      )}

      {status === 'concluido' && (
        <div class="card" style="text-align: center; padding: 5rem 2rem;">
          <div style="font-size: 4rem; margin-bottom: 1rem;">✅</div>
          <h2 style="color: #059669;">Respostas Enviadas!</h2>
          <p style="color: var(--color-text-muted); line-height: 1.6;">Muito obrigado pela sua participação. Seus dados foram salvos anonimamente e ajudarão a melhorar o ambiente de trabalho.</p>
        </div>
      )}

      {status === 'pendente' && (
        <form method="POST">
          <div style="background: #eff6ff; color: #1e40af; padding: 1.25rem; border-radius: var(--radius-md); margin-bottom: 2rem; font-size: 0.875rem; line-height: 1.5;">
            <strong>🔒 Sua privacidade é garantida.</strong> Este formulário é confidencial. Seus dados individuais não serão compartilhados com a chefia; apenas os resultados agrupados por setor serão analisados.
          </div>

          {templateQuestoes.map((eixo) => (
            <div class="card">
              <div class="eixo-title">{eixo.eixo}</div>
              
              {eixo.perguntas.map((perg: any) => (
                <div class="question-block">
                  <div class="question-text">{perg.texto}</div>
                  <div class="radio-group">
                    {alternativas.map((alt) => (
                      <label class="radio-option">
                        <input type="radio" name={perg.id} value={alt.valor} required />
                        <span class="custom-radio"></span>
                        <span class="radio-label">{alt.texto}</span>
                      </label>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          ))}

          <div style="margin-top: 2rem; margin-bottom: 5rem;">
            <button type="submit" class="btn btn-primary">FINALIZAR E ENVIAR RESPOSTAS</button>
          </div>
        </form>
      )}
    </div>

  </body>
</html>
