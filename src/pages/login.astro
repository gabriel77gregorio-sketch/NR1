---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

let errorMsg = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get('email')?.toString();
    const password = formData.get('password')?.toString();

    const supabaseClient = supabase(Astro);
    const { data: authData, error } = await supabaseClient.auth.signInWithPassword({
      email: email || '',
      password: password || '',
    });

    if (error) {
      errorMsg = error.message;
    } else if (authData && authData.user) {
      const { data: perfil } = await supabaseClient
        .from('perfis_usuarios')
        .select('role')
        .eq('id', authData.user.id)
        .single();
        
      if (perfil && (perfil as any).role === 'SuperAdmin') {
        return Astro.redirect('/dashboard');
      } else {
        return Astro.redirect('/rh/dashboard');
      }
    }
  } catch (error: any) {
    errorMsg = error?.message || 'Erro inesperado ao fazer login';
  }
}
---

<Layout title="Login | NR1 SaaS">
  <main class="login-split-container">
    
    <!-- Lado Esquerdo: Formulário -->
    <div class="login-left">
      <div class="login-content">
        <div class="brand-logo">
           <span style="font-weight: 900; font-size: 1.5rem; color: #1e3a8a; letter-spacing: -1px;">NR1</span>
           <span style="font-weight: 300; font-size: 1.5rem; color: #64748b;">Compliance</span>
        </div>

        <div class="login-header">
          <p class="overline">PLATAFORMA RH</p>
          <h1>Acesse a NR1</h1>
          <p class="subtitle">Sua plataforma de gestão ocupacional com inteligência e performance.</p>
        </div>

        {errorMsg && (
          <div class="error-alert">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            {errorMsg}
          </div>
        )}

        <form method="POST" class="login-form">
          <div class="form-group">
            <label for="email">E-mail corporativo</label>
            <div class="input-wrapper">
              <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              <input type="email" name="email" id="email" required placeholder="seu.nome@empresa.com.br" />
            </div>
          </div>
          
          <div class="form-group">
            <label for="password">Senha</label>
            <div class="input-wrapper">
              <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              <input type="password" name="password" id="password" required placeholder="••••••••" />
            </div>
          </div>

          <div class="form-actions">
            <a href="#" class="forgot-password">Esqueceu sua senha?</a>
          </div>

          <button type="submit" class="btn-login">Entrar na plataforma</button>
        </form>

        <footer class="login-footer">
           <p>© 2024 NR1 Compliance — Gestão de Pessoas com Inteligência</p>
        </footer>
      </div>
    </div>

    <!-- Lado Direito: Info / Marketing -->
    <div class="login-right">
      <div class="marketing-content">
        <p class="marketing-overline">GESTÃO DE RISCOS & PESSOAS</p>
        <h2 class="marketing-title">Conectando conformidade, <span class="highlight">estratégia e bem-estar.</span></h2>
        <p class="marketing-subtitle">A plataforma que transforma a adequação à NR-1 em inteligência competitiva, automação e dados — do diagnóstico ao plano de ação.</p>

        <ul class="feature-list">
          <li>
            <div class="feature-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div>
            <div class="feature-text">
              <strong>Diagnóstico Psicossocial Inteligente</strong>
              <span>Gestão automatizada do COPSOQ II-Br e inventário de riscos.</span>
            </div>
          </li>
          <li>
            <div class="feature-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
            <div class="feature-text">
              <strong>Gestão de Riscos (PGR / NR-1)</strong>
              <span>Matrizes de severidade dinâmicas e monitoramento de GHE.</span>
            </div>
          </li>
          <li>
            <div class="feature-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg></div>
            <div class="feature-text">
              <strong>Canal de Ética & Denúncias</strong>
              <span>Ambiente 100% anônimo para compliance e segurança psicológica.</span>
            </div>
          </li>
          <li>
            <div class="feature-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg></div>
            <div class="feature-text">
              <strong>Planos de Ação 5W2H</strong>
              <span>Transforme gargalos em intervenções práticas com prazos e responsáveis.</span>
            </div>
          </li>
          <li>
            <div class="feature-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path><path d="M22 12A10 10 0 0 0 12 2v10z"></path></svg></div>
            <div class="feature-text">
              <strong>People Analytics Integrado</strong>
              <span>Visão consolidada de KPIs, clima e riscos em tempo real.</span>
            </div>
          </li>
        </ul>

        <div class="legal-tag">
          <div class="dot"></div>
          <span>Dados protegidos em conformidade com a LGPD</span>
        </div>
      </div>
    </div>

  </main>
</Layout>

<style>
  .login-split-container {
    display: flex;
    min-height: 100vh;
    width: 100%;
    background: #fff;
    font-family: 'Inter', sans-serif;
  }

  .login-left {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .login-content {
    width: 100%;
    max-width: 440px;
    position: relative;
  }

  .brand-logo {
    margin-bottom: 1.5rem;
  }

  .overline {
    font-size: 0.75rem;
    font-weight: 800;
    color: #64748b;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }

  .login-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #0f172a;
    margin: 0;
    letter-spacing: -1px;
  }

  .login-header .subtitle {
    color: #64748b;
    margin-top: 0.75rem;
    font-size: 1rem;
    line-height: 1.5;
  }

  .login-form {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #334155;
    margin-bottom: 0.5rem;
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-icon {
    position: absolute;
    left: 1rem;
    color: #94a3b8;
  }

  .input-wrapper input {
    width: 100%;
    padding: 0.875rem 1rem 0.875rem 3rem;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 1rem;
    background: #f8fafc;
    transition: all 0.2s;
  }

  .input-wrapper input:focus {
    outline: none;
    border-color: #1e3a8a;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(30, 58, 138, 0.05);
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
  }

  .forgot-password {
    font-size: 0.875rem;
    color: #1e3a8a;
    text-decoration: none;
    font-weight: 600;
  }

  .btn-login {
    background: #0f172a;
    color: white;
    border: none;
    padding: 1rem;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 1rem;
  }

  .btn-login:hover {
    background: #1e293b;
  }

  .error-alert {
    background: #fef2f2;
    color: #991b1b;
    padding: 1rem;
    border-radius: 10px;
    margin-top: 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    border: 1px solid #fee2e2;
  }

  .login-footer {
    margin-top: 3rem;
    color: #94a3b8;
    font-size: 0.75rem;
  }

  /* Lado Direito */
  .login-right {
    flex: 1.2;
    background: linear-gradient(135deg, #020617 0%, #1e3a8a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 3rem;
    color: white;
    position: relative;
    overflow: hidden;
  }

  .login-right::before {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0; left: 0;
    background: radial-gradient(circle at top right, rgba(56, 189, 248, 0.1), transparent);
  }

  .marketing-content {
    max-width: 560px;
    position: relative;
    z-index: 2;
  }

  .marketing-overline {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 2px;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .marketing-title {
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -2px;
    margin-bottom: 1rem;
  }

  .highlight {
    color: #38bdf8;
  }

  .marketing-subtitle {
    font-size: 1rem;
    line-height: 1.5;
    color: #cbd5e1;
    margin-bottom: 1.5rem;
  }

  .feature-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feature-list li {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .feature-icon {
    background: rgba(255, 255, 255, 0.1);
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #38bdf8;
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .feature-text strong {
    display: block;
    font-size: 1rem;
    margin-bottom: 0.15rem;
  }

  .feature-text span {
    font-size: 0.875rem;
    color: #94a3b8;
  }

  .legal-tag {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: #94a3b8;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: #38bdf8;
    border-radius: 50%;
  }

  @media (max-width: 1024px) {
    .login-right {
      display: none;
    }
  }
</style>
